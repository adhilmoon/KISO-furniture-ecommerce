<%# Active link highlighting — pure CSS-driven via data-path %>
<script>
(function() {
    const path = window.location.pathname;
    document.querySelectorAll('.sidebar-link').forEach(link => {
        const linkPath = link.getAttribute('data-path');
        if (path === linkPath || path.startsWith(linkPath + '/')) {
            link.classList.remove('text-brand-muted', 'hover:text-brand-light', 'hover:bg-white/5');
            link.classList.add('text-brand-accent', 'bg-brand-accent/10', 'border', 'border-brand-accent/20');
            const icon = link.querySelector('span');
            if (icon) {
                icon.classList.remove('bg-white/5');
                icon.classList.add('bg-brand-accent/20');
            }
        }
    });
})();
</script>