<%# Active link highlighting — pure CSS-driven via data-path %>
<script>
(function() {
    const path = window.location.pathname;
    document.querySelectorAll('.sidebar-link').forEach(link => {
        const linkPath = link.getAttribute('data-path');
        if (path === linkPath || path.startsWith(linkPath + '/')) {
            link.classList.remove('text-brand-muted', 'hover:text-brand-light', 'hover:bg-white/5', 'border-transparent');
            link.classList.add('text-brand-light', 'bg-white/[0.03]');
            link.style.borderLeft = '2px solid #D8FF3E';
            link.style.borderTop = '1px solid rgba(255,255,255,0.05)';
            link.style.borderRight = '1px solid rgba(255,255,255,0.05)';
            link.style.borderBottom = '1px solid rgba(255,255,255,0.05)';
            const icon = link.querySelector('.sidebar-icon');
            if (icon) {
                icon.classList.remove('bg-white/5');
                icon.style.backgroundColor = 'rgba(216, 255, 62, 0.12)';
            }
            const num = link.querySelector('.font-mono');
            if (num) num.classList.add('text-neon');
        }
    });
})();
</script>
