<style>
  #main-nav.nav-scrolled {
    background: rgba(20, 18, 16, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
</style>

<nav id="main-nav"
  class="flex items-center justify-between px-6 md:px-12 py-5 fixed w-full top-0 z-50 transition-all duration-300 <%= locals.isProfilePage ? 'bg-brand-bg1 border-b border-white/5' : 'bg-transparent' %> text-stone-100">

  <div class="flex items-center gap-4">
    <% if(locals.isProfilePage) { %>
      <button id="mobile-profile-sidebar-toggle"
        class="md:hidden p-1 text-stone-100 hover:text-brand-accent transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
      <% } %>

        <a href="/" class="flex items-center gap-3 group">
          <span
            class="text-2xl font-bold tracking-tighter hover:text-brand-accent transition-colors duration-300">KISO</span>
        </a>
  </div>

  <ul class="hidden md:flex items-center gap-10 text-[13px] font-medium tracking-widest uppercase text-stone-300">
    <li><a href="/user/store" class="hover:text-stone-100 transition-colors duration-300">Store</a></li>
    <li class="relative">
      <button id="cat-dropdown-btn" class="hover:text-stone-100 transition-colors duration-300 uppercase flex items-center gap-1">
        Categories
        <svg id="cat-dropdown-arrow" class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div id="cat-dropdown-menu" class="absolute left-0 mt-4 w-48 bg-brand-bg1 border border-white/5 shadow-xl rounded-lg opacity-0 invisible translate-y-2 transition-all duration-300 flex flex-col pt-2 pb-2 z-[60]">
        <% if (locals.globalCategories && locals.globalCategories.length > 0) { %>
          <% globalCategories.forEach(category => { %>
            <a href="/user/store?category=<%= category._id %>" class="px-5 py-2.5 text-sm hover:bg-white/5 hover:text-brand-accent transition-colors"><%= category.categoryName %></a>
          <% }) %>
        <% } else { %>
            <span class="px-5 py-2.5 text-sm text-brand-muted">No Categories</span>
        <% } %>
      </div>
    </li>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('cat-dropdown-btn');
    const menu = document.getElementById('cat-dropdown-menu');
    const arrow = document.getElementById('cat-dropdown-arrow');

    if (btn && menu) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !menu.classList.contains('invisible');
        
        if (isOpen) {
          menu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          arrow.classList.remove('rotate-180');
        } else {
          menu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
          arrow.classList.add('rotate-180');
        }
      });

      document.addEventListener('click', (e) => {
        if (!menu.contains(e.target) && !btn.contains(e.target)) {
          menu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          arrow.classList.remove('rotate-180');
        }
      });
    }
  });
</script>
    <li><a href="/about" class="hover:text-stone-100 transition-colors duration-300">About</a></li>
  </ul>

  <div class="flex items-center gap-5 md:gap-6">

    <a href="<%= locals.user ? '/user/wishlist' : '/user/login' %>"
      class="p-2 text-stone-300 hover:text-brand-accent transition-colors group relative" title="Wishlist">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor"
        class="w-5 h-5 group-hover:scale-110 transition-transform">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
      </svg>
    </a>

    <a href="<%= locals.user ? '/user/cart' : '/user/login' %>"
      class="p-2 text-stone-300 hover:text-brand-accent transition-colors group relative mr-1 md:mr-2" title="Cart">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor"
        class="w-5 h-5 group-hover:scale-110 transition-transform">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
      </svg>
    </a>

    <% if (locals.user) { %>
      <a href="/user/profile" id="nav-profile-img"
        class="w-8 h-8 md:w-9 md:h-9 rounded-full bg-stone-800 flex items-center justify-center overflow-hidden border border-stone-700 hover:border-stone-100 transition-colors">
        <% if(user && user.avatar) { %>
          <img src="<%= user.avatar %>" alt="Profile" class="w-full h-full object-cover">
          <% } else { %>
            <span class="text-[10px] md:text-xs font-bold uppercase text-stone-100">
              <%= (user.name || user.username || 'U' ).charAt(0) %>
            </span>
            <% } %>
      </a>
      <% } else if (locals.title && locals.title !=='Login' ) { %>
        <a href="/user/login"
          class="text-[12px] font-bold tracking-widest uppercase border-b border-stone-100/30 hover:border-stone-100 transition-colors pb-0.5 text-stone-100">
          Login
        </a>
        <% } %>

          <% if(!locals.isProfilePage) { %>
            <button id="mobile-menu-btn" class="md:hidden p-1 text-stone-100 hover:text-stone-300">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                stroke="currentColor" class="w-7 h-7">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
            </button>
            <% } %>
  </div>
</nav>

<% if(!locals.isProfilePage) { %>
  <div id="mobile-sidebar-overlay"
    class="fixed inset-0 bg-black/60 z-[90] hidden md:hidden transition-opacity duration-300 backdrop-blur-sm"></div>
  <div id="mobile-sidebar"
    class="fixed top-0 left-0 bottom-0 w-72 bg-stone-900 text-stone-100 z-[100] transform -translate-x-full transition-transform duration-300 ease-in-out md:hidden shadow-2xl flex flex-col border-r border-stone-800">

    <div class="p-6 flex-1 flex flex-col">
      <div class="flex justify-between items-center mb-10">
        <h2 class="text-xl font-bold tracking-widest uppercase">MENU</h2>
        <button id="close-sidebar"
          class="p-2 text-stone-400 hover:text-stone-100 text-3xl transition-colors">&times;</button>
      </div>

      <nav class="space-y-3">
        <a href="/user/store" class="block px-4 py-3 text-sm font-medium tracking-wide rounded-sm transition-colors text-stone-400 hover:bg-stone-800 hover:text-stone-100 uppercase">Store</a>
        
        <details class="group">
          <summary class="flex items-center justify-between px-4 py-3 text-sm font-medium tracking-wide rounded-sm transition-colors text-stone-400 hover:bg-stone-800 hover:text-stone-100 uppercase cursor-pointer list-none">
            Categories
            <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="pl-8 flex flex-col space-y-2 mt-2 pb-2">
            <% if (locals.globalCategories && locals.globalCategories.length > 0) { %>
              <% globalCategories.forEach(category => { %>
                <a href="/user/store?category=<%= category._id %>" class="block py-2 text-sm text-stone-500 hover:text-brand-accent transition-colors"><%= category.categoryName %></a>
              <% }) %>
            <% } else { %>
                <span class="block py-2 text-sm text-stone-500">No Categories</span>
            <% } %>
          </div>
        </details>

        <a href="/about" class="block px-4 py-3 text-sm font-medium tracking-wide rounded-sm transition-colors text-stone-400 hover:bg-stone-800 hover:text-stone-100 uppercase">About</a>
      </nav>
    </div>
  </div>
  <% } %>

    <% if(locals.isProfilePage) { %>
      <div id="profile-sidebar-overlay"
        class="fixed inset-0 bg-black/60 z-[90] hidden md:hidden transition-opacity duration-300 backdrop-blur-sm">
      </div>
      <div id="profile-sidebar-menu"
        class="fixed top-0 left-0 bottom-0 w-72 bg-stone-900 text-stone-100 z-[100] transform -translate-x-full transition-transform duration-300 ease-in-out md:hidden shadow-2xl flex flex-col border-r border-stone-800">

        <div class="p-6 flex-1 flex flex-col">
          <div class="flex justify-between items-center mb-10">
            <h2 class="text-xl font-bold tracking-widest uppercase">Account</h2>
            <button id="close-profile-sidebar"
              class="p-2 text-stone-400 hover:text-stone-100 text-3xl transition-colors">&times;</button>
          </div>

          <nav class="space-y-3">
            <a href="/user/profile"
              class="<%= locals.currentPage === 'profile' ? 'bg-stone-800 text-stone-100' : 'text-stone-400 hover:bg-stone-800 hover:text-stone-100' %> block px-4 py-3 text-sm font-medium tracking-wide rounded-sm transition-colors">
              Personal Info
            </a>
            <a href="/user/orders"
              class="<%= locals.currentPage === 'orders' ? 'bg-stone-800 text-stone-100' : 'text-stone-400 hover:bg-stone-800 hover:text-stone-100' %> block px-4 py-3 text-sm font-medium tracking-wide rounded-sm transition-colors">
              My Orders
            </a>
            <a href="/user/address"
              class="<%= locals.currentPage === 'address' ? 'bg-stone-800 text-stone-100' : 'text-stone-400 hover:bg-stone-800 hover:text-stone-100' %> block px-4 py-3 text-sm font-medium tracking-wide rounded-sm transition-colors">
              Address
            </a>
            <a href="/user/wallet"
              class="<%= locals.currentPage === 'wallet' ? 'bg-stone-800 text-stone-100' : 'text-stone-400 hover:bg-stone-800 hover:text-stone-100' %> block px-4 py-3 text-sm font-medium tracking-wide rounded-sm transition-colors">
              Wallet
            </a>
            <a href="/user/settings"
              class="<%= locals.currentPage === 'settings' ? 'bg-stone-800 text-stone-100' : 'text-stone-400 hover:bg-stone-800 hover:text-stone-100' %> block px-4 py-3 text-sm font-medium tracking-wide rounded-sm transition-colors">
              Settings
            </a>
          </nav>

          <div class="mt-auto pt-8 border-t border-stone-800">
            <button onclick="handleLogout()"
              class="flex items-center px-4 py-3 text-red-400 hover:bg-red-400/10 font-medium rounded-sm transition-all w-full tracking-wide text-sm">
              <span class="mr-3">🚪</span> Logout
            </button>
          </div>
        </div>
      </div>
      <% } %>

<script>
  (function () {
    const nav = document.getElementById('main-nav');
    const isProfilePage = nav.classList.contains('bg-brand-bg1');

    function handleScroll() {
      if (window.scrollY > 20) {
        nav.classList.add('nav-scrolled');
        if (!isProfilePage) nav.classList.remove('bg-transparent');
      } else {
        nav.classList.remove('nav-scrolled');
        if (!isProfilePage) nav.classList.add('bg-transparent');
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  })();
</script>