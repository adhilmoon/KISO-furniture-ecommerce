<style>
  #main-nav.nav-scrolled {
    background: rgba(10, 10, 10, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  #announce-bar {
    background: var(--c-neon, #D8FF3E);
    color: #0A0A0A;
  }
  #announce-bar .marquee-track { animation-duration: 38s; }
  #nav-logo {
    font-family: var(--font-display, 'Anton'), Impact, sans-serif;
    letter-spacing: 0.02em;
    font-size: 1.75rem;
    line-height: 1;
  }
  .nav-link {
    font-family: var(--font-mono, ui-monospace), monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
  }
  .nav-link::before {
    content: "● ";
    color: var(--c-neon, #D8FF3E);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .nav-link:hover::before { opacity: 1; }
</style>

<nav id="main-nav"
  class="flex items-center justify-between px-6 md:px-12 py-4 fixed w-full top-0 z-50 transition-all duration-300 <%= locals.isProfilePage ? 'bg-brand-bg1 border-b border-white/5' : 'bg-transparent' %> text-stone-100">

  <div class="flex items-center gap-4">
    <% if(locals.isProfilePage) { %>
      <button id="mobile-profile-sidebar-toggle"
        class="md:hidden p-1 text-stone-100 hover:text-brand-accent transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
      <% } %>

        <a href="/" class="flex items-center gap-3 group">
          <span id="nav-logo"
            class="font-bold uppercase group-hover:text-neon transition-colors duration-300">KISO</span>
          <span class="hidden md:inline font-mono text-[9px] uppercase tracking-[0.3em] text-brand-muted border border-white/15 px-1.5 py-0.5">VOL.01</span>
        </a>
  </div>

  <ul class="hidden md:flex items-center gap-10 nav-link uppercase text-stone-300">
    <li><a href="/user/store" class="hover:text-stone-100 transition-colors duration-300">Store</a></li>
    <li class="relative">
      <button id="cat-dropdown-btn" class="hover:text-stone-100 transition-colors duration-300 uppercase flex items-center gap-1.5">
        Categories
        <svg id="cat-dropdown-arrow" class="w-3 h-3 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div id="cat-dropdown-menu" class="absolute left-0 mt-4 w-52 bg-brand-bg1 border border-white/10 shadow-2xl opacity-0 invisible translate-y-2 transition-all duration-300 flex flex-col pt-2 pb-2 z-[60]">
        <div class="px-4 pb-2 mb-1 border-b border-white/5 font-mono text-[9px] uppercase tracking-[0.3em] text-brand-muted">Index</div>
        <% if (locals.globalCategories && locals.globalCategories.length > 0) { %>
          <% globalCategories.forEach((category, i) => { %>
            <a href="/user/store?category=<%= category._id %>" class="px-4 py-2.5 text-xs uppercase tracking-wider hover:bg-white/5 hover:text-neon transition-colors flex items-center justify-between group">
              <span><%= category.categoryName %></span>
              <span class="font-mono text-[9px] text-brand-muted group-hover:text-neon">0<%= i + 1 %></span>
            </a>
          <% }) %>
        <% } else { %>
            <span class="px-4 py-2.5 text-xs text-brand-muted">No Categories</span>
        <% } %>
      </div>
    </li>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('cat-dropdown-btn');
    const menu = document.getElementById('cat-dropdown-menu');
    const arrow = document.getElementById('cat-dropdown-arrow');

    if (btn && menu) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !menu.classList.contains('invisible');
        
        if (isOpen) {
          menu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          arrow.classList.remove('rotate-180');
        } else {
          menu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
          arrow.classList.add('rotate-180');
        }
      });

      document.addEventListener('click', (e) => {
        if (!menu.contains(e.target) && !btn.contains(e.target)) {
          menu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          arrow.classList.remove('rotate-180');
        }
      });
    }
  });
</script>
    <li><a href="/about" class="hover:text-stone-100 transition-colors duration-300">About</a></li>
    <li class="hidden lg:flex items-center gap-2 pl-6 ml-2 border-l border-white/10">
