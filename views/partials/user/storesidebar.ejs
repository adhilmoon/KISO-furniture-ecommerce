<aside class="w-full bg-brand-bg1 border-r border-white/5 p-6 sticky top-24 h-[calc(100vh-6rem)] overflow-y-auto">

    <!-- HEADER STRIP -->
    <div class="mb-6 pb-5 border-b border-white/5">
        <p class="font-mono text-[9px] uppercase tracking-[0.3em] text-neon mb-2">// 00 · Index</p>
        <h2 class="font-display uppercase text-3xl text-brand-light leading-none">Filter<br>& Sort</h2>
    </div>

    <div class="space-y-6">

        <!-- ── CATEGORY ──────────────────────────────────── -->
        <div class="border-b border-white/5 pb-6">
            <button onclick="toggleFilter('catFilter')"
                class="w-full flex justify-between items-center font-mono text-[10px] uppercase tracking-[0.3em] text-brand-light mb-4 group">
                <span class="flex items-center gap-2"><span class="text-neon">01</span> Category</span>
                <svg id="catFilterIcon" class="w-3 h-3 text-brand-muted group-hover:text-neon transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div id="catFilter" class="space-y-1.5">
                <% if (typeof categories !== 'undefined' && categories.length) { %>
                    <label class="block cursor-pointer group">
                        <input type="radio" name="categoryFilter" value=""
                            class="peer hidden"
                            onchange="applyFilters()"
                            <%= !activeFilters.categoryId ? 'checked' : '' %>>
                        <div class="px-4 py-2.5 border border-white/5 bg-brand-bg2/30 text-brand-muted text-xs uppercase tracking-wider font-medium transition-all duration-300 flex items-center justify-between
                            peer-checked:bg-white/[0.04] peer-checked:text-brand-light peer-checked:border-l-2 peer-checked:border-l-neon
                            group-hover:bg-brand-bg2 group-hover:text-brand-light">
                            <span>All Categories</span>
                            <span class="font-mono text-[9px] text-brand-muted/50 group-hover:text-neon">00</span>
                        </div>
                    </label>
                    <% categories.forEach((cat, idx) => { %>
                        <label class="block cursor-pointer group">
                            <input type="radio" name="categoryFilter" value="<%= cat._id %>"
                                class="peer hidden"
                                onchange="applyFilters()"
                                <%= (activeFilters.categoryId === String(cat._id)) ? 'checked' : '' %>>
                            <div class="px-4 py-2.5 border border-white/5 bg-brand-bg2/30 text-brand-muted text-xs uppercase tracking-wider font-medium transition-all duration-300 flex items-center justify-between
                                peer-checked:bg-white/[0.04] peer-checked:text-brand-light peer-checked:border-l-2 peer-checked:border-l-neon
                                group-hover:bg-brand-bg2 group-hover:text-brand-light">
                                <span><%= cat.categoryName %></span>
                                <span class="font-mono text-[9px] text-brand-muted/50 group-hover:text-neon">0<%= idx + 1 %></span>
                            </div>
                        </label>
                    <% }) %>
                <% } else { %>
                    <p class="font-mono text-[10px] text-brand-muted uppercase tracking-wider">// No categories</p>
                <% } %>
            </div>
        </div>

        <!-- ── PRICE RANGE ────────────────────────────────── -->
        <div class="border-b border-white/5 pb-6">
            <button onclick="toggleFilter('priceFilter')"
                class="w-full flex justify-between items-center font-mono text-[10px] uppercase tracking-[0.3em] text-brand-light mb-4 group">
                <span class="flex items-center gap-2"><span class="text-neon">02</span> Price Range</span>
                <svg id="priceFilterIcon" class="w-3 h-3 text-brand-muted group-hover:text-neon transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div id="priceFilter" class="pt-2 pb-2">
                <div class="px-1">
                    <!-- Display Values -->
                    <div class="flex justify-between font-display text-brand-light text-2xl mb-6">
                        <span id="minPriceDisplay">₹<%= storeMinPrice.toLocaleString() %></span>
                        <span class="text-neon mx-2 self-center text-base">→</span>
                        <span id="maxPriceDisplay">₹<%= storeMaxPrice.toLocaleString() %>+</span>
                    </div>

                    <!-- Dual Slider Track -->
                    <div class="relative h-1 bg-white/10 mb-4">
                        <div id="sliderTrack" class="absolute h-full bg-neon z-10" style="left: 0%; right: 0%;"></div>

                        <input type="range" id="minPriceSlider" min="<%= storeMinPrice %>" max="<%= storeMaxPrice %>" step="100"
                            value="<%= activeFilters.minPrice > 0 ? activeFilters.minPrice : storeMinPrice %>"
                            oninput="updatePriceSlider()"
                            class="absolute w-full -top-1.5 appearance-none bg-transparent pointer-events-none z-20
                            [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-4 [&::-webkit-slider-thumb]:h-4 [&::-webkit-slider-thumb]:bg-neon [&::-webkit-slider-thumb]:cursor-pointer [&::-webkit-slider-thumb]:shadow-[0_0_10px_rgba(216,255,62,0.6)] [&::-webkit-slider-thumb]:border [&::-webkit-slider-thumb]:border-brand-bg1">

                        <input type="range" id="maxPriceSlider" min="<%= storeMinPrice %>" max="<%= storeMaxPrice %>" step="100"
                            value="<%= activeFilters.maxPrice > 0 ? activeFilters.maxPrice : storeMaxPrice %>"
                            oninput="updatePriceSlider()"
                            class="absolute w-full -top-1.5 appearance-none bg-transparent pointer-events-none z-20
                            [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-4 [&::-webkit-slider-thumb]:h-4 [&::-webkit-slider-thumb]:bg-neon [&::-webkit-slider-thumb]:cursor-pointer [&::-webkit-slider-thumb]:shadow-[0_0_10px_rgba(216,255,62,0.6)] [&::-webkit-slider-thumb]:border [&::-webkit-slider-thumb]:border-brand-bg1">
                    </div>

                    <div class="flex justify-between font-mono text-[9px] uppercase tracking-[0.25em] text-brand-muted">
                        <span>MIN</span>
                        <span>MAX</span>
                    </div>

                    <input type="hidden" id="minPrice" value="<%= activeFilters.minPrice > 0 ? activeFilters.minPrice : '' %>">
                    <input type="hidden" id="maxPrice" value="<%= activeFilters.maxPrice > 0 ? activeFilters.maxPrice : '' %>">
                </div>
            </div>
        </div>

    </div>

    <!-- ── ACTION BUTTONS ─────────────────────────────────── -->
    <div class="mt-8 space-y-2">
        <button id="applyFiltersBtn" onclick="applyFilters()"
            class="group w-full bg-neon hover:bg-white text-brand-bg1 font-display uppercase text-base tracking-tight py-3 transition-all flex items-center justify-center gap-3">
            <span>Apply</span>
            <span class="bg-brand-bg1 text-neon w-6 h-6 flex items-center justify-center text-xs group-hover:translate-x-1 transition-transform">→</span>
        </button>
        <button onclick="clearFilters()"
            class="w-full border border-white/10 hover:border-neon text-brand-muted hover:text-neon py-3 font-mono text-[10px] uppercase tracking-[0.3em] transition-all">
            // Clear All
        </button>
    </div>

    <!-- Footer signature -->
    <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between font-mono text-[9px] uppercase tracking-[0.25em] text-brand-muted">
        <span>Index · v01</span>
        <span class="font-jp">キソ</span>
    </div>

</aside>
