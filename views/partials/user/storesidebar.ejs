<aside class="w-full bg-brand-bg1 border-r border-white/5 p-6 sticky top-24 h-[calc(100vh-6rem)] overflow-y-auto">

    <!-- TITLE -->
    <h2 class="text-lg font-semibold text-brand-light mb-6 tracking-wide flex items-center gap-2">
        <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
        </svg>
        Filters & Sort
    </h2>

    <div class="space-y-5">

        <!-- ── SORT ─────────────────────────────────────── -->
        <div class="border-b border-white/5 pb-5">
            <p class="text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Sort By</p>
            <select id="sortSelect"
                class="w-full bg-brand-bg2 border border-white/10 text-brand-light text-sm rounded-xl px-3 py-2 focus:outline-none focus:border-brand-accent/50 transition">
                <option value="newest"    <%= activeFilters.sort === 'newest'     ? 'selected' : '' %>>Newest First</option>
                <option value="oldest"    <%= activeFilters.sort === 'oldest'     ? 'selected' : '' %>>Oldest First</option>
                <option value="price-asc" <%= activeFilters.sort === 'price-asc'  ? 'selected' : '' %>>Price: Low → High</option>
                <option value="price-desc"<%= activeFilters.sort === 'price-desc' ? 'selected' : '' %>>Price: High → Low</option>
                <option value="name-asc"  <%= activeFilters.sort === 'name-asc'   ? 'selected' : '' %>>Name: A → Z</option>
                <option value="name-desc" <%= activeFilters.sort === 'name-desc'  ? 'selected' : '' %>>Name: Z → A</option>
            </select>
        </div>

        <!-- ── CATEGORY ──────────────────────────────────── -->
        <div class="border-b border-white/5 pb-5">
            <button onclick="toggleFilter('catFilter')"
                class="w-full flex justify-between items-center text-sm font-semibold text-brand-light mb-3">
                Category
                <svg id="catFilterIcon" class="w-4 h-4 text-brand-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div id="catFilter" class="space-y-2">
                <% if (typeof categories !== 'undefined' && categories.length) { %>
                    <% categories.forEach(cat => { %>
                        <label class="flex items-center gap-2.5 text-sm text-brand-muted cursor-pointer hover:text-brand-light transition group">
                            <input type="radio" name="categoryFilter" value="<%= cat._id %>"
                                class="accent-brand-accent"
                                <%= (activeFilters.categoryId === String(cat._id)) ? 'checked' : '' %>>
                            <span class="group-hover:text-brand-light transition"><%= cat.categoryName %></span>
                        </label>
                    <% }) %>
                    <label class="flex items-center gap-2.5 text-sm text-brand-muted cursor-pointer hover:text-brand-light transition group">
                        <input type="radio" name="categoryFilter" value=""
                            class="accent-brand-accent"
                            <%= !activeFilters.categoryId ? 'checked' : '' %>>
                        <span class="group-hover:text-brand-light transition">All Categories</span>
                    </label>
                <% } else { %>
                    <p class="text-xs text-brand-muted">No categories found</p>
                <% } %>
            </div>
        </div>

        <!-- ── PRICE RANGE ────────────────────────────────── -->
        <div class="border-b border-white/5 pb-5">
            <button onclick="toggleFilter('priceFilter')"
                class="w-full flex justify-between items-center text-sm font-semibold text-brand-light mb-3">
                Price Range
                <svg id="priceFilterIcon" class="w-4 h-4 text-brand-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div id="priceFilter" class="space-y-3">
                <div class="flex gap-2">
                    <div class="flex-1">
                        <label class="text-xs text-brand-muted mb-1 block">Min (₹)</label>
                        <input type="number" id="minPrice" min="0" placeholder="0"
                            value="<%= activeFilters.minPrice > 0 ? activeFilters.minPrice : '' %>"
                            class="w-full bg-brand-bg2 border border-white/10 text-brand-light text-sm rounded-xl px-3 py-2 focus:outline-none focus:border-brand-accent/50 transition">
                    </div>
                    <div class="flex-1">
                        <label class="text-xs text-brand-muted mb-1 block">Max (₹)</label>
                        <input type="number" id="maxPrice" min="0" placeholder="Any"
                            value="<%= activeFilters.maxPrice > 0 ? activeFilters.maxPrice : '' %>"
                            class="w-full bg-brand-bg2 border border-white/10 text-brand-light text-sm rounded-xl px-3 py-2 focus:outline-none focus:border-brand-accent/50 transition">
                    </div>
                </div>
                <!-- Quick price presets -->
                <div class="flex flex-wrap gap-1.5">
                    <button type="button" onclick="setPricePreset(0,5000)"    class="text-xs px-2.5 py-1 rounded-lg border border-white/10 text-brand-muted hover:border-brand-accent/40 hover:text-brand-light transition">Under ₹5k</button>
                    <button type="button" onclick="setPricePreset(5000,20000)" class="text-xs px-2.5 py-1 rounded-lg border border-white/10 text-brand-muted hover:border-brand-accent/40 hover:text-brand-light transition">₹5k–20k</button>
                    <button type="button" onclick="setPricePreset(20000,50000)"class="text-xs px-2.5 py-1 rounded-lg border border-white/10 text-brand-muted hover:border-brand-accent/40 hover:text-brand-light transition">₹20k–50k</button>
                    <button type="button" onclick="setPricePreset(50000,0)"   class="text-xs px-2.5 py-1 rounded-lg border border-white/10 text-brand-muted hover:border-brand-accent/40 hover:text-brand-light transition">₹50k+</button>
                </div>
            </div>
        </div>

    </div>

    <!-- ── ACTION BUTTONS ─────────────────────────────────── -->
    <div class="mt-8 space-y-3">
        <button id="applyFiltersBtn" onclick="applyFilters()"
            class="w-full bg-brand-accent hover:bg-yellow-500 text-brand-bg1 py-2.5 rounded-xl font-semibold text-sm transition-all flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Apply Filters
        </button>
        <button onclick="clearFilters()"
            class="w-full border border-white/10 hover:border-white/20 text-brand-muted hover:text-brand-light py-2.5 rounded-xl text-sm transition-all">
            Clear All
        </button>
    </div>

</aside>