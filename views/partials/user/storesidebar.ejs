<aside class="w-full bg-brand-bg1 border-r border-white/5 p-6 sticky top-24 h-[calc(100vh-6rem)] overflow-y-auto">

    <!-- TITLE -->
    <h2 class="text-lg font-semibold text-brand-light mb-6 tracking-wide flex items-center gap-2">
        <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
        </svg>
        Filters & Sort
    </h2>

    <div class="space-y-5">

        <!-- ── SORT (Removed by request) ────────────────────────────────── -->
        <!-- ── CATEGORY ──────────────────────────────────── -->
        <div class="border-b border-white/5 pb-5">
            <button onclick="toggleFilter('catFilter')"
                class="w-full flex justify-between items-center text-sm font-semibold text-brand-light mb-3">
                Category
                <svg id="catFilterIcon" class="w-4 h-4 text-brand-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div id="catFilter" class="space-y-2.5">
                <% if (typeof categories !== 'undefined' && categories.length) { %>
                    <label class="block cursor-pointer group">
                        <input type="radio" name="categoryFilter" value=""
                            class="peer hidden"
                            onchange="applyFilters()"
                            <%= !activeFilters.categoryId ? 'checked' : '' %>>
                        <div class="px-4 py-2.5 rounded-xl border border-white/5 bg-brand-bg2/30 text-brand-muted text-sm font-medium transition-all duration-300
                            peer-checked:bg-brand-accent/10 peer-checked:text-brand-accent peer-checked:border-brand-accent/30
                            group-hover:bg-brand-bg2 group-hover:text-brand-light">
                            All Categories
                        </div>
                    </label>
                    <% categories.forEach(cat => { %>
                        <label class="block cursor-pointer group">
                            <input type="radio" name="categoryFilter" value="<%= cat._id %>"
                                class="peer hidden"
                                onchange="applyFilters()"
                                <%= (activeFilters.categoryId === String(cat._id)) ? 'checked' : '' %>>
                            <div class="px-4 py-2.5 rounded-xl border border-white/5 bg-brand-bg2/30 text-brand-muted text-sm font-medium transition-all duration-300
                                peer-checked:bg-brand-accent/10 peer-checked:text-brand-accent peer-checked:border-brand-accent/30
                                group-hover:bg-brand-bg2 group-hover:text-brand-light">
                                <%= cat.categoryName %>
                            </div>
                        </label>
                    <% }) %>
                <% } else { %>
                    <p class="text-xs text-brand-muted">No categories found</p>
                <% } %>
            </div>
        </div>

        <!-- ── PRICE RANGE ────────────────────────────────── -->
        <div class="border-b border-white/5 pb-5">
            <button onclick="toggleFilter('priceFilter')"
                class="w-full flex justify-between items-center text-sm font-semibold text-brand-light mb-3">
                Price Range
                <svg id="priceFilterIcon" class="w-4 h-4 text-brand-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div id="priceFilter" class="pt-2 pb-4">
                <div class="px-2">
                    <!-- Display Values -->
                    <div class="flex justify-between text-brand-light text-sm font-bold mb-6">
                        <span id="minPriceDisplay">₹<%= storeMinPrice.toLocaleString() %></span>
                        <span id="maxPriceDisplay">₹<%= storeMaxPrice.toLocaleString() %>+</span>
                    </div>

                    <!-- Dual Slider Track -->
                    <div class="relative h-1.5 bg-white/10 rounded-full mb-4">
                        <div id="sliderTrack" class="absolute h-full bg-brand-accent rounded-full z-10" style="left: 0%; right: 0%;"></div>
                        
                        <!-- Min Thumb -->
                        <input type="range" id="minPriceSlider" min="<%= storeMinPrice %>" max="<%= storeMaxPrice %>" step="100" 
                            value="<%= activeFilters.minPrice > 0 ? activeFilters.minPrice : storeMinPrice %>"
                            oninput="updatePriceSlider()"
                            class="absolute w-full -top-1.5 appearance-none bg-transparent pointer-events-none z-20
                            [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-4 [&::-webkit-slider-thumb]:h-4 [&::-webkit-slider-thumb]:bg-brand-accent [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:cursor-pointer [&::-webkit-slider-thumb]:shadow-[0_0_10px_rgba(212,175,55,0.5)]">
                            
                        <!-- Max Thumb -->
                        <input type="range" id="maxPriceSlider" min="<%= storeMinPrice %>" max="<%= storeMaxPrice %>" step="100" 
                            value="<%= activeFilters.maxPrice > 0 ? activeFilters.maxPrice : storeMaxPrice %>"
                            oninput="updatePriceSlider()"
                            class="absolute w-full -top-1.5 appearance-none bg-transparent pointer-events-none z-20
                            [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-4 [&::-webkit-slider-thumb]:h-4 [&::-webkit-slider-thumb]:bg-brand-accent [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:cursor-pointer [&::-webkit-slider-thumb]:shadow-[0_0_10px_rgba(212,175,55,0.5)]">
                    </div>

                    <!-- Hidden inputs for legacy getActiveParams compatibility -->
                    <input type="hidden" id="minPrice" value="<%= activeFilters.minPrice > 0 ? activeFilters.minPrice : '' %>">
                    <input type="hidden" id="maxPrice" value="<%= activeFilters.maxPrice > 0 ? activeFilters.maxPrice : '' %>">
                </div>
            </div>
        </div>

    </div>

    <!-- ── ACTION BUTTONS ─────────────────────────────────── -->
    <div class="mt-8 space-y-3">
        <button id="applyFiltersBtn" onclick="applyFilters()"
            class="w-full bg-brand-accent hover:bg-yellow-500 text-brand-bg1 py-2.5 rounded-xl font-semibold text-sm transition-all flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Apply Filters
        </button>
        <button onclick="clearFilters()"
            class="w-full border border-white/10 hover:border-white/20 text-brand-muted hover:text-brand-light py-2.5 rounded-xl text-sm transition-all">
            Clear All
        </button>
    </div>

</aside>