<footer class="bg-brand-bg1 border-t border-white/5 text-brand-muted font-sans">
  <div class="max-w-6xl mx-auto px-6 py-12">

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 mb-10">

      <!-- Brand -->
      <div class="sm:col-span-2 md:col-span-1">
        <a href="/" class="text-2xl font-bold tracking-tighter text-brand-light hover:text-brand-accent transition-colors">
          <%= locals.site?.brand || 'KISO' %>
        </a>
        <p class="mt-3 text-sm leading-relaxed">
          Japandi-inspired furniture, designed for calm and comfort.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-brand-light mb-4">Company</h3>
        <ul class="space-y-2 text-sm">
          <% (locals.site?.footerLinks || []).forEach(function(link) { %>
            <li>
              <a href="<%= link.href %>" class="hover:text-brand-light transition-colors"><%= link.label %></a>
            </li>
          <% }); %>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-brand-light mb-4">Support</h3>
        <ul class="space-y-2 text-sm">
          <% if (locals.site?.contact?.email) { %>
            <li>
              <a href="mailto:<%= locals.site.contact.email %>" class="hover:text-brand-light transition-colors break-all">
                <%= locals.site.contact.email %>
              </a>
            </li>
          <% } %>
          <% if (locals.site?.contact?.phone) { %>
            <li>
              <a href="tel:<%= locals.site.contact.phone.replace(/\s+/g, '') %>" class="hover:text-brand-light transition-colors">
                <%= locals.site.contact.phone %>
              </a>
            </li>
          <% } %>
          <li><a href="/user/orders" class="hover:text-brand-light transition-colors">Track Order</a></li>
          <li><a href="/user/page/contact" class="hover:text-brand-light transition-colors">Help Center</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-brand-light mb-4">Follow</h3>
        <div class="flex gap-3">
          <% if (locals.site?.social?.instagram) { %>
            <a href="<%= locals.site.social.instagram %>" target="_blank" rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center rounded-full border border-white/10 hover:border-brand-accent/40 hover:text-brand-accent transition-colors"
              aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
          <% } %>
          <% if (locals.site?.social?.facebook) { %>
            <a href="<%= locals.site.social.facebook %>" target="_blank" rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center rounded-full border border-white/10 hover:border-brand-accent/40 hover:text-brand-accent transition-colors"
              aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          <% } %>
          <% if (locals.site?.social?.pinterest) { %>
            <a href="<%= locals.site.social.pinterest %>" target="_blank" rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center rounded-full border border-white/10 hover:border-brand-accent/40 hover:text-brand-accent transition-colors"
              aria-label="Pinterest">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16c2 0 3-1.5 3-3.5s-1.5-3.5-3-3.5c-2.5 0-4 2.5-4 5.5 0 2 1.5 3 2.5 3"/><path d="M12 8v8"/></svg>
            </a>
          <% } %>
        </div>
      </div>
    </div>

    <div class="pt-6 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs">
      <p>© <%= new Date().getFullYear() %> <%= locals.site?.brand || 'KISO' %>. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/user/page/terms" class="hover:text-brand-light transition-colors">Terms</a>
        <a href="/user/page/privacy" class="hover:text-brand-light transition-colors">Privacy</a>
      </div>
    </div>
  </div>
</footer>
