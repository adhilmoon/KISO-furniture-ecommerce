<div class="w-full">

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-kiso-text">Product Management</h1>
    <p class="text-brand-muted text-sm mt-1">View and manage products</p>
  </div>

  <!-- Search + Add -->
  <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 mb-8">
    <div class="flex items-center flex-1 bg-brand-bg2 border border-white/10 rounded-lg px-4 py-3 gap-3">
      <svg class="w-4 h-4 text-brand-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.35-4.35" />
      </svg>
      <input type="text" id="searchInput" placeholder="Search products by name..." oninput="handleSearchDebounced()"
        class="bg-transparent outline-none text-kiso-text placeholder-brand-muted text-sm w-full flex-1" />
      <button type="button" id="clearSearchBtn" onclick="clearSearch()" aria-label="Clear search"
        class="hidden text-brand-muted hover:text-white transition-colors text-lg leading-none">
        &times;
      </button>
    </div>
    <select id="categoryFilter" class="bg-brand-bg2 border border-white/10 text-kiso-text px-4 py-3 rounded-lg text-sm outline-none w-full sm:w-auto">
      <option value="">All Categories</option>
      <!-- Example Categories -->
      <option value="chairs">Chairs</option>
      <option value="tables">Tables</option>
      <option value="sofas">Sofas</option>
    </select>
    <button
      class="bg-brand-bg2 border border-white/10 text-kiso-text px-5 py-3 rounded-lg text-sm hover:bg-white/5 transition">
      Search
    </button>
    <a href="/admin/product/add" id="addProductBtn"
      class="bg-kiso-text text-kiso-bg px-5 py-3 rounded-lg text-sm font-semibold hover:bg-white/90 transition text-center sm:text-left">
      + Add Product
    </a>
  </div>

  <!-- Table -->
  <div class="border border-white/10 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">

        <!-- Head -->
        <thead>
          <tr class="bg-brand-bg2 border-b border-white/10">
            <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Product</th>
            <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">SKU</th>
            <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Category</th>
            <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Price</th>
            <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Stock</th>
            <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Status</th>
            <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Edit</th>
            <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Action</th>
          </tr>
        </thead>

        <!-- Body -->
        <tbody class="divide-y divide-white/10" id="productTableBody">
          <% if (typeof products !== 'undefined' && products.length > 0) { %>
            <% products.forEach((product, index) => { %>
              <tr class="hover:bg-white/5 transition product-row" data-name="<%= product.productName ? product.productName.toLowerCase() : '' %>">
                
                <!-- Image + Name -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded bg-brand-bg2 border border-white/10 overflow-hidden flex-shrink-0">
                      <% if (product.images && product.images.length > 0) { %>
                        <img src="<%= product.images[0] %>" alt="<%= product.productName %>" class="w-full h-full object-cover" />
                      <% } else { %>
                        <div class="w-full h-full flex items-center justify-center text-brand-muted text-xs">
                          Image
                        </div>
                      <% } %>
                    </div>
                    <div>
                      <p class="text-kiso-text font-medium"><%= product.productName %></p>
                      <p class="text-brand-muted text-xs mt-0.5"><%= product.brand || 'No brand' %></p>
                    </div>
                  </div>
                </td>

                <!-- SKU -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-brand-muted font-mono text-xs"><%= product.sku || 'N/A' %></span>
                </td>

                <!-- Category -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-brand-muted text-sm">
                    <%= product.category && product.category.categoryName ? product.category.categoryName : 'Uncategorized' %>
                  </span>
                </td>

                <!-- Price -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-kiso-text font-medium">
                    $<%= product.price ? product.price.toFixed(2) : '0.00' %>
                  </span>
                </td>

                <!-- Stock -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (product.quantity > 10) { %>
                    <span class="text-green-400 font-medium"><%= product.quantity %></span>
                  <% } else if (product.quantity > 0) { %>
                    <span class="text-yellow-400 font-medium"><%= product.quantity %></span>
                  <% } else { %>
                    <span class="text-red-400 font-medium">Out of stock</span>
                  <% } %>
                </td>

                <!-- Status -->
                <td class="px-6 py-4 whitespace-nowrap" id="status-<%= product._id %>">
                  <% if (product.isActive) { %>
                    <span
                      class="px-3 py-1 inline-flex text-xs font-semibold rounded-full bg-green-400/10 text-green-400 border border-green-400/20">
                      Active
                    </span>
                  <% } else { %>
                    <span
                      class="px-3 py-1 inline-flex text-xs font-semibold rounded-full bg-red-400/10 text-red-400 border border-red-400/20">
                      Inactive
                    </span>
                  <% } %>
                </td>

                <!-- Edit -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <a href="/admin/products/edit/<%= product._id %>"
                    class="border border-green-400/40 text-green-400 px-4 py-1 rounded-full text-xs hover:bg-green-400/10 transition inline-block text-center">
                    Edit
                  </a>
                </td>

                <!-- Action -->
                <td class="px-6 py-4 whitespace-nowrap" id="action-<%= product._id %>">
                  <% if (product.isActive) { %>
                    <button onclick="disableProduct('<%= product._id %>')"
                      class="bg-red-500/80 text-white px-4 py-1 rounded-lg text-xs hover:bg-red-600 transition font-medium w-full max-w-[80px]">
                      Disable
                    </button>
                  <% } else { %>
                    <button onclick="enableProduct('<%= product._id %>')"
                      class="bg-green-500/80 text-white px-4 py-1 rounded-lg text-xs hover:bg-green-600 transition font-medium w-full max-w-[80px]">
                      Enable
                    </button>
                  <% } %>
                </td>

              </tr>
            <% }) %>
          <% } else { %>
            <!-- Render dummy row if no products are passed, for UI preview -->
            <tr class="hover:bg-white/5 transition">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 rounded bg-brand-bg2 border border-white/10 overflow-hidden flex-shrink-0 flex items-center justify-center text-brand-muted text-xs">
                    Img
                  </div>
                  <div>
                    <p class="text-kiso-text font-medium">Nordic Lounge Chair</p>
                    <p class="text-brand-muted text-xs mt-0.5">KISO Home</p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-brand-muted font-mono text-xs">SKU-FUR-001</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-brand-muted text-sm">Chairs</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-kiso-text font-medium">$299.00</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-green-400 font-medium">45</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-3 py-1 inline-flex text-xs font-semibold rounded-full bg-green-400/10 text-green-400 border border-green-400/20">
                  Active
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <a href="#" class="border border-green-400/40 text-green-400 px-4 py-1 rounded-full text-xs hover:bg-green-400/10 transition inline-block text-center">
                  Edit
                </a>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <button class="bg-red-500/80 text-white px-4 py-1 rounded-lg text-xs hover:bg-red-600 transition font-medium w-full max-w-[80px]">
                  Disable
                </button>
              </td>
            </tr>
          <% } %>
        </tbody>

      </table>
    </div>
  </div>

  <!-- Empty State -->
  <% if (typeof products !== 'undefined' && products.length === 0) { %>
    <div class="text-center py-16 border border-white/10 rounded-xl mt-0">
      <svg class="w-12 h-12 text-brand-muted mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
      </svg>
      <p class="text-brand-muted text-sm">No products found.</p>
      <a href="/admin/products/add" class="mt-4 inline-block text-brand-accent text-sm underline">Add your first product</a>
    </div>
  <% } %>

  <!-- Pagination -->
  <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="flex items-center justify-between mt-6">
      <p class="text-brand-muted text-sm">
        Showing <%= ((currentPage - 1) * perPage) + 1 %> to
        <%= Math.min(currentPage * perPage, totalProducts) %> of
        <%= totalProducts %> products
      </p>

      <div class="flex items-center gap-2">
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>"
            class="px-3 py-2 border border-white/10 rounded-lg text-brand-muted hover:bg-white/5 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </a>
        <% } %>

        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="?page=<%= i %>"
            class="px-4 py-2 rounded-lg text-sm transition
            <%= i === currentPage ? 'bg-white/10 text-kiso-text' : 'border border-white/10 text-brand-muted hover:bg-white/5' %>">
            <%= i %>
          </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>"
            class="px-3 py-2 border border-white/10 rounded-lg text-brand-muted hover:bg-white/5 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        <% } %>
      </div>
    </div>
  <% } %>

</div>

<!-- Only include script if needed, currently no JS file specific to product management -->
<!-- <script src="/js/admin_side/productManagement.js"></script> -->
