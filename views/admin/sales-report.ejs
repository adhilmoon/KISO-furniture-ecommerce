<div class="w-full">

  <!-- Header -->
  <div class="mb-8 flex flex-col sm:flex-row sm:items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-kiso-text">Sales Report</h1>
      <p class="text-brand-muted text-sm mt-1"><%= report.label %></p>
    </div>
    <div class="flex gap-2">
      <a href="/admin/sales-report/download/pdf?period=<%= period %>&startDate=<%= startDate %>&endDate=<%= endDate %>"
        class="px-4 py-2.5 bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 font-semibold text-sm rounded-xl transition-colors">
        Download PDF
      </a>
      <a href="/admin/sales-report/download/excel?period=<%= period %>&startDate=<%= startDate %>&endDate=<%= endDate %>"
        class="px-4 py-2.5 bg-green-500/10 hover:bg-green-500/20 text-green-400 border border-green-500/20 font-semibold text-sm rounded-xl transition-colors">
        Download Excel
      </a>
    </div>
  </div>

  <!-- Filters -->
  <form method="GET" action="/admin/sales-report" class="mb-6 bg-brand-bg1 border border-white/10 rounded-2xl p-5">
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
      <div>
        <label class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Period</label>
        <select name="period" id="periodSelect" onchange="toggleCustomRange()" class="w-full bg-brand-bg2 border border-white/10 rounded-xl px-4 py-2.5 text-brand-light text-sm outline-none focus:border-brand-accent/40">
          <option value="daily" <%= period === 'daily' ? 'selected' : '' %>>Daily (Today)</option>
          <option value="weekly" <%= period === 'weekly' ? 'selected' : '' %>>Weekly</option>
          <option value="monthly" <%= period === 'monthly' ? 'selected' : '' %>>Monthly</option>
          <option value="yearly" <%= period === 'yearly' ? 'selected' : '' %>>Yearly</option>
          <option value="custom" <%= period === 'custom' ? 'selected' : '' %>>Custom Range</option>
        </select>
      </div>
      <div id="startDateField" class="<%= period === 'custom' ? '' : 'hidden' %>">
        <label class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Start Date</label>
        <input type="date" name="startDate" value="<%= startDate %>" class="w-full bg-brand-bg2 border border-white/10 rounded-xl px-4 py-2.5 text-brand-light text-sm outline-none focus:border-brand-accent/40"/>
      </div>
      <div id="endDateField" class="<%= period === 'custom' ? '' : 'hidden' %>">
        <label class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">End Date</label>
        <input type="date" name="endDate" value="<%= endDate %>" class="w-full bg-brand-bg2 border border-white/10 rounded-xl px-4 py-2.5 text-brand-light text-sm outline-none focus:border-brand-accent/40"/>
      </div>
      <div class="flex items-end">
        <button type="submit" class="w-full px-5 py-2.5 bg-brand-accent text-kiso-bg font-bold text-sm rounded-xl hover:bg-brand-accent/90 transition-colors">Generate</button>
      </div>
    </div>
  </form>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <% const cards = [
      { label: 'Total Orders', value: report.summary.totalOrders, prefix: '' },
      { label: 'Total Sales', value: report.summary.totalSales, prefix: '₹' },
      { label: 'Coupon Discount', value: report.summary.totalCouponDiscount, prefix: '₹' },
      { label: 'Item Discount', value: report.summary.totalItemDiscount, prefix: '₹' },
      { label: 'Wallet Paid', value: report.summary.totalWalletPaid, prefix: '₹' },
      { label: 'Net Revenue', value: report.summary.totalRevenue, prefix: '₹' },
      { label: 'Refunds Count', value: report.summary.totalRefunds, prefix: '' },
      { label: 'Refund Amount', value: report.summary.totalRefundAmount, prefix: '₹' }
    ]; %>
    <% cards.forEach(function(c) { %>
      <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-5">
        <p class="text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2"><%= c.label %></p>
        <p class="text-2xl font-extrabold text-brand-light"><%= c.prefix %><%= c.value.toLocaleString('en-IN') %></p>
      </div>
    <% }) %>
  </div>

  <!-- Daily Breakdown Table -->
  <div class="bg-brand-bg1 border border-white/10 rounded-2xl overflow-hidden shadow-lg shadow-black/20">
    <div class="px-6 py-4 border-b border-white/5">
      <h2 class="text-sm font-semibold text-brand-muted uppercase tracking-wider">Daily Breakdown</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-brand-bg2/80 border-b border-white/5 text-brand-muted uppercase tracking-wider text-[11px]">
          <tr>
            <th class="px-6 py-4 text-left font-semibold">Date</th>
            <th class="px-6 py-4 text-center font-semibold">Orders</th>
            <th class="px-6 py-4 text-right font-semibold">Sales</th>
            <th class="px-6 py-4 text-right font-semibold">Coupon Discount</th>
            <th class="px-6 py-4 text-right font-semibold">Revenue</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <% if (!report.breakdown || report.breakdown.length === 0) { %>
            <tr><td colspan="5" class="px-6 py-10 text-center text-brand-muted">No data in selected range</td></tr>
          <% } else { %>
            <% report.breakdown.forEach(function(r) { %>
              <tr class="hover:bg-white/5 transition-colors">
                <td class="px-6 py-4 text-brand-light font-medium"><%= r._id %></td>
                <td class="px-6 py-4 text-center text-brand-muted"><%= r.orders %></td>
                <td class="px-6 py-4 text-right text-brand-light">₹<%= r.sales.toLocaleString('en-IN') %></td>
                <td class="px-6 py-4 text-right text-brand-muted">₹<%= (r.couponDiscount || 0).toLocaleString('en-IN') %></td>
                <td class="px-6 py-4 text-right text-brand-accent font-semibold">₹<%= r.revenue.toLocaleString('en-IN') %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
function toggleCustomRange() {
  const period = document.getElementById('periodSelect').value;
  const show = period === 'custom';
  document.getElementById('startDateField').classList.toggle('hidden', !show);
  document.getElementById('endDateField').classList.toggle('hidden', !show);
}
</script>
