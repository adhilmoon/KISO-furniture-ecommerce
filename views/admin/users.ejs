<div class="p-4 sm:p-8 max-w-7xl mx-auto w-full font-sans transition-colors duration-300">
    
    <!-- Page Header -->
    <header class="mb-10">
        <h1 class="text-3xl font-bold text-kiso-text tracking-tight mb-1">Customers</h1>
        <p class="text-sm text-brand-muted">View and manage customer accounts.</p>
    </header>

    <!-- Stats Matrix -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <!-- Total Users -->
        <div class="bg-brand-bg1 p-6 rounded-2xl border border-white/10 shadow-lg shadow-black/20 flex items-center hover:border-brand-accent/50 transition relative group">
            <div class="absolute inset-0 bg-brand-accent/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
            <div class="w-12 h-12 rounded-xl bg-brand-bg2 border border-white/5 flex items-center justify-center text-kiso-text mr-4 relative z-10">
                <i class="fas fa-users text-xl"></i>
            </div>
            <div class="relative z-10">
                <p class="text-[13px] font-medium text-brand-muted uppercase tracking-wider mb-1">Total Users</p>
                <h3 id="totalUsersCount" class="text-3xl font-bold text-kiso-text">
                    <%= totalUsers %>
                </h3>
            </div>
        </div>

        <!-- Active Users -->
        <div class="bg-brand-bg1 p-6 rounded-2xl border border-white/10 shadow-lg shadow-black/20 flex items-center hover:border-brand-accent/50 transition relative group">
            <div class="absolute inset-0 bg-green-500/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
            <div class="w-12 h-12 rounded-xl bg-brand-bg2 border border-white/5 flex items-center justify-center text-green-400 mr-4 relative z-10 shadow-[0_0_15px_rgba(74,222,128,0.1)]">
                <i class="fas fa-user-check text-xl"></i>
            </div>
            <div class="relative z-10">
                <p class="text-[13px] font-medium text-brand-muted uppercase tracking-wider mb-1">Active Users</p>
                <h3 id="activeUsersCount" class="text-3xl font-bold text-kiso-text">
                    <%= users.filter(u=> u.isActive && !u.isBlocked).length %>
                </h3>
            </div>
        </div>

        <!-- Blocked Users -->
        <div class="bg-brand-bg1 p-6 rounded-2xl border border-white/10 shadow-lg shadow-black/20 flex items-center hover:border-brand-accent/50 transition relative group">
            <div class="absolute inset-0 bg-red-500/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
            <div class="w-12 h-12 rounded-xl bg-brand-bg2 border border-white/5 flex items-center justify-center text-red-400 mr-4 relative z-10 shadow-[0_0_15px_rgba(248,113,113,0.1)]">
                <i class="fas fa-user-slash text-xl"></i>
            </div>
            <div class="relative z-10">
                <p class="text-[13px] font-medium text-brand-muted uppercase tracking-wider mb-1">Blocked Users</p>
                <h3 id="blockedUsersCount" class="text-3xl font-bold text-kiso-text">
                    <%= users.filter(u=> u.isBlocked).length %>
                </h3>
            </div>
        </div>
    </div>

    <!-- Filters & Search -->
    <div class="flex flex-col sm:flex-row items-center gap-4 mb-8">
        <!-- Search Box -->
        <div class="relative w-full sm:flex-1">
            <svg class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-brand-muted" fill="none"
                stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input type="text" id="searchInput" placeholder="Search by name or email"
                class="w-full pl-12 pr-12 py-3 bg-brand-bg1 border border-white/10 rounded-xl text-kiso-text placeholder-brand-muted focus:outline-none focus:border-brand-accent transition-colors shadow-lg shadow-black/10">
            <button type="button" id="clearSearchBtn" aria-label="Clear search"
                class=" absolute right-3 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full text-brand-muted hover:bg-brand-bg2 hover:text-kiso-text transition-colors flex items-center justify-center">
                &times;
            </button>
        </div>
        
        <!-- Status Filter -->
        <div class="w-full sm:w-auto">
            <select id="statusFilter"
                class="w-full sm:w-48 px-4 py-3 bg-brand-bg1 border border-white/10 rounded-xl text-kiso-text focus:outline-none focus:border-brand-accent transition-colors appearance-none shadow-lg shadow-black/10">
                <option value="all">All Status</option>
                <option value="active">Active</option>
                <option value="blocked">Blocked</option>
            </select>
        </div>
    </div>

    <!-- Users Table -->
    <div class="border border-white/10 rounded-2xl overflow-hidden shadow-lg shadow-black/20 mb-12">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-brand-bg1 border-b border-white/10 text-brand-muted uppercase tracking-wider text-[11px]">
                    <tr>
                        <th class="px-6 py-5 font-semibold">User ID</th>
                        <th class="px-6 py-5 font-semibold">Customer</th>
                        <th class="px-6 py-5 font-semibold">Contact</th>
                        <th class="px-6 py-5 font-semibold">Joined Date</th>
                        <th class="px-6 py-5 font-semibold text-center">Orders</th>
                        <th class="px-6 py-5 font-semibold text-center">Status</th>
                        <th class="px-6 py-5 font-semibold text-right">Action</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody" class="divide-y divide-white/5 bg-brand-bg2/50 backdrop-blur-sm">
                    <% users.forEach((user, index)=> { %>
                        <tr class="hover:bg-white/5 transition-colors group user-row" data-user-id="<%= user._id %>"
                            data-status="<%= user.isBlocked ? 'blocked' : 'active' %>" data-name="<%= user.name.toLowerCase() %>"
                            data-email="<%= user.email.toLowerCase() %>">
                            
                            <!-- User ID -->
                            <td class="px-6 py-4 whitespace-nowrap border-l-2 border-transparent group-hover:border-brand-accent/70 font-medium text-kiso-text">
                                #<%= user.userId || (10000 + index) %>
                            </td>

                            <!-- Name / Customer -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full border border-white/10 object-cover flex items-center justify-center text-kiso-bg font-bold tracking-wider" style="background-color: #9A8478;">
                                        <%= user.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-sm font-semibold text-brand-light"><%= user.name %></span>
                                        <span class="text-xs text-brand-muted truncate max-w-[150px]"><%= user.email %></span>
                                    </div>
                                </div>
                            </td>

                            <!-- Contact (Phone) -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-brand-muted"><%= user.phone || 'N/A' %></span>
                            </td>

                            <!-- Joined Date -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-brand-muted font-medium">
                                    <%= new Date(user.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                </span>
                            </td>

                            <!-- Orders -->
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <span class="text-sm font-bold text-kiso-text">
                                    <%= user.ordercount || user.orderCount || 0 %>
                                </span>
                            </td>

                            <!-- Status --> 
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <% if (!user.isBlocked) { %>
                                    <span class="px-3 py-1 bg-green-500/10 text-green-400 border border-green-500/20 rounded-full text-xs font-semibold tracking-wide">
                                        Active
                                    </span>
                                <% } else { %>
                                    <span class="px-3 py-1 bg-red-500/10 text-red-500 border border-red-500/20 rounded-full text-xs font-semibold tracking-wide">
                                        Blocked
                                    </span>
                                <% } %>
                            </td>

                            <!-- Action -->
                            <td class="px-6 py-4 whitespace-nowrap text-right">
                                <button id="action-btn-<%= user._id %>" onclick="toggleBlock('<%= user._id %>')"
                                    class="px-5 py-2 rounded-lg text-xs font-semibold transition-colors shadow-lg <%= user.isBlocked ? 'bg-green-500/20 text-green-400 hover:bg-green-500/30 shadow-green-500/10' : 'bg-red-500/20 text-red-400 hover:bg-red-500/30 flex-shrink-0 shadow-red-500/10' %>">
                                    <%= user.isBlocked ? 'Activate' : 'Block' %>
                                </button>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div id="usersPagination" class="bg-brand-bg1 px-6 py-4 border-t border-white/5">
            <div class="flex items-center justify-between">
                <p class="text-[13px] font-medium text-brand-muted">
                    Showing <span class="text-brand-light"><%= ((currentPage - 1) * perPage) + 1 %></span> 
                    to <span class="text-brand-light"><%= Math.min(currentPage * perPage, totalUsers) %></span> 
                    of <span class="text-brand-light"><%= totalUsers %></span> customers
                </p>

                <div class="flex items-center gap-2">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= currentPage - 1 %>"
                            class="px-3 py-2 bg-brand-bg2 border border-white/10 rounded-lg text-kiso-text hover:bg-white/5 transition-colors shadow-lg shadow-black/10 flex items-center justify-center">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                            </svg>
                        </a>
                    <% } %>

                    <% for(let i=1; i <=totalPages; i++) { %>
                        <a href="?page=<%= i %>"
                            class="w-10 h-10 flex items-center justify-center rounded-lg text-[13px] font-bold transition-all shadow-lg shadow-black/10 <%= i === currentPage ? 'bg-brand-accent text-kiso-bg shadow-brand-accent/20' : 'bg-brand-bg2 text-brand-muted border border-white/10 hover:bg-white/5 hover:text-brand-light' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %>"
                            class="px-3 py-2 bg-brand-bg2 border border-white/10 rounded-lg text-kiso-text hover:bg-white/5 transition-colors shadow-lg shadow-black/10 flex items-center justify-center">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios@1.13.2/dist/axios.min.js"></script>
<script src="/js/admin/adminUsers.js"></script>
<script src="/js/user/search.js"></script>