<div class="w-full">

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-brand-light">Inventory Management</h1>
    <p class="text-brand-muted text-sm mt-1">Monitor and update product variant stock levels</p>
  </div>

  <!-- Stat Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <!-- Total Products -->
    <div class="bg-brand-bg1 border border-white/10 rounded-xl px-6 py-5 flex items-center gap-4">
      <div class="w-11 h-11 rounded-lg bg-white/5 flex items-center justify-center text-xl flex-shrink-0">📦</div>
      <div>
        <p class="text-brand-muted text-xs font-medium uppercase tracking-wide">Total Products</p>
        <p class="text-brand-light text-2xl font-bold mt-0.5"><%= totalProducts %></p>
      </div>
    </div>
    <!-- Out of Stock -->
    <div class="bg-brand-bg1 border border-white/10 rounded-xl px-6 py-5 flex items-center gap-4">
      <div class="w-11 h-11 rounded-lg bg-red-500/10 flex items-center justify-center text-xl flex-shrink-0">🚫</div>
      <div>
        <p class="text-brand-muted text-xs font-medium uppercase tracking-wide">Out of Stock</p>
        <p class="text-red-400 text-2xl font-bold mt-0.5"><%= outOfStock %></p>
      </div>
    </div>
    <!-- Low Stock -->
    <div class="bg-brand-bg1 border border-white/10 rounded-xl px-6 py-5 flex items-center gap-4">
      <div class="w-11 h-11 rounded-lg bg-orange-500/10 flex items-center justify-center text-xl flex-shrink-0">⚠️</div>
      <div>
        <p class="text-brand-muted text-xs font-medium uppercase tracking-wide">Low Stock</p>
        <p class="text-orange-400 text-2xl font-bold mt-0.5"><%= lowStock %></p>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <form method="GET" action="/admin/inventory" class="flex flex-col sm:flex-row flex-wrap gap-3 mb-6">
    <!-- Search -->
    <div class="flex items-center flex-1 min-w-[200px] bg-brand-bg1 border border-white/10 rounded-lg px-4 py-2.5 gap-3">
      <svg class="w-4 h-4 text-brand-muted flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="text"
        name="search"
        value="<%= search %>"
        placeholder="Search products..."
        class="bg-transparent outline-none text-brand-light placeholder-brand-muted text-sm w-full"
      />
    </div>

    <!-- Stock filter -->
    <select
      name="stock"
      class="bg-brand-bg1 border border-white/10 text-brand-light px-4 py-2.5 rounded-lg text-sm outline-none min-w-[160px]"
    >
      <option value="" <%= stockFilter === '' ? 'selected' : '' %>>All Stock Levels</option>
      <option value="low" <%= stockFilter === 'low' ? 'selected' : '' %>>Low Stock (≤5)</option>
      <option value="out" <%= stockFilter === 'out' ? 'selected' : '' %>>Out of Stock</option>
    </select>

    <!-- Category filter -->
    <select
      name="category"
      class="bg-brand-bg1 border border-white/10 text-brand-light px-4 py-2.5 rounded-lg text-sm outline-none min-w-[160px]"
    >
      <option value="" <%= categoryId === '' ? 'selected' : '' %>>All Categories</option>
      <% categories.forEach(cat => { %>
        <option value="<%= cat._id %>" <%= categoryId === String(cat._id) ? 'selected' : '' %>><%= cat.categoryName %></option>
      <% }) %>
    </select>

    <!-- Submit -->
    <button
      type="submit"
      class="bg-brand-accent text-black px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-brand-accent/90 transition"
    >
      Filter
    </button>

    <!-- Clear -->
    <% if (search || stockFilter || categoryId) { %>
      <a
        href="/admin/inventory"
        class="bg-brand-bg1 border border-white/10 text-brand-muted px-5 py-2.5 rounded-lg text-sm font-medium hover:text-brand-light hover:bg-white/5 transition text-center"
      >
        Clear
      </a>
    <% } %>
  </form>

  <!-- Table -->
  <% if (products.length === 0) { %>
    <!-- Empty State -->
    <div class="bg-brand-bg1 border border-white/10 rounded-xl py-20 flex flex-col items-center justify-center gap-4">
      <div class="text-5xl opacity-30">📦</div>
      <p class="text-brand-light text-lg font-medium">No products found</p>
      <p class="text-brand-muted text-sm">Try adjusting your filters or search query.</p>
      <a href="/admin/inventory" class="text-brand-accent text-sm hover:underline">Clear filters</a>
    </div>
  <% } else { %>
    <div class="bg-brand-bg1 border border-white/10 rounded-xl overflow-hidden mb-6">
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="inventoryTable">
          <thead>
            <tr class="bg-brand-bg2 border-b border-white/10">
              <th class="text-left text-brand-muted font-medium px-5 py-4 uppercase tracking-wide text-xs w-10">#</th>
              <th class="text-left text-brand-muted font-medium px-5 py-4 uppercase tracking-wide text-xs">Product</th>
              <th class="text-left text-brand-muted font-medium px-5 py-4 uppercase tracking-wide text-xs">Category</th>
              <th class="text-left text-brand-muted font-medium px-5 py-4 uppercase tracking-wide text-xs">Variants</th>
              <th class="text-left text-brand-muted font-medium px-5 py-4 uppercase tracking-wide text-xs">Total Stock</th>
              <th class="text-left text-brand-muted font-medium px-5 py-4 uppercase tracking-wide text-xs">Status</th>
              <th class="text-left text-brand-muted font-medium px-5 py-4 uppercase tracking-wide text-xs">Edit Stock</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach((product, index) => {
                const thumb = product.variants?.[0]?.images?.[0] || null;
                const variantCount = product.variants?.length || 0;
            %>
              <!-- Main product row -->
              <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors" id="row-<%= product._id %>">
                <!-- # -->
                <td class="px-5 py-4 text-brand-muted">
                  <%= ((pageNum - 1) * 10) + index + 1 %>
                </td>

                <!-- Product -->
                <td class="px-5 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-brand-bg2 border border-white/10 overflow-hidden flex-shrink-0 flex items-center justify-center">
                      <% if (thumb) { %>
                        <img src="<%= thumb %>" alt="<%= product.productName %>" class="w-full h-full object-cover" />
                      <% } else { %>
                        <svg class="w-5 h-5 text-brand-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 4-4 4 4 4-4 4 4"/>
                        </svg>
                      <% } %>
                    </div>
                    <span class="text-brand-light font-medium truncate max-w-[180px]"><%= product.productName %></span>
                  </div>
                </td>

                <!-- Category -->
                <td class="px-5 py-4 text-brand-muted">
                  <%= product.category?.categoryName || '—' %>
                </td>

                <!-- Variants -->
                <td class="px-5 py-4 text-brand-muted">
                  <%= variantCount %> variant<%= variantCount !== 1 ? 's' : '' %>
                </td>

                <!-- Total Stock -->
                <td class="px-5 py-4 text-brand-light font-semibold">
                  <%= product.totalStock %>
                </td>

                <!-- Status Badge -->
                <td class="px-5 py-4">
                  <% if (product.stockStatus === 'out') { %>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-500/15 text-red-400 border border-red-500/20">
                      <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>Out of Stock
                    </span>
                  <% } else if (product.stockStatus === 'low') { %>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-orange-500/15 text-orange-400 border border-orange-500/20">
                      <span class="w-1.5 h-1.5 rounded-full bg-orange-400"></span>Low Stock
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-500/15 text-green-400 border border-green-500/20">
                      <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>In Stock
                    </span>
                  <% } %>
                </td>

                <!-- Edit Stock Button -->
                <td class="px-5 py-4">
                  <button
                    type="button"
                    onclick="toggleVariantRow('<%= product._id %>')"
                    id="editBtn-<%= product._id %>"
                    class="px-3 py-1.5 rounded-lg border border-white/10 bg-white/5 text-brand-muted hover:text-brand-light hover:bg-white/10 text-xs font-medium transition-all duration-150"
                  >
                    Edit Stock
                  </button>
                </td>
              </tr>

              <!-- Expandable variant rows -->
              <tr id="variantRow-<%= product._id %>" class="hidden">
                <td colspan="7" class="bg-brand-bg2/50 border-b border-white/10 px-6 py-5">
                  <div class="mb-3 flex items-center gap-2">
                    <span class="text-brand-muted text-xs font-semibold uppercase tracking-wide">Variants for</span>
                    <span class="text-brand-light text-xs font-semibold"><%= product.productName %></span>
                  </div>

                  <% if (!product.variants || product.variants.length === 0) { %>
                    <p class="text-brand-muted text-sm">No variants found for this product.</p>
                  <% } else { %>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                      <% product.variants.forEach((variant, vIdx) => { %>
                        <div class="bg-brand-bg1 border border-white/10 rounded-xl p-4" id="variantCard-<%= product._id %>-<%= vIdx %>">
                          <!-- Variant image -->
                          <% if (variant.images && variant.images[0]) { %>
                            <img
                              src="<%= variant.images[0] %>"
                              alt="Variant image"
                              class="w-full h-24 object-cover rounded-lg mb-3 border border-white/5"
                            />
                          <% } %>

                          <!-- Variant details -->
                          <div class="flex flex-wrap gap-2 mb-3">
                            <% if (variant.color) { %>
                              <span class="px-2 py-0.5 rounded-full bg-white/5 text-brand-muted text-xs border border-white/10">
                                <%= variant.color %>
                              </span>
                            <% } %>
                            <% if (variant.size) { %>
                              <span class="px-2 py-0.5 rounded-full bg-white/5 text-brand-muted text-xs border border-white/10">
                                Size: <%= variant.size %>
                              </span>
                            <% } %>
                            <% if (variant.price) { %>
                              <span class="px-2 py-0.5 rounded-full bg-brand-accent/10 text-brand-accent text-xs border border-brand-accent/20">
                                ₹<%= variant.price %>
                              </span>
                            <% } %>
                          </div>

                          <!-- Stock input + save -->
                          <div class="flex items-center gap-2">
                            <label class="text-brand-muted text-xs flex-shrink-0">Stock:</label>
                            <input
                              type="number"
                              min="0"
                              id="stockInput-<%= product._id %>-<%= vIdx %>"
                              value="<%= variant.stock || 0 %>"
                              class="flex-1 bg-brand-bg2 border border-white/10 text-brand-light text-sm rounded-lg px-3 py-1.5 outline-none focus:border-brand-accent/40 transition-colors min-w-0"
                            />
                            <button
                              type="button"
                              onclick="saveStock('<%= product._id %>', <%= vIdx %>)"
                              id="saveBtn-<%= product._id %>-<%= vIdx %>"
                              class="px-3 py-1.5 bg-brand-accent text-black text-xs font-semibold rounded-lg hover:bg-brand-accent/90 transition-colors flex-shrink-0"
                            >
                              Save
                            </button>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <div class="flex items-center justify-between">
        <p class="text-brand-muted text-sm">
          Page <span class="text-brand-light font-medium"><%= pageNum %></span> of <span class="text-brand-light font-medium"><%= totalPages %></span>
        </p>
        <div class="flex items-center gap-2">
          <% if (pageNum > 1) { %>
            <a
              href="/admin/inventory?page=<%= pageNum - 1 %>&search=<%= encodeURIComponent(search) %>&stock=<%= stockFilter %>&category=<%= categoryId %>"
              class="px-4 py-2 rounded-lg bg-brand-bg1 border border-white/10 text-brand-muted hover:text-brand-light hover:bg-white/5 text-sm transition"
            >
              &larr; Prev
            </a>
          <% } %>

          <% for (let p = Math.max(1, pageNum - 2); p <= Math.min(totalPages, pageNum + 2); p++) { %>
            <a
              href="/admin/inventory?page=<%= p %>&search=<%= encodeURIComponent(search) %>&stock=<%= stockFilter %>&category=<%= categoryId %>"
              class="px-3.5 py-2 rounded-lg text-sm transition <%= p === pageNum ? 'bg-brand-accent text-black font-semibold' : 'bg-brand-bg1 border border-white/10 text-brand-muted hover:text-brand-light hover:bg-white/5' %>"
            >
              <%= p %>
            </a>
          <% } %>

          <% if (pageNum < totalPages) { %>
            <a
              href="/admin/inventory?page=<%= pageNum + 1 %>&search=<%= encodeURIComponent(search) %>&stock=<%= stockFilter %>&category=<%= categoryId %>"
              class="px-4 py-2 rounded-lg bg-brand-bg1 border border-white/10 text-brand-muted hover:text-brand-light hover:bg-white/5 text-sm transition"
            >
              Next &rarr;
            </a>
          <% } %>
        </div>
      </div>
    <% } %>
  <% } %>

</div>

<script>
  // Toggle variant expandable row
  function toggleVariantRow(productId) {
    const variantRow = document.getElementById('variantRow-' + productId);
    const editBtn    = document.getElementById('editBtn-' + productId);
    const isHidden   = variantRow.classList.contains('hidden');

    if (isHidden) {
      variantRow.classList.remove('hidden');
      editBtn.textContent = 'Close';
      editBtn.classList.add('text-brand-accent', 'border-brand-accent/30', 'bg-brand-accent/10');
      editBtn.classList.remove('text-brand-muted', 'border-white/10', 'bg-white/5');
    } else {
      variantRow.classList.add('hidden');
      editBtn.textContent = 'Edit Stock';
      editBtn.classList.remove('text-brand-accent', 'border-brand-accent/30', 'bg-brand-accent/10');
      editBtn.classList.add('text-brand-muted', 'border-white/10', 'bg-white/5');
    }
  }

  // Save a variant's stock via PATCH
  async function saveStock(productId, variantIndex) {
    const input   = document.getElementById('stockInput-' + productId + '-' + variantIndex);
    const saveBtn = document.getElementById('saveBtn-' + productId + '-' + variantIndex);
    const stock   = input.value;

    if (stock === '' || isNaN(parseInt(stock))) {
      if (typeof toast !== 'undefined') toast.error('Please enter a valid stock number.');
      return;
    }

    const originalText = saveBtn.textContent;
    saveBtn.textContent = 'Saving…';
    saveBtn.disabled    = true;

    try {
      const res = await axios.patch('/admin/inventory/stock', {
        productId,
        variantIndex,
        stock: parseInt(stock)
      });

      if (res.data.success) {
        if (typeof toast !== 'undefined') toast.success(res.data.message || 'Stock updated.');

        // Update the total stock display cell optimistically
        updateTotalStockDisplay(productId);
      } else {
        if (typeof toast !== 'undefined') toast.error(res.data.message || 'Update failed.');
      }
    } catch (err) {
      const msg = err.response?.data?.message || 'Something went wrong. Please try again.';
      if (typeof toast !== 'undefined') toast.error(msg);
    } finally {
      saveBtn.textContent = originalText;
      saveBtn.disabled    = false;
    }
  }

  // Recalculate & update total-stock cell after edits (client-side, best-effort)
  function updateTotalStockDisplay(productId) {
    let total = 0;
    let idx   = 0;
    while (true) {
      const input = document.getElementById('stockInput-' + productId + '-' + idx);
      if (!input) break;
      total += Math.max(0, parseInt(input.value) || 0);
      idx++;
    }

    // Find the total-stock <td> — it is the 5th cell (index 4) of the main row
    const mainRow = document.getElementById('row-' + productId);
    if (mainRow) {
      const cells = mainRow.querySelectorAll('td');
      if (cells[4]) cells[4].textContent = total;

      // Update status badge cell (index 5)
      if (cells[5]) {
        let badge = '';
        if (total === 0) {
          badge = '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-500/15 text-red-400 border border-red-500/20"><span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>Out of Stock</span>';
        } else if (total <= 5) {
          badge = '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-orange-500/15 text-orange-400 border border-orange-500/20"><span class="w-1.5 h-1.5 rounded-full bg-orange-400"></span>Low Stock</span>';
        } else {
          badge = '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-500/15 text-green-400 border border-green-500/20"><span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>In Stock</span>';
        }
        cells[5].innerHTML = badge;
      }
    }
  }
</script>
