<!-- Modal Backdrop -->
<div id="addCategoryModal" class="fixed inset-0 bg-black/60 items-center justify-center z-50 hidden">

    <!-- Modal Card -->
    <div class="bg-brand-bg2 border border-white/10 rounded-2xl p-8 w-full max-w-xl mx-4">

        <!-- Header -->
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-kiso-text">Add New Category</h2>
            <p class="text-brand-muted text-sm mt-1">Create a new product category</p>
        </div>

        <!-- Form -->
        <form id="addCategoryForm" onsubmit="handleCategorysubmit(event)">

            <!-- Category Name -->
            <div class="mb-5">
                <label class="block text-kiso-text text-sm font-semibold mb-2">Category Name</label>
                <input id="name" type="text" name="name" placeholder="e.g, kitchen"
                    class="w-full bg-brand-bg1 border border-white/10 text-kiso-text placeholder-brand-muted rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-kiso-brown transition-colors">
                <p id="err-name" class="text-red-500 text-xs mt-0.5"></p>
            </div>

            <!-- Description -->
            <div class="mb-8">
                <label class="block text-kiso-text text-sm font-semibold mb-2">Description</label>
                <textarea name="description" rows="3" placeholder="Optional details about the category..." id="description"
                    class="w-full bg-brand-bg1 border border-white/10 text-kiso-text placeholder-brand-muted rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-kiso-brown transition resize-none"></textarea>
                <p id="err-description" class="text-red-500 text-xs mt-0.5"></p>
            </div>

            <!-- Buttons -->
            <div class="flex items-center justify-end gap-3">
                <button type="button" onclick="toggleAddCategoryModal()"
                    class="px-5 py-2.5 rounded-lg text-sm text-kiso-text border border-white/10 hover:bg-white/5 transition">
                    Cancel
                </button>
                <button type="submit"
                    class="px-5 py-2.5 rounded-lg text-sm font-semibold bg-brand-accent text-kiso-bg hover:opacity-90 transition">
                    Add Category
                </button>
            </div>

        </form>
    </div>
</div>