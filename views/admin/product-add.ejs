<%# ── Page: Add Product ──────────────────────────────────────────────── %>
<div class="p-4 sm:p-8 max-w-7xl mx-auto w-full font-sans">

  <%# Breadcrumb / Header %>
  <div class="mb-8">
    <div class="flex items-center gap-2 text-xs text-brand-muted mb-3">
      <a href="/admin/products" class="hover:text-brand-light transition">Products</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-brand-light">Add New Product</span>
    </div>
    <h1 class="text-2xl font-bold text-kiso-text tracking-tight">Add New Product</h1>
    <p class="text-sm text-brand-muted mt-1">Fill in the details below to add a product to your catalog.</p>
  </div>

  <%# ── Global Error Banner (hidden by default) ── %>
  <div id="formErrorBanner" class="hidden mb-6 flex items-start gap-3 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl px-5 py-4 text-sm">
    <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span id="formErrorText">Please fix the errors above before submitting.</span>
  </div>

  <form id="addProductForm" enctype="multipart/form-data" novalidate>
    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">

      <%# ═══════════════════════════════════════════════════════
          LEFT COLUMN  (7/12 wide)
      ═══════════════════════════════════════════════════════ %>
      <div class="xl:col-span-7 flex flex-col gap-6">

        <%# ── Card 1: Basic Information ── %>
        <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
          <h2 class="text-sm font-semibold text-kiso-text uppercase tracking-wider mb-6 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            Basic Information
          </h2>

          <div class="flex flex-col gap-5">

            <%# Product Name %>
            <div>
              <label for="productName" class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">
                Product Name <span class="text-red-400 normal-case tracking-normal">*</span>
              </label>
              <input type="text" id="productName" name="productName"
                placeholder="e.g. Upholstered Bed Frame, Oslo 3-Seater Sofa"
                class="field-input w-full" autocomplete="off" />
              <p class="field-error hidden" id="err-productName">Product name is required.</p>
            </div>

            <%# Description %>
            <div>
              <label for="description" class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">
                Description
              </label>
              <textarea id="description" name="description" rows="4"
                placeholder="Describe the product — highlight key features, style, and use case."
                class="field-input w-full resize-none"></textarea>
              <p class="text-xs text-brand-muted mt-1.5">Min. 20 characters recommended.</p>
            </div>

            <%# Material %>
            <div>
              <label for="material" class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">
                Material
              </label>
              <input type="text" id="material" name="material"
                placeholder="e.g. Solid Teak Wood, Velvet Fabric, Powder-Coated Steel"
                class="field-input w-full" />
            </div>

          </div>
        </div>

        <%# ── Card 2: Dimensions ── %>
        <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
          <h2 class="text-sm font-semibold text-kiso-text uppercase tracking-wider mb-6 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
            Overall Dimensions
          </h2>
          <p class="text-xs text-brand-muted mb-5">All values in centimetres (cm). Leave 0 if not applicable.</p>

          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Width (cm)</label>
              <div class="relative">
                <input type="number" id="dimWidth" name="dimensions[width]" placeholder="0" min="0" step="0.1"
                  class="field-input w-full pr-12" />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-brand-muted pointer-events-none">cm</span>
              </div>
              <p class="field-error hidden" id="err-dimWidth">Must be ≥ 0.</p>
            </div>
            <div>
              <label class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Depth (cm)</label>
              <div class="relative">
                <input type="number" id="dimDepth" name="dimensions[depth]" placeholder="0" min="0" step="0.1"
                  class="field-input w-full pr-12" />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-brand-muted pointer-events-none">cm</span>
              </div>
              <p class="field-error hidden" id="err-dimDepth">Must be ≥ 0.</p>
            </div>
            <div>
              <label class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Height (cm)</label>
              <div class="relative">
                <input type="number" id="dimHeight" name="dimensions[height]" placeholder="0" min="0" step="0.1"
                  class="field-input w-full pr-12" />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-brand-muted pointer-events-none">cm</span>
              </div>
              <p class="field-error hidden" id="err-dimHeight">Must be ≥ 0.</p>
            </div>
          </div>
        </div>

        <%# ── Card 3: Custom Attributes ── %>
        <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h2 class="text-sm font-semibold text-kiso-text uppercase tracking-wider flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-5 5a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 10V5a2 2 0 012-2z"/></svg>
                Additional Specifications
              </h2>
              <p class="text-xs text-brand-muted mt-1 ml-6">Free-form attributes — e.g. Seat Height, No. of Drawers, Mirror Shape</p>
            </div>
            <button type="button" id="addAttrBtn" onclick="addCustomAttribute()"
              class="shrink-0 flex items-center gap-1.5 text-xs font-semibold text-brand-accent border border-brand-accent/40 hover:border-brand-accent hover:bg-brand-accent/10 px-3 py-2 rounded-lg transition">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
              Add
            </button>
          </div>

          <%# Column headers %>
          <div id="attrHeaderRow" class="hidden grid grid-cols-[1fr_1fr_auto] gap-3 mb-2 mt-5 px-1">
            <span class="text-xs font-semibold text-brand-muted uppercase tracking-wider">Attribute Name</span>
            <span class="text-xs font-semibold text-brand-muted uppercase tracking-wider">Value</span>
            <span class="w-8"></span>
          </div>

          <div id="customAttributesContainer" class="flex flex-col gap-2.5 mt-5"></div>

          <%# Empty state %>
          <div id="customAttrEmpty" class="mt-5 border border-dashed border-white/10 rounded-xl py-8 text-center">
            <svg class="w-8 h-8 text-white/10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-5 5a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 10V5a2 2 0 012-2z"/></svg>
            <p class="text-xs text-brand-muted">No attributes added yet.</p>
            <p class="text-xs text-white/20 mt-0.5">Click <strong class="text-white/30">+ Add</strong> to include any product-specific property.</p>
          </div>
        </div>

        <%# ── Card 4: Variants ── %>
        <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h2 class="text-sm font-semibold text-kiso-text uppercase tracking-wider flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                Product Variants
              </h2>
              <p class="text-xs text-brand-muted mt-1 ml-6">Each variant can carry its own price, stock level, and images.</p>
            </div>
            <button type="button" onclick="addVariant()"
              class="shrink-0 flex items-center gap-1.5 text-xs font-semibold text-kiso-text bg-brand-bg2 hover:bg-white/10 border border-white/10 px-3 py-2 rounded-lg transition">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
              Add Variant
            </button>
          </div>

          <div id="variantsContainer" class="flex flex-col gap-4 mt-5"></div>

          <%# Empty state %>
          <div id="variantEmpty" class="border border-dashed border-white/10 rounded-xl py-10 text-center mt-5">
            <svg class="w-8 h-8 text-white/10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            <p class="text-xs text-brand-muted">No variants yet.</p>
            <p class="text-xs text-white/20 mt-0.5">Click <strong class="text-white/30">+ Add Variant</strong> to add size/colour options with their own prices.</p>
          </div>
        </div>

      </div><%# end left column %>

      <div class="xl:col-span-5 flex flex-col gap-6">

        <%# ── Card: Pricing & Categorisation ── %>
        <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
          <h2 class="text-sm font-semibold text-kiso-text uppercase tracking-wider mb-6 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 13v-1m-2.599-1A2.5 2.5 0 0112 20c1.657 0 3-.895 3-2m-3-8V3"/></svg>
            Pricing & Category
          </h2>

          <div class="flex flex-col gap-5">

            <%# Category %>
            <div>
              <label for="category" class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">
                Category <span class="text-red-400 normal-case tracking-normal">*</span>
              </label>
              <div class="relative">
                <select id="category" name="category" class="field-input w-full appearance-none pr-10 text-kiso-text">
                  <option value="" disabled selected class="bg-brand-bg2 text-brand-muted">Select a category</option>
                  <% if(typeof categories !== "undefined" && categories.length > 0) { %>
                    <% categories.forEach(cat => { %>
                      <option value="<%= cat._id %>" class="bg-brand-bg2 text-kiso-text"><%= cat.categoryName %></option>
                    <% }) %>
                  <% } else { %>
                    <option value="" disabled class="bg-brand-bg2 text-brand-muted">No active categories found</option>
                  <% } %>
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                  <svg class="w-4 h-4 text-brand-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </div>
              </div>
              <p class="field-error hidden" id="err-category">Please select a category.</p>
            </div>

            <%# Base Price %>
            <div>
              <label for="basePrice" class="block text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">
                Base Price <span class="text-red-400 normal-case tracking-normal">*</span>
              </label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-brand-muted text-sm font-medium pointer-events-none">₹</span>
                <input type="number" id="basePrice" name="basePrice"
                  placeholder="0.00" min="0" step="0.01"
                  class="field-input w-full pl-8" />
              </div>
              <p class="field-error hidden" id="err-basePrice">Enter a valid price (≥ 0).</p>
              <p class="text-xs text-brand-muted mt-1.5">This is the default listing price. Individual variants can have their own price.</p>
            </div>

          </div>
        </div>

        <%# ── Card: Main Product Images ── %>
        <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
          <h2 class="text-sm font-semibold text-kiso-text uppercase tracking-wider mb-2 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Product Images
          </h2>
          <p class="text-xs text-brand-muted mb-5">Upload the main gallery images for this product. Shown on the product listing page.</p>

          <input type="file" id="images" name="images"  accept="image/*"
            class="hidden" onchange="handleMainImages(this)" />
          <label for="images"
            id="mainImageDropZone"
            class="block border-2 border-dashed border-white/10 hover:border-brand-accent/40 rounded-xl p-8 text-center cursor-pointer transition group">
            <svg class="w-10 h-10 text-white/20 group-hover:text-brand-accent/40 mx-auto mb-3 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p class="text-sm font-medium text-brand-muted group-hover:text-brand-light transition">Click to upload images</p>
            <p class="text-xs text-white/25 mt-1">JPG, PNG, WebP · Max 8 MB each</p>
          </label>
          <p class="field-error hidden mt-2" id="err-images">At least one product image is required.</p>

          <div id="mainImgPreview" class="flex flex-wrap gap-2 mt-4"></div>
        </div>

        <%# ── Card: Publish ── %>
        <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
          <h2 class="text-sm font-semibold text-kiso-text uppercase tracking-wider mb-5 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Publish
          </h2>

          <div class="flex gap-3">
            <a href="/admin/products"
              class="flex-1 text-center bg-brand-bg2 hover:bg-white/10 border border-white/10 text-brand-muted hover:text-brand-light font-medium px-4 py-3 rounded-xl text-sm transition">
              Discard
            </a>
            <button type="submit" id="saveProductBtn"
              class="flex-1 flex items-center justify-center gap-2 bg-brand-accent hover:bg-brand-accent/90 text-white font-semibold px-4 py-3 rounded-xl text-sm transition shadow-lg shadow-brand-accent/20 disabled:opacity-50 disabled:cursor-not-allowed">
              <span id="saveBtnLabel">Save Product</span>
              <svg id="saveBtnSpinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
            </button>
          </div>
        </div>

      </div><%# end right column %>

    </div>
  </form>
   <%- include('./croperModal') %>
</div><%# end page wrapper %>


<%# Page script — loaded after DOM is ready %>
<script src="/js/admin/productAdd.js" defer></script>

