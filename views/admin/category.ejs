<div class="w-full">

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-kiso-text">Category Management</h1>
    <p class="text-brand-muted text-sm mt-1">View and manage product categories</p>
  </div>

  <!-- Search + Add -->
  <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 mb-8">
    <div class="flex items-center flex-1 bg-brand-bg2 border border-white/10 rounded-lg px-4 py-3 gap-3">
      <svg class="w-4 h-4 text-brand-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.35-4.35" />
      </svg>
      <input type="text" id="searchInput" placeholder="Search by name"
        class="bg-transparent outline-none text-kiso-text placeholder-brand-muted text-sm w-full" />
    </div>
    <button
      class="bg-brand-bg2 border border-white/10 text-kiso-text px-5 py-3 rounded-lg text-sm hover:bg-white/5 transition">
      Search
    </button>
    <button id="addCategoryBtn" onclick="toggleAddCategoryModal()"
      class="bg-kiso-text text-kiso-bg px-5 py-3 rounded-lg text-sm font-semibold hover:bg-white/90 transition">
      + Add Category
    </button>
  </div>

  <!-- Table -->
  <div class="border border-white/10 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">

      <!-- Head -->
      <thead>
        <tr class="bg-brand-bg2 border-b border-white/10">
          <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">ID</th>
          <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs"> Category Name
          </th>
          <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Created Date</th>
          <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Description</th>
          <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Products</th>
          <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Status</th>
          <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Edit</th>
          <th class="text-left text-brand-muted font-medium px-6 py-4 uppercase tracking-wide text-xs">Action</th>
        </tr>
      </thead>

      <!-- Body -->
      <tbody class="divide-y divide-white/10">
        <% categories.forEach((category, index)=> { %>
          <tr class="hover:bg-white/5 transition category-row" data-name="<%= category.categoryName.toLowerCase() %>">

            <!-- ID -->
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="text-kiso-text font-medium">C#<%= String(index + 1).padStart(3, '0' ) %></span>
            </td>

            <!-- Name + Avatar -->
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center gap-3">
                <div
                  class="w-8 h-8 rounded-full bg-brand-accent flex items-center justify-center text-kiso-bg text-xs font-bold">
                  <%= category.categoryName.charAt(0).toUpperCase() %>
                </div>
                <span class="text-kiso-text font-medium">
                  <%= category.name %>
                </span>
              </div>
            </td>

            <!-- Created Date -->
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="text-brand-muted text-sm">
                <%= new Date(category.createdAt).toISOString().split('T')[0] %>
              </span>
            </td>

            <!-- Description -->
            <td class="px-6 py-4">
              <span class="text-brand-muted text-sm">
                <%= category.description || 'N/A' %>
              </span>
            </td>

            <!-- Product Count -->
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="text-kiso-text font-medium">
                <%= category.productCount || 0 %>
              </span>
            </td>

            <!-- Status -->
            <td class="px-6 py-4 whitespace-nowrap">
              <% if (category.isActieve) { %>
                <span
                  class="px-3 py-1 inline-flex text-xs font-semibold rounded-full bg-green-400/10 text-green-400 border border-green-400/20">
                  Active
                </span>
                <% } else { %>
                  <span
                    class="px-3 py-1 inline-flex text-xs font-semibold rounded-full bg-red-400/10 text-red-400 border border-red-400/20">
                    Inactive
                  </span>
                  <% } %>
            </td>

            <!-- Edit -->
            <td class="px-6 py-4 whitespace-nowrap">
              <button onclick="editCategory('<%= category._id %>')"
                class="border border-green-400/40 text-green-400 px-4 py-1 rounded-full text-xs hover:bg-green-400/10 transition">
                Edit
              </button>
            </td>

            <!-- Action -->
            <td class="px-6 py-4 whitespace-nowrap">
              <button onclick="deleteCategory('<%= category._id %>')"
                class="bg-red-500/80 text-white px-4 py-1 rounded-lg text-xs hover:bg-red-600 transition">
                Delete
              </button>
            </td>

          </tr>
          <% }) %>
      </tbody>

    </table>
    </div>
  </div>

  <!-- Empty State -->
  <% if (!categories || categories.length===0) { %>
    <div class="text-center py-16 border border-white/10 rounded-xl mt-0">
      <p class="text-brand-muted text-sm">No categories found.</p>
      <a href="/admin/categories/add" class="mt-4 inline-block text-brand-accent text-sm underline">Add your first
        category</a>
    </div>
    <% } %>

      <!-- Pagination -->
      <div class="flex items-center justify-between mt-6">
        <p class="text-brand-muted text-sm">
          Showing <%= ((currentPage - 1) * perPage) + 1 %> to
            <%= Math.min(currentPage * perPage, totalCategories) %> of
              <%= totalCategories %> categories
        </p>

        <div class="flex items-center gap-2">

          <% if (currentPage> 1) { %>
            <a href="?page=<%= currentPage - 1 %>"
              class="px-3 py-2 border border-white/10 rounded-lg text-brand-muted hover:bg-white/5 transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
            </a>
            <% } %>

              <% for (let i=1; i <=totalPages; i++) { %>
                <a href="?page=<%= i %>"
                  class="px-4 py-2 rounded-lg text-sm transition
          <%= i === currentPage ? 'bg-white/10 text-kiso-text' : 'border border-white/10 text-brand-muted hover:bg-white/5' %>">
                  <%= i %>
                </a>
                <% } %>

                  <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %>"
                      class="px-3 py-2 border border-white/10 rounded-lg text-brand-muted hover:bg-white/5 transition">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                    <% } %>

        </div>
      </div>

</div>
<%- include('./category-add') %>
  <script src="/js/admin_side/categoryManagement.js"></script>