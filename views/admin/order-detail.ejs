<div id="orderDetailRoot" data-order-id="<%= order._id %>" class="p-4 sm:p-8 max-w-5xl mx-auto w-full font-sans transition-colors duration-300">

  <%
    var statusClasses = {
      pending:          'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
      confirmed:        'bg-blue-500/10 text-blue-400 border-blue-500/20',
      processing:       'bg-blue-500/10 text-blue-400 border-blue-500/20',
      shipped:          'bg-purple-500/10 text-purple-400 border-purple-500/20',
      out_for_delivery: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
      delivered:        'bg-green-500/10 text-green-400 border-green-500/20',
      cancelled:        'bg-red-500/10 text-red-400 border-red-500/20',
      return_requested: 'bg-orange-500/10 text-orange-400 border-orange-500/20',
      returned:         'bg-gray-500/10 text-gray-400 border-gray-500/20',
      refunded:         'bg-green-500/10 text-green-400 border-green-500/20'
    };
    var statusLabels = {
      pending:          'Order Placed',
      confirmed:        'Order Placed',
      processing:       'Order Placed',
      shipped:          'Shipped',
      out_for_delivery: 'Out for Delivery',
      delivered:        'Delivered',
      cancelled:        'Cancelled',
      return_requested: 'Return Requested',
      returned:         'Returned',
      refunded:         'Refunded'
    };
    var currentCls = statusClasses[order.orderStatus] || 'bg-gray-500/10 text-gray-400 border-gray-500/20';
    var currentLbl = statusLabels[order.orderStatus] || order.orderStatus;
    var allCancelled = order.orderItems && order.orderItems.length > 0 &&
      order.orderItems.every(function(i) { return i.status === 'cancelled'; });

    // Forward-only status transitions
    var nextStatusMap = {
      pending:          ['shipped', 'cancelled'],
      confirmed:        ['shipped', 'cancelled'],
      processing:       ['shipped', 'cancelled'],
      shipped:          ['out_for_delivery', 'cancelled'],
      out_for_delivery: ['delivered', 'cancelled'],
      delivered:        [],
      cancelled:        [],
      return_requested: [],
      returned:         []
    };
    var availableStatuses = nextStatusMap[order.orderStatus] || [];
    var statusLocked = availableStatuses.length === 0 || allCancelled;
    var statusLockedReason = allCancelled
      ? 'All items cancelled'
      : order.orderStatus === 'delivered'
        ? 'Order delivered — no further status changes'
        : ['cancelled','return_requested','returned'].includes(order.orderStatus)
          ? 'Status is final'
          : null;
  %>

  <!-- Back Link -->
  <a
    href="/admin/orders"
    class="inline-flex items-center gap-2 text-brand-muted hover:text-kiso-text transition-colors text-sm mb-8"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Orders
  </a>

  <!-- Header -->
  <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-10">
    <div>
      <h1 class="text-3xl font-bold text-kiso-text tracking-tight font-mono"><%= displayId %></h1>
      <p class="text-sm text-brand-muted mt-1">
        Placed on <%= new Date(order.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
      </p>
    </div>
    <span class="self-start sm:self-auto px-4 py-2 border rounded-full text-sm font-semibold tracking-wide <%= currentCls %>">
      <%= currentLbl %>
    </span>
  </header>

  <!-- Status Update -->
  <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 mb-6 shadow-lg shadow-black/20">
    <h2 class="text-sm font-semibold text-brand-muted uppercase tracking-wider mb-4">Update Order Status</h2>
    <% if (statusLocked) { %>
      <div class="flex items-center gap-2 text-sm text-brand-muted font-semibold">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        <%= statusLockedReason %>
      </div>
    <% } else { %>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
        <div class="relative flex-1">
          <select
            id="statusSelect"
            class="w-full pl-4 pr-10 py-3 bg-brand-bg2 border border-white/10 rounded-xl text-kiso-text focus:outline-none focus:border-brand-accent transition-colors appearance-none shadow-lg shadow-black/10"
          >
            <% availableStatuses.forEach(function(s) { %>
              <option value="<%= s %>"><%= statusLabels[s] || s %></option>
            <% }); %>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-4 flex items-center">
            <svg class="w-4 h-4 text-brand-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </div>
        <button
          id="updateStatusBtn"
          onclick="updateOrderStatus()"
          class="px-7 py-3 bg-brand-accent text-kiso-bg font-semibold rounded-xl hover:bg-brand-accent/90 transition-colors shadow-lg shadow-brand-accent/20 whitespace-nowrap"
        >
          Update Status
        </button>
      </div>
    <% } %>
  </div>

  <!-- COD Payment Status -->
  <% if (order.paymentMethod === 'cod' && order.paymentStatus !== 'refunded') { %>
    <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 mb-6 shadow-lg shadow-black/20">
      <h2 class="text-sm font-semibold text-brand-muted uppercase tracking-wider mb-4">Payment Status (COD)</h2>
      <div class="flex items-center justify-between gap-4">
        <span class="text-sm font-semibold <%= order.paymentStatus === 'paid' ? 'text-green-400' : 'text-yellow-400' %>">
          <%= order.paymentStatus === 'paid' ? 'Paid' : 'Pending' %>
        </span>
        <% if (order.paymentStatus === 'pending') { %>
          <button
            id="markPaidBtn"
            onclick="markCODPaid()"
            class="px-6 py-2.5 bg-green-500/10 hover:bg-green-500/20 text-green-400 border border-green-500/20 font-semibold text-sm rounded-xl transition-colors whitespace-nowrap"
          >
            Mark as Paid
          </button>
        <% } else { %>
          <span class="px-4 py-2 text-xs font-semibold text-green-400 border border-green-500/20 rounded-xl bg-green-500/5">Payment Collected</span>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- Delivery Progress Tracker -->
  <%
    var trackerOrder   = ['pending', 'confirmed', 'processing', 'shipped', 'out_for_delivery', 'delivered'];
    var cancelledSet   = ['cancelled', 'return_requested', 'returned'];
    var isCancelled    = cancelledSet.includes(order.orderStatus);
    var curTrackerIdx  = trackerOrder.indexOf(order.orderStatus);
    var trackerSteps   = [
      { label: 'Order Placed',     statuses: ['pending', 'confirmed', 'processing'] },
      { label: 'Shipped',          statuses: ['shipped'] },
      { label: 'Out for Delivery', statuses: ['out_for_delivery'] },
      { label: 'Delivered',        statuses: ['delivered'] }
    ];
    function getTrackerState(stepStatuses) {
      if (isCancelled) return 'upcoming';
      var maxIdx = Math.max.apply(null, stepStatuses.map(function(s) { return trackerOrder.indexOf(s); }));
      if (curTrackerIdx > maxIdx) return 'done';
      if (stepStatuses.indexOf(order.orderStatus) > -1) return 'current';
      return 'upcoming';
    }
  %>
  <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 mb-6 shadow-lg shadow-black/20">
    <h2 class="text-sm font-semibold text-brand-muted uppercase tracking-wider mb-5">Delivery Progress</h2>
    <% if (isCancelled) { %>
      <div class="flex items-center gap-2 text-sm font-semibold <%= order.orderStatus === 'cancelled' ? 'text-red-400' : 'text-orange-400' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <%= currentLbl %>
      </div>
    <% } else { %>
      <div class="flex items-center">
        <% trackerSteps.forEach(function(step, i) {
          var state  = getTrackerState(step.statuses);
          var isLast = i === trackerSteps.length - 1;
          var prevState = i > 0 ? getTrackerState(trackerSteps[i-1].statuses) : null;
        %>
          <div class="flex flex-col items-center flex-1">
            <div class="flex items-center w-full">
              <% if (i > 0) { %>
                <div class="flex-1 h-0.5 <%= (prevState === 'done' || state === 'done' || state === 'current') ? 'bg-brand-accent' : 'bg-white/10' %> transition-all duration-500"></div>
              <% } else { %><div class="flex-1"></div><% } %>

              <% if (state === 'done') { %>
                <div class="w-9 h-9 rounded-full bg-brand-accent flex items-center justify-center flex-shrink-0 shadow-lg shadow-brand-accent/20">
                  <svg class="w-4 h-4 text-kiso-bg" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
              <% } else if (state === 'current') { %>
                <div class="w-9 h-9 rounded-full border-2 border-brand-accent bg-brand-bg2 flex items-center justify-center flex-shrink-0">
                  <span class="w-3 h-3 rounded-full bg-brand-accent animate-pulse"></span>
                </div>
              <% } else { %>
                <div class="w-9 h-9 rounded-full border-2 border-white/15 bg-white/5 flex items-center justify-center flex-shrink-0">
                  <span class="w-2 h-2 rounded-full bg-white/20"></span>
                </div>
              <% } %>

              <% if (!isLast) { %>
                <div class="flex-1 h-0.5 <%= state === 'done' ? 'bg-brand-accent' : 'bg-white/10' %> transition-all duration-500"></div>
              <% } else { %><div class="flex-1"></div><% } %>
            </div>
            <p class="text-xs font-semibold mt-2.5 text-center leading-tight
              <%= state === 'done' ? 'text-brand-accent' : state === 'current' ? 'text-kiso-text' : 'text-brand-muted/50' %>">
              <%= step.label %>
            </p>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

    <!-- Customer Info -->
    <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
      <h2 class="text-sm font-semibold text-brand-muted uppercase tracking-wider mb-4 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
        </svg>
        Customer
      </h2>
      <% if (order.userId) { %>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-kiso-bg font-bold flex-shrink-0" style="background-color: #9A8478;">
            <%= order.userId.name ? order.userId.name.charAt(0).toUpperCase() : '?' %>
          </div>
          <div>
            <p class="font-semibold text-brand-light"><%= order.userId.name || 'N/A' %></p>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex items-center gap-2 text-brand-muted">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            <span class="truncate"><%= order.userId.email || 'N/A' %></span>
          </div>
          <div class="flex items-center gap-2 text-brand-muted">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            <span><%= order.userId.phone || 'N/A' %></span>
          </div>
        </div>
      <% } else { %>
        <p class="text-brand-muted text-sm">User account deleted</p>
      <% } %>
    </div>

    <!-- Shipping Address -->
    <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
      <h2 class="text-sm font-semibold text-brand-muted uppercase tracking-wider mb-4 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
        </svg>
        Shipping Address
      </h2>
      <% if (order.shippingAddress) { %>
        <div class="space-y-1 text-sm text-brand-muted">
          <% if (order.shippingAddress.name) { %>
            <p class="font-semibold text-brand-light"><%= order.shippingAddress.name %></p>
          <% } %>
          <% if (order.shippingAddress.addressLine1) { %><p><%= order.shippingAddress.addressLine1 %></p><% } %>
          <% if (order.shippingAddress.addressLine2) { %><p><%= order.shippingAddress.addressLine2 %></p><% } %>
          <% if (order.shippingAddress.city || order.shippingAddress.state) { %>
            <p><%= [order.shippingAddress.city, order.shippingAddress.state].filter(Boolean).join(', ') %></p>
          <% } %>
          <% if (order.shippingAddress.pincode || order.shippingAddress.postalCode) { %>
            <p><%= order.shippingAddress.pincode || order.shippingAddress.postalCode %></p>
          <% } %>
          <% if (order.shippingAddress.country) { %><p><%= order.shippingAddress.country %></p><% } %>
          <% if (order.shippingAddress.phone) { %>
            <p class="pt-1"><%= order.shippingAddress.phone %></p>
          <% } %>
        </div>
      <% } else { %>
        <p class="text-brand-muted text-sm">No address on record</p>
      <% } %>
    </div>

    <!-- Order Summary -->
    <div class="bg-brand-bg1 border border-white/10 rounded-2xl p-6 shadow-lg shadow-black/20">
      <h2 class="text-sm font-semibold text-brand-muted uppercase tracking-wider mb-4 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
        </svg>
        Order Summary
      </h2>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between text-brand-muted">
          <span>Subtotal</span>
          <span class="text-brand-light">&#8377;<%= (order.subtotal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
        </div>
        <div class="flex justify-between text-brand-muted">
          <span>Shipping</span>
          <% if (!order.shippingCost || order.shippingCost === 0) { %>
            <span class="text-green-400 font-semibold">FREE</span>
          <% } else { %>
            <span class="text-brand-light">&#8377;<%= order.shippingCost.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
          <% } %>
        </div>
        <% if (order.discount && order.discount > 0) { %>
          <div class="flex justify-between text-brand-muted">
            <span>Discount</span>
            <span class="text-green-400">-&#8377;<%= order.discount.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
          </div>
        <% } %>
        <div class="border-t border-white/10 pt-2 mt-2 flex justify-between">
          <span class="font-bold text-kiso-text">Grand Total</span>
          <span class="font-bold text-kiso-text">&#8377;<%= (order.grandTotal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
        </div>
        <div class="border-t border-white/5 pt-3 mt-1 space-y-2">
          <div class="flex justify-between text-brand-muted">
            <span>Payment Method</span>
            <span class="text-brand-light font-medium capitalize"><%= (order.paymentMethod || 'N/A').replace(/_/g, ' ') %></span>
          </div>
          <div class="flex justify-between text-brand-muted">
            <span>Payment Status</span>
            <%
              var psClass = order.paymentStatus === 'paid'
                ? 'text-green-400'
                : order.paymentStatus === 'failed'
                  ? 'text-red-400'
                  : 'text-yellow-400';
            %>
            <span class="font-semibold capitalize <%= psClass %>"><%= order.paymentStatus || 'N/A' %></span>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Cancellation Reason -->
  <% if (order.cancellationReason) { %>
    <div class="bg-red-500/5 border border-red-500/20 rounded-2xl p-5 mb-6 shadow-lg shadow-black/20">
      <h2 class="text-sm font-semibold text-red-400 uppercase tracking-wider mb-2 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
        </svg>
        Cancellation Reason
      </h2>
      <p class="text-sm text-brand-muted"><%= order.cancellationReason %></p>
    </div>
  <% } %>

  <!-- Return Request -->
  <% if (order.orderStatus === 'return_requested' || order.orderStatus === 'returned') { %>
    <div class="bg-orange-500/5 border border-orange-500/20 rounded-2xl p-5 mb-6 shadow-lg shadow-black/20">
      <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
        <div class="flex-1">
          <h2 class="text-sm font-semibold text-orange-400 uppercase tracking-wider mb-3 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
            </svg>
            Return Request
          </h2>
          <% if (order.returnReason) { %>
            <p class="text-sm text-brand-muted mb-1"><span class="text-brand-light font-semibold">Reason:</span> <%= order.returnReason %></p>
          <% } %>
          <% if (order.returnApprovedAt) { %>
            <p class="text-xs text-green-400 mt-2">Approved on <%= new Date(order.returnApprovedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
          <% } %>
        </div>
        <% if (order.returnImage) { %>
          <a href="<%= order.returnImage %>" target="_blank" class="flex-shrink-0">
            <img src="<%= order.returnImage %>" alt="Return proof" class="w-24 h-24 object-cover rounded-xl border border-orange-500/20 hover:opacity-80 transition-opacity"/>
          </a>
        <% } %>
      </div>
      <% if (order.orderStatus === 'return_requested') { %>
        <div class="mt-4 pt-4 border-t border-orange-500/10">
          <button id="approveReturnBtn" onclick="approveReturn()"
            class="px-6 py-2.5 bg-green-500/10 hover:bg-green-500/20 text-green-400 border border-green-500/20 font-semibold text-sm rounded-xl transition-colors">
            Approve Return & Refund
          </button>
        </div>
      <% } else { %>
        <div class="mt-3 pt-3 border-t border-orange-500/10">
          <span class="text-xs font-semibold text-green-400 px-3 py-1.5 bg-green-500/10 border border-green-500/20 rounded-lg">Return Approved · Refunded</span>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- Order Items -->
  <div class="bg-brand-bg1 border border-white/10 rounded-2xl overflow-hidden shadow-lg shadow-black/20 mb-8">
    <div class="px-6 py-4 border-b border-white/5">
      <h2 class="text-sm font-semibold text-brand-muted uppercase tracking-wider flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/>
        </svg>
        Order Items
        <span class="ml-1 px-2 py-0.5 bg-brand-bg2 border border-white/5 rounded-full text-xs text-brand-muted">
          <%= order.orderItems ? order.orderItems.length : 0 %>
        </span>
      </h2>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-brand-bg2/80 border-b border-white/5 text-brand-muted uppercase tracking-wider text-[11px]">
          <tr>
            <th class="px-6 py-4 font-semibold text-left">Product</th>
            <th class="px-6 py-4 font-semibold text-center">Qty</th>
            <th class="px-6 py-4 font-semibold text-right">Unit Price</th>
            <th class="px-6 py-4 font-semibold text-right">Total</th>
            <th class="px-6 py-4 font-semibold text-center">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <% if (!order.orderItems || order.orderItems.length === 0) { %>
            <tr>
              <td colspan="5" class="px-6 py-10 text-center text-brand-muted">No items in this order</td>
            </tr>
          <% } else { %>
            <% order.orderItems.forEach(function(item) { %>
              <%
                var itemCls = statusClasses[item.status] || 'bg-gray-500/10 text-gray-400 border-gray-500/20';
                var itemLbl = statusLabels[item.status] || (item.status || 'N/A');
                var thumbnail = null;
                if (item.productId && item.productId.variants) {
                  var vi = item.variantIndex != null ? item.variantIndex : 0;
                  var variant = item.productId.variants[vi];
                  if (variant && variant.images && variant.images.length > 0) {
                    thumbnail = variant.images[0];
                  }
                }
                var productName = item.productId ? (item.productId.productName || 'Unknown Product') : 'Deleted Product';
                var unitPrice = item.price || 0;
                var itemTotal = unitPrice * (item.quantity || 1);
              %>
              <tr class="hover:bg-white/5 transition-colors group">
                <!-- Product -->
                <td class="px-6 py-4">
                  <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-xl overflow-hidden border border-white/10 bg-brand-bg2 flex-shrink-0 flex items-center justify-center">
                      <% if (thumbnail) { %>
                        <img src="<%= thumbnail %>" alt="<%= productName %>" class="w-full h-full object-cover" />
                      <% } else { %>
                        <svg class="w-7 h-7 text-brand-muted/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                        </svg>
                      <% } %>
                    </div>
                    <div>
                      <p class="font-semibold text-brand-light"><%= productName %></p>
                      <% if (item.cancellationReason) { %>
                        <p class="text-xs text-red-400 mt-0.5">Cancelled: <%= item.cancellationReason %></p>
                      <% } %>
                      <% if (item.returnReason) { %>
                        <p class="text-xs text-orange-400 mt-0.5">Return: <%= item.returnReason %></p>
                      <% } %>
                    </div>
                  </div>
                </td>

                <!-- Qty -->
                <td class="px-6 py-4 text-center">
                  <span class="font-bold text-kiso-text"><%= item.quantity || 1 %></span>
                </td>

                <!-- Unit Price -->
                <td class="px-6 py-4 text-right text-brand-muted">
                  &#8377;<%= unitPrice.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                </td>

                <!-- Total -->
                <td class="px-6 py-4 text-right font-semibold text-brand-light">
                  &#8377;<%= itemTotal.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                </td>

                <!-- Status -->
                <td class="px-6 py-4 text-center">
                  <span class="px-3 py-1 border rounded-full text-xs font-semibold tracking-wide <%= itemCls %>">
                    <%= itemLbl %>
                  </span>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script src="/js/admin/orderDeatials.js"></script>