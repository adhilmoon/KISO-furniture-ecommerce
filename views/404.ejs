<div class="min-h-screen bg-brand-bg1 flex flex-col items-center justify-center px-6 py-20 relative overflow-hidden">

    <!-- Subtle grain overlay -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none"
        style="background-image: url('https://grainy-gradients.vercel.app/noise.svg');"></div>

    <!-- Ambient accent glow -->
    <div class="absolute -top-40 -left-40 w-[480px] h-[480px] rounded-full bg-brand-accent/10 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-40 -right-40 w-[480px] h-[480px] rounded-full bg-brand-accent/5 blur-3xl pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-5xl text-center">

        <!-- 404 with broken chair inside the zero -->
        <div class="flex items-center justify-center select-none gap-2 sm:gap-4 md:gap-6">
            <span class="text-[180px] sm:text-[260px] md:text-[360px] lg:text-[420px] font-black leading-none tracking-tighter text-brand-light glitch-wrapper" data-text="4">4</span>

            <!-- Hollow zero -->
            <div class="relative shrink-0
                        w-[180px] h-[180px]
                        sm:w-[260px] sm:h-[260px]
                        md:w-[360px] md:h-[360px]
                        lg:w-[420px] lg:h-[420px]">
                <!-- Outer ring -->
                <div class="absolute inset-0 rounded-full border-[20px] sm:border-[28px] md:border-[36px] lg:border-[44px] border-brand-light shadow-[0_0_60px_rgba(212,175,55,0.15)]"></div>
                <!-- Inner content (chair) -->
                <div class="absolute inset-[20px] sm:inset-[28px] md:inset-[36px] lg:inset-[44px] flex items-center justify-center">
                    <svg viewBox="0 0 200 240" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-[60%] h-[80%]">
                        <line class="chair-part leg-bl" x1="55" y1="150" x2="45" y2="230" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
                        <line class="chair-part leg-br" x1="145" y1="150" x2="155" y2="230" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
                        <line class="chair-part leg-fl" x1="65" y1="155" x2="55" y2="230" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
                        <line class="chair-part leg-fr" x1="135" y1="155" x2="145" y2="230" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
                        <rect class="chair-part seat" x="50" y="140" width="100" height="18" rx="3" fill="currentColor" />
                        <line class="chair-part slat-l" x1="75" y1="55" x2="70" y2="140" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
                        <line class="chair-part slat-m" x1="100" y1="50" x2="100" y2="140" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
                        <line class="chair-part slat-r" x1="125" y1="55" x2="130" y2="140" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
                        <rect class="chair-part backrest" x="60" y="40" width="80" height="20" rx="4" fill="currentColor" />
                    </svg>
                </div>
            </div>

            <span class="text-[180px] sm:text-[260px] md:text-[360px] lg:text-[420px] font-black leading-none tracking-tighter text-brand-light glitch-wrapper" data-text="4">4</span>
        </div>

        <!-- Copy -->
        <div class="mt-10 md:mt-14 space-y-4">
            <p class="text-xs uppercase tracking-[0.4em] text-brand-accent font-bold">Error 404</p>
            <h2 class="text-2xl md:text-4xl font-bold text-brand-light tracking-tight">
                The furniture broke.
            </h2>
            <p class="text-brand-muted text-sm md:text-base max-w-xl mx-auto leading-relaxed">
                <% if (typeof message !== 'undefined' && message) { %>
                    <%= message %>
                <% } else { %>
                    The page you’re looking for has been moved, removed, or never built. Let’s get you back to the showroom.
                <% } %>
            </p>
        </div>

        <!-- CTA -->
        <div class="mt-10 flex flex-col sm:flex-row gap-3 items-center justify-center">
            <a href="/"
                class="inline-flex items-center gap-2 px-8 py-3.5 bg-brand-accent text-brand-bg1 font-bold text-xs uppercase tracking-widest rounded-xl hover:scale-[1.02] transition-transform shadow-xl shadow-brand-accent/20">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Home
            </a>
            <a href="/user/store"
                class="inline-flex items-center gap-2 px-8 py-3.5 border border-white/10 text-brand-light font-semibold text-xs uppercase tracking-widest rounded-xl hover:bg-white/5 transition-colors">
                Browse Store
            </a>
        </div>
    </div>
</div>

<style>
    /* Glitch on side 4s */
    .glitch-wrapper { position: relative; display: inline-block; line-height: 1; }
    .glitch-wrapper::before,
    .glitch-wrapper::after {
        content: attr(data-text);
        position: absolute;
        inset: 0;
        pointer-events: none;
    }
    .glitch-wrapper::before {
        left: 2px;
        text-shadow: -1px 0 #A67B5B;
        clip-path: inset(24% 0 29% 0);
        animation: glitch-anim-1 2.5s infinite linear alternate-reverse;
    }
    .glitch-wrapper::after {
        left: -2px;
        text-shadow: -1px 0 #cc4444;
        clip-path: inset(54% 0 21% 0);
        animation: glitch-anim-2 3s infinite linear alternate-reverse;
    }
    @keyframes glitch-anim-1 {
        0% { clip-path: inset(80% 0 2% 0); }
        20% { clip-path: inset(20% 0 60% 0); }
        40% { clip-path: inset(50% 0 10% 0); }
        60% { clip-path: inset(10% 0 80% 0); }
        80% { clip-path: inset(90% 0 5% 0); }
        100% { clip-path: inset(30% 0 40% 0); }
    }
    @keyframes glitch-anim-2 {
        0% { clip-path: inset(10% 0 80% 0); }
        20% { clip-path: inset(80% 0 10% 0); }
        40% { clip-path: inset(40% 0 50% 0); }
        60% { clip-path: inset(20% 0 20% 0); }
        80% { clip-path: inset(5% 0 90% 0); }
        100% { clip-path: inset(60% 0 30% 0); }
    }

    /* Broken-chair animation (re-used) */
    .chair-part {
        color: #d4af37;
        transform-box: fill-box;
        transform-origin: center center;
        animation-duration: 4s;
        animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        animation-iteration-count: infinite;
    }
    .seat     { animation-name: break-seat; }
    .backrest { animation-name: break-backrest; }
    .slat-l   { animation-name: break-slat-l; }
    .slat-m   { animation-name: break-slat-m; }
    .slat-r   { animation-name: break-slat-r; }
    .leg-bl   { animation-name: break-leg-bl; }
    .leg-br   { animation-name: break-leg-br; }
    .leg-fl   { animation-name: break-leg-fl; }
    .leg-fr   { animation-name: break-leg-fr; }

    @keyframes break-seat {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(0, 55px) rotate(25deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
    @keyframes break-backrest {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(-40px, -50px) rotate(-30deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
    @keyframes break-slat-l {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(-35px, -20px) rotate(-45deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
    @keyframes break-slat-m {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(5px, -40px) rotate(10deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
    @keyframes break-slat-r {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(35px, -20px) rotate(45deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
    @keyframes break-leg-bl {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(-40px, 40px) rotate(-40deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
    @keyframes break-leg-br {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(40px, 40px) rotate(40deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
    @keyframes break-leg-fl {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(-25px, 50px) rotate(-20deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
    @keyframes break-leg-fr {
        0%, 28% { transform: translate(0,0) rotate(0); }
        50%, 68% { transform: translate(25px, 50px) rotate(20deg); }
        90%, 100% { transform: translate(0,0) rotate(0); }
    }
</style>
