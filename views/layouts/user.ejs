<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - KISO
    </title>

    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg">
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.svg">
    <link rel="manifest" href="/icons/site.webmanifest">
    <meta name="theme-color" content="#0A0A0A">

    <link href="/css/output.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">

    <link rel="preconnect" href="https://play.gumlet.io" crossorigin>
    <link rel="dns-prefetch" href="https://play.gumlet.io">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet">

    <style>
      :root {
        --font-display: 'Anton', 'Impact', sans-serif;
        --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', ui-monospace, monospace;
        --font-jp: 'Noto Sans JP', sans-serif;
        --c-accent: #D4AF37;       /* KISO brand gold */
        --c-accent-soft: #B8941F;  /* darker gold for hover */
        --c-neon: #D4AF37;         /* legacy alias — render as gold */
        --c-ink: #050505;
        --c-paper: #E8E2D5;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-body);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .font-display { font-family: var(--font-display); letter-spacing: -0.01em; }
      .font-mono { font-family: var(--font-mono); }
      .font-jp { font-family: var(--font-jp); }
      .text-neon { color: var(--c-accent); }
      .bg-neon { background-color: var(--c-accent); }
      .border-neon { border-color: var(--c-accent); }
      .bg-ink { background-color: var(--c-ink); }
      .bg-paper { background-color: var(--c-paper); }
      .text-paper { color: var(--c-paper); }

      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .marquee-track {
        animation: marquee 38s linear infinite;
        will-change: transform;
      }
      .grain::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/></svg>");
        opacity: 0.06;
        mix-blend-mode: overlay;
        z-index: 1;
      }
      .grid-dots {
        background-image: radial-gradient(rgba(212,175,55,0.07) 1px, transparent 1px);
        background-size: 24px 24px;
      }
      .text-stroke {
        -webkit-text-stroke: 1px rgba(212,175,55,0.35);
        color: transparent;
      }
      @keyframes reveal-up {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .reveal { animation: reveal-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) both; }

      /* Hero scrollytelling — smoother step transitions, no judder. */
      .step {
        transition: opacity 600ms cubic-bezier(0.4, 0, 0.2, 1),
                    transform 700ms cubic-bezier(0.16, 1, 0.3, 1) !important;
      }
    </style>

</head>

<body class="bg-brand-bg1 flex flex-col min-h-screen">

    <!-- Header -->
    <%- include('../partials/user/header') %>

        <% if (locals.isProfilePage) { %>
            <div class="flex-grow flex bg-brand-bg1 mt-24">

                <aside class="hidden md:block w-64 bg-brand-bg1 border-r border-white/5 relative z-10">
                    <%- include('../partials/user/profile-sidebar') %>
                </aside>

                <main class="flex-1 overflow-y-auto">
                    <div class="max-w-5xl mx-auto px-4 py-8 md:py-12">
                        <%- body %>
                    </div>
                </main>

            </div>
            <% } else { %>
                <main class="w-full">
                    <%- body %>
                </main>
                <% } %>



                    <!-- Footer -->
                    <%- include('../partials/user/footer') %>

                        <!-- Scripts -->
                        <script src="https://cdn.jsdelivr.net/npm/axios@1.13.2/dist/axios.min.js"></script>
                        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
                        <script src="/js/shared/toast.js"></script>
                        <script src="/js/shared/logout.js"></script>
                        <script src="/js/shared/sideBar.js"></script>
                        <script src="/js/shared/confirm.js"></script>
                        <script src="/js/shared/image-handler.js"></script>
                        <script src="/js/shared/cacheHandler.js"></script>
                        <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
                        
                     
</body>

</html>