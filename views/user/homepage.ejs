<main class="bg-brand-bg1 text-stone-100 selection:bg-brand-accent/30">


    <!-- Scrollytelling Section -->
    <div id="scrolly-container">
        <!-- The sticky visual container -->
        <div class="sticky-wrapper">
            <!-- Native video: scrubbed by scroll position (primary) -->
            <video id="sofa-video"
                class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 object-cover"
                style="width:100vw; height:56.25vw; min-height:100vh; min-width:177.78vh;"
                muted playsinline preload="auto" disablepictureinpicture
                poster="">
                <source src="/videos/hero-sofa.mp4" type="video/mp4">
            </video>

            <!-- Fallback: looping Gumlet embed, shown only if native video can't load -->
            <iframe id="sofa-video-frame"
                src="https://play.gumlet.io/embed/6a140fc4035bf1e7e7a36f61?preload=true&autoplay=true&loop=true&background=true&disable_player_controls=true"
                class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 hidden"
                style="border:0; width:100vw; height:56.25vw; min-height:100vh; min-width:177.78vh;"
                loading="lazy"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen>
            </iframe>

            <!-- Storytelling Overlays -->
            <div id="steps-container" class="absolute inset-0 pointer-events-none bg-gradient-to-b from-black/40 via-black/20 to-black/50">
                <!-- Hero Intro (0-15%) -->
                <div data-start="0" data-end="15"
                    class="step absolute inset-0 flex flex-col items-center justify-center text-center px-6 opacity-100 transition-all duration-700 ease-out">
                    <h1
                        class="text-5xl md:text-8xl font-bold tracking-tighter mb-6 text-brand-accent drop-shadow-[0_0_15px_rgba(212,175,55,0.3)]">
                        Elevated Living.</h1>
                    <p class="text-stone-400 text-lg md:text-xl max-w-xl font-light">
                        Discover our curated collection of Japandi-inspired furniture, designed for calm and comfort.
                    </p>
                </div>

                <!-- Craftsmanship (15-40%) -->
                <div data-start="15" data-end="40"
                    class="step absolute inset-0 md:inset-y-0 md:left-0 flex flex-col justify-end items-start px-8 md:px-24 text-left w-full md:w-1/2 opacity-0 translate-y-10 transition-all duration-700 ease-out">
                    <div style="margin-bottom: 10vh; width: 100%;">
                        <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">Built for generations.</h2>
                        <p class="text-stone-400 text-lg max-w-md font-light">
                            Kiln-dried solid ash wood and precision joinery form an unyielding foundation.
                        </p>
                    </div>
                </div>

                <!-- Comfort (40-65%) -->
                <div data-start="40" data-end="65"
                    class="step absolute inset-y-0 right-0 left-auto flex flex-col justify-end items-end px-8 md:px-24 text-right w-full md:w-1/2 ml-auto opacity-0 translate-y-10 transition-all duration-700 ease-out">
                    <div
                        style="margin-bottom: 10vh; width: 100%; display: flex; flex-direction: column; align-items: flex-end;">
                        <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">Uncompromising comfort.</h2>
                        <p class="text-stone-400 text-lg max-w-md font-light">
                            Multi-layer high-resilience foam and a responsive suspension system perfectly adapt to your
                            body.
                        </p>
                    </div>
                </div>

                <!-- Materials (65-85%) -->
                <div data-start="65" data-end="85"
                    class="step absolute inset-0 md:inset-y-0 md:left-0 flex flex-col justify-end items-start px-8 md:px-24 text-left w-full md:w-1/2 opacity-0 translate-y-10 transition-all duration-700 ease-out">
                    <div style="margin-bottom: 10vh; width: 100%;">
                        <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">Everyday luxury.</h2>
                        <p class="text-stone-400 text-lg max-w-md font-light">
                            Spill-resistant, performance-grade linen blends offer a breathable, tactile harmony.
                        </p>
                    </div>
                </div>

                <!-- CTA (85-100%) -->
                <div data-start="85" data-end="100"
                    class="step absolute inset-0 flex flex-col items-center justify-center text-center px-6 opacity-0 translate-y-10 transition-all duration-700 ease-out">
                    <h2 class="text-5xl md:text-8xl font-bold tracking-tighter mb-8">Center your space.</h2>
                    <p class="text-stone-400 text-lg md:text-xl max-w-xl font-light mb-12">
                        The Signature Sofa. Crafted for modern living.
                    </p>
                    <a href="/user/store"
                        class="pointer-events-auto px-10 py-5 bg-brand-accent text-brand-bg1 font-bold tracking-widest uppercase hover:scale-105 transition-transform duration-300">
                        Shop Premium Furniture
                    </a>
                </div>
            </div>

        </div>
    </div> <!-- Close scrolly-container -->

    <!-- ─── Drop Ticker (above banner) ─────────────────────────── -->
    <div class="relative border-y border-white/10 bg-neon text-brand-bg1 overflow-hidden">
      <div class="flex marquee-track py-2.5 font-display uppercase text-xl md:text-2xl tracking-tight whitespace-nowrap">
        <div class="flex shrink-0 items-center gap-8 px-6">
          <span>◆ Drop 001 — Live Now</span>
          <span>◆ Free Ship ₹4999+</span>
          <span>◆ 30-Day Trial</span>
          <span class="font-jp">キソ・新作</span>
          <span>◆ Limited Pieces</span>
          <span>◆ Made In India</span>
        </div>
        <div class="flex shrink-0 items-center gap-8 px-6" aria-hidden="true">
          <span>◆ Drop 001 — Live Now</span>
          <span>◆ Free Ship ₹4999+</span>
          <span>◆ 30-Day Trial</span>
          <span class="font-jp">キソ・新作</span>
          <span>◆ Limited Pieces</span>
          <span>◆ Made In India</span>
        </div>
      </div>
    </div>

    <!-- Banner Slider -->
    <% if (banners && banners.length > 0) { %>
        <section id="bannerSlider"
            class="relative w-full overflow-hidden transition-colors duration-700 mb-16 md:mb-24 border-b border-white/5"
            style="background: <%= banners[0].bgColor %>;"
            data-autoplay="6000">

            <!-- Edition meta bar (top) -->
            <div class="absolute top-0 left-0 right-0 z-30 flex items-center justify-between px-6 md:px-10 py-3 font-mono text-[10px] uppercase tracking-[0.25em] text-white/75 bg-gradient-to-b from-black/40 to-transparent pointer-events-none">
              <span>// Editorial / Drop_001</span>
              <span class="hidden md:inline">N 19°04' · E 72°52'</span>
              <span><span data-banner-counter>01</span>/<%= String(banners.length).padStart(2,'0') %></span>
            </div>

            <div class="relative w-full aspect-[16/9] sm:aspect-[21/9] md:aspect-[16/6] lg:aspect-[21/8]">
                <% banners.forEach(function(b, i) { %>
                    <div class="banner-slide absolute inset-0 transition-opacity duration-700 ease-in-out <%= i === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none' %>"
                        data-index="<%= i %>" data-bg="<%= b.bgColor %>" data-text="<%= b.textColor %>"
                        style="color: <%= b.textColor %>;">
                        <img src="<%= b.image.url %>" alt="<%= b.title || 'banner' %>"
                            class="absolute inset-0 w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent"></div>

                        <div class="relative z-10 h-full flex items-end md:items-center px-6 md:px-12 lg:px-20 xl:px-28 pb-16 md:pb-0">
                            <div class="max-w-2xl">
                                <div class="flex items-center gap-3 mb-4 md:mb-6">
                                    <span class="w-1.5 h-1.5 rounded-full bg-neon animate-pulse"></span>
                                    <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-neon">New · 0<%= i + 1 %></span>
                                    <span class="h-px w-12 bg-white/30"></span>
                                </div>

                                <% if (b.title) { %>
                                    <h2 class="font-display uppercase leading-[0.88] text-5xl md:text-7xl lg:text-8xl tracking-tight drop-shadow-[0_4px_24px_rgba(0,0,0,0.7)]">
                                        <%= b.title %>
                                    </h2>
                                <% } %>
                                <% if (b.subtitle) { %>
                                    <p class="mt-4 md:mt-6 text-sm md:text-base lg:text-lg max-w-md font-medium opacity-95 drop-shadow-[0_1px_6px_rgba(0,0,0,0.5)]">
                                        <%= b.subtitle %>
                                    </p>
                                <% } %>
                                <% if (b.ctaText && b.linkUrl) { %>
                                    <a href="<%= b.linkUrl %>"
                                        class="group inline-flex items-center gap-3 mt-6 md:mt-8 pl-6 pr-3 py-3 bg-neon text-brand-bg1 font-display uppercase text-base md:text-lg tracking-tight hover:bg-white transition-colors">
                                        <span><%= b.ctaText %></span>
                                        <span class="bg-brand-bg1 text-neon w-8 h-8 flex items-center justify-center text-sm group-hover:translate-x-1 transition-transform">→</span>
                                    </a>
                                <% } %>
                            </div>
                        </div>

                        <!-- vertical katakana side label -->
                        <div class="hidden md:block absolute right-6 top-1/2 -translate-y-1/2 z-10 font-jp text-[10px] tracking-[0.4em] text-white/40 [writing-mode:vertical-rl]">
                          キソ・コレクション
                        </div>
                    </div>
                <% }); %>
            </div>

            <% if (banners.length > 1) { %>
                <button type="button" data-banner-prev
                    class="absolute left-4 md:left-6 top-1/2 -translate-y-1/2 z-20 w-11 h-11 md:w-12 md:h-12 flex items-center justify-center bg-brand-bg1/60 hover:bg-neon hover:text-brand-bg1 text-white backdrop-blur-sm border border-white/15 transition-colors">
                    <span aria-hidden="true" class="text-xl">‹</span><span class="sr-only">Previous</span>
                </button>
                <button type="button" data-banner-next
                    class="absolute right-4 md:right-6 top-1/2 -translate-y-1/2 z-20 w-11 h-11 md:w-12 md:h-12 flex items-center justify-center bg-brand-bg1/60 hover:bg-neon hover:text-brand-bg1 text-white backdrop-blur-sm border border-white/15 transition-colors">
                    <span aria-hidden="true" class="text-xl">›</span><span class="sr-only">Next</span>
                </button>

                <div class="absolute bottom-4 md:bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-1.5 bg-brand-bg1/40 backdrop-blur-sm px-3 py-2 border border-white/10">
                    <% banners.forEach(function(_, i) { %>
                        <button type="button" data-banner-dot="<%= i %>"
                            class="w-6 h-1 hover:bg-white transition-colors <%= i === 0 ? '' : 'bg-white/30' %>"
                            style="<%= i === 0 ? 'background-color:#D8FF3E;' : '' %>"
                            aria-label="Go to slide <%= i + 1 %>"></button>
                    <% }); %>
                </div>
            <% } %>
        </section>
    <% } %>

    <!-- Featured Products Section -->
    <section class="py-24 bg-brand-bg1 px-6 md:px-12 lg:px-16 xl:px-24 relative z-10">
        <div class="w-full mx-auto">
            <div class="mb-16 flex flex-col md:flex-row justify-between items-end gap-6">
                <div>
                    <h2 class="text-xs uppercase tracking-[0.3em] text-brand-accent font-bold mb-4">The Collection</h2>
                    <h3 class="text-4xl md:text-6xl font-bold tracking-tight text-brand-light">Featured Products</h3>
                </div>
                <a href="/user/store"
                    class="text-sm border-b border-brand-accent text-brand-accent pb-1 hover:text-white hover:border-white transition-colors uppercase tracking-widest font-bold">View
                    All</a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <% if(products && products.length> 0) { %>
                    <% products.slice(0, 4).forEach(product=> { %>
                        <a href="/user/product/<%= product._id %>"
                            class="group block bg-brand-bg2 rounded-3xl overflow-hidden border border-white/5 hover:border-brand-accent/40 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(212,175,55,0.15)] relative">
                            <div
                                class="aspect-square overflow-hidden relative flex items-center justify-center bg-brand-bg1">
                                <!-- Full bleed product image setup -->
                                <img src="<%= product.img %>" alt="<%= product.productName %>"
                                    class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700 ease-in-out">
                            </div>
                            <div class="p-6">
                                <h4 class="text-xl font-bold text-white mb-2">
                                    <%= product.productName %>
                                </h4>
                                <p class="text-brand-accent font-semibold tracking-wide">$<%= product.basePrice %>
                                </p>
                            </div>
                        </a>
                        <% }) %>
                            <% } else { %>
                                <p class="text-brand-muted">No products found.</p>
                                <% } %>
            </div>
        </div>
    </section>

    <!-- Room Categories Section -->
    <section class="py-32 bg-brand-bg2 px-6 md:px-12 lg:px-16 xl:px-24 relative z-10">
        <div class="w-full mx-auto">
            <div class="mb-20 text-center">
                <h2 class="text-xs uppercase tracking-[0.3em] text-brand-accent font-bold mb-4">Spaces</h2>
                <h3 class="text-4xl md:text-6xl font-bold tracking-tight text-white">Curated Rooms</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
                <% if(rooms && rooms.length> 0) { %>
                    <% rooms.slice(0, 2).forEach((room, index)=> { %>
                        <a href="<%= room.linkUrl || '/user/store' %>"
                            class="group relative aspect-[16/10] md:aspect-[1/1] rounded-[2rem] overflow-hidden inline-block w-full shadow-2xl hover:shadow-[0_0_50px_rgba(212,175,55,0.15)] transition-shadow duration-500">
                            <img src="<%= room.image.url %>" alt="<%= room.title %>"
                                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000 ease-out">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent">
                            </div>
                            <div
                                class="absolute bottom-8 left-8 md:bottom-12 md:left-12 flex flex-col items-start z-10">
                                <h4
                                    class="text-3xl md:text-5xl font-bold text-white mb-4 tracking-tight transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500 drop-shadow-md">
                                    <%= room.title %>
                                </h4>
                                <span
                                    class="inline-flex items-center gap-2 text-brand-accent font-bold uppercase tracking-widest text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                                    Explore <span class="text-lg">→</span>
                                </span>
                            </div>
                        </a>
                        <% }) %>
                            <% } else { %>
                                <p class="text-brand-muted text-center">No rooms available.</p>
                                <% } %>
            </div>
        </div>
    </section>

</main>
<script src="/js/user/homePage.js"></script>
<script src="/js/user/bannerSlider.js"></script>