<div class="min-h-screen bg-brand-bg1 pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Breadcrumbs -->
        <nav class="flex mb-8 text-sm font-medium" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2">
                <li><a href="/user/cart" class="text-brand-muted hover:text-brand-accent transition-colors">Cart</a></li>
                <li class="flex items-center space-x-2">
                    <svg class="w-4 h-4 text-brand-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-brand-light font-bold">Checkout</span>
                </li>
                <li class="flex items-center space-x-2 opacity-40">
                    <svg class="w-4 h-4 text-brand-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-brand-muted">Payment</span>
                </li>
                <li class="flex items-center space-x-2 opacity-40">
                    <svg class="w-4 h-4 text-brand-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-brand-muted">Confirm</span>
                </li>
            </ol>
        </nav>

        <div class="flex flex-col lg:flex-row gap-12">
            
            <!-- Left Side: Items and Addresses -->
            <div class="flex-1 space-y-12">
                
                <!-- Order Items -->
                <section>
                    <h2 class="text-2xl font-bold text-brand-light mb-6 flex items-center gap-3">
                        <span class="w-8 h-8 bg-brand-accent/10 border border-brand-accent/20 rounded-lg flex items-center justify-center text-brand-accent text-sm">1</span>
                        Order Items
                    </h2>
                    
                    <div class="bg-brand-bg2 rounded-2xl border border-white/5 overflow-hidden">
                        <div class="divide-y divide-white/5">
                            <% cart.items.forEach(item => { %>
                                <% 
                                    const product = item.productId;
                                    const variant = product.variants && product.variants.length > item.variantIndex ? product.variants[item.variantIndex] : null;
                                    const image = variant && variant.images && variant.images.length > 0 ? variant.images[0] : (product.img || '/images/placeholder.png');
                                %>
                                <div class="p-6 flex gap-6 items-center">
                                    <div class="w-24 h-24 bg-brand-bg1 rounded-xl overflow-hidden border border-white/5 shrink-0">
                                        <img src="<%= image %>" alt="<%= product.productName %>" class="w-full h-full object-cover">
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="text-brand-light font-bold text-lg"><%= product.productName %></h3>
                                        <div class="flex flex-wrap gap-x-4 gap-y-1 mt-1">
                                            <% if (variant) { %>
                                                <p class="text-sm text-brand-muted"><%= variant.optionType %>: <span class="text-brand-light/80"><%= variant.optionValue %></span></p>
                                            <% } %>
                                            <p class="text-sm text-brand-muted">Qty: <span class="text-brand-light/80"><%= item.quantity %></span></p>
                                        </div>
                                        <p class="text-xs text-green-500/80 font-medium mt-2 flex items-center gap-1">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>
                                            In stock
                                        </p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-brand-accent font-bold text-lg">₹<%= (item.price * item.quantity).toLocaleString() %></p>
                                        <p class="text-xs text-brand-muted mt-1">₹<%= item.price.toLocaleString() %> each</p>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </section>

                <!-- Delivery Address -->
                <section>
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-bold text-brand-light flex items-center gap-3">
                            <span class="w-8 h-8 bg-brand-accent/10 border border-brand-accent/20 rounded-lg flex items-center justify-center text-brand-accent text-sm">2</span>
                            Delivery Address
                        </h2>
                        <a href="/user/address?add=true" class="text-xs font-bold text-brand-accent hover:text-white transition-colors bg-brand-accent/10 px-4 py-2 rounded-lg border border-brand-accent/20">
                            + Add New Address
                        </a>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% if (addresses && addresses.length > 0) { %>
                            <% addresses.forEach((addr, index) => { %>
                                <label class="relative group cursor-pointer">
                                    <input type="radio" name="selectedAddress" value="<%= addr._id %>" <%= index === 0 ? 'checked' : '' %> class="peer sr-only">
                                    <div class="h-full p-6 bg-brand-bg2 border border-white/5 rounded-2xl transition-all duration-300
                                        peer-checked:border-brand-accent peer-checked:bg-brand-accent/[0.03] peer-checked:shadow-[0_0_20px_rgba(212,175,55,0.05)]
                                        group-hover:border-white/10">
                                        
                                        <div class="flex justify-between items-start mb-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-5 h-5 rounded-full border-2 border-brand-muted flex items-center justify-center peer-checked:border-brand-accent transition-colors">
                                                    <div class="w-2.5 h-2.5 rounded-full bg-brand-accent opacity-0 peer-checked:opacity-100 transition-opacity"></div>
                                                </div>
                                                <span class="text-xs font-bold uppercase tracking-wider text-brand-muted"><%= addr.type %></span>
                                            </div>
                                            <% if (addr.isDefault) { %>
                                                <span class="text-[10px] px-2 py-0.5 bg-brand-accent/10 text-brand-accent rounded font-bold uppercase">Default</span>
                                            <% } %>
                                        </div>

                                        <h4 class="text-brand-light font-bold mb-1"><%= addr.fullName %></h4>
                                        <p class="text-sm text-brand-muted leading-relaxed">
                                            <%= addr.houseName %>, <%= addr.city %><br>
                                            <%= addr.state %> - <%= addr.pincode %><br>
                                            <span class="inline-block mt-2 text-brand-light/60">Phone: <%= addr.mobile %></span>
                                        </p>
                                    </div>
                                </label>
                            <% }) %>
                        <% } else { %>
                            <div class="col-span-full py-12 px-6 border-2 border-dashed border-white/5 rounded-3xl text-center">
                                <p class="text-brand-muted mb-4">No addresses found in your account.</p>
                                <a href="/user/address" class="inline-block px-8 py-3 bg-brand-accent text-brand-bg1 font-bold rounded-xl hover:bg-yellow-500 transition shadow-lg shadow-brand-accent/20">
                                    Manage Addresses
                                </a>
                            </div>
                        <% } %>
                    </div>
                </section>

                <!-- Payment Method Toggle -->
                <section class="opacity-50 pointer-events-none">
                     <h2 class="text-2xl font-bold text-brand-light mb-6 flex items-center gap-3">
                        <span class="w-8 h-8 bg-brand-accent/10 border border-brand-accent/20 rounded-lg flex items-center justify-center text-brand-accent text-sm">3</span>
                        Payment Method
                    </h2>
                    <div class="p-6 border border-dashed border-white/10 rounded-2xl text-brand-muted italic">
                        Select an address to continue to payment options...
                    </div>
                </section>

            </div>

            <!-- Right Side: Order Summary -->
            <div class="lg:w-96">
                <div class="bg-brand-bg2 rounded-3xl border border-white/5 p-8 sticky top-32 shadow-xl">
                    <h3 class="text-2xl font-bold text-brand-light mb-8">Order Summary</h3>
                    
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-brand-muted font-medium">
                            <span>Subtotal</span>
                            <span class="text-brand-light">₹<%= cart.totalAmount.toLocaleString() %></span>
                        </div>
                        <div class="flex justify-between text-brand-muted font-medium">
                            <span>Shipping</span>
                            <span class="text-green-500 font-bold">FREE</span>
                        </div>
                        <div class="flex justify-between text-brand-muted font-medium pt-4 border-t border-white/5">
                            <span class="text-lg">Total</span>
                            <span class="text-2xl font-bold text-brand-accent">₹<%= cart.totalAmount.toLocaleString() %></span>
                        </div>
                    </div>

                    <!-- Coupon Code -->
                    <div class="mb-8">
                        <label for="coupon" class="block text-xs font-bold text-brand-muted uppercase tracking-widest mb-3">Have a coupon?</label>
                        <div class="flex gap-2 p-1.5 bg-brand-bg1 border border-white/5 rounded-xl focus-within:border-brand-accent/40 transition-colors">
                            <input type="text" id="coupon" placeholder="Enter code" class="bg-transparent border-none focus:ring-0 text-brand-light text-sm w-full px-3">
                            <button class="px-4 py-2 bg-brand-bg2 hover:bg-white/5 text-brand-light text-xs font-bold rounded-lg border border-white/5 transition-all">Apply</button>
                        </div>
                    </div>

                    <button id="btnContinueToPayment" class="w-full py-4 bg-brand-accent hover:bg-yellow-500 text-brand-bg1 font-bold rounded-xl transition-all shadow-lg shadow-brand-accent/20 transform active:scale-95 flex items-center justify-center gap-3">
                        Continue to Payment
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
                    </button>

                    <p class="mt-6 text-center text-[10px] text-brand-muted leading-relaxed">
                        Secure & Encrypted Checkout • 30-Day Return Guarantee<br>
                        By clicking continue, you agree to our <a href="#" class="underline">Terms of Service</a>.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    document.getElementById('btnContinueToPayment').addEventListener('click', function() {
        const selectedAddress = document.querySelector('input[name="selectedAddress"]:checked');
        if (!selectedAddress) {
            Swal.fire({
                icon: 'warning',
                title: 'Address Required',
                text: 'Please select a delivery address to proceed.',
                background: '#111111',
                color: '#F8F9FA',
                confirmButtonColor: '#D4AF37'
            });
            return;
        }

        const addressId = selectedAddress.value;
        window.location.href = `/checkout/payment?addressId=${addressId}`;
    });
</script>
