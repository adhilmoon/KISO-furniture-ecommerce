<div class="w-full max-w-4xl mx-auto px-4">

    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-bold text-brand-light">My Wallet</h1>
        <p class="text-brand-muted text-sm mt-1">Refunds from cancellations and returns are credited here</p>
    </div>

    <!-- Balance Card -->
    <div class="bg-gradient-to-br from-brand-accent/20 to-brand-bg2 border border-brand-accent/30 rounded-2xl p-6 mb-8 shadow-lg shadow-brand-accent/10">
        <p class="text-xs font-bold text-brand-muted uppercase tracking-widest mb-2">Available Balance</p>
        <p class="text-4xl font-extrabold text-brand-accent">₹<%= wallet.balance.toLocaleString('en-IN') %></p>
        <p class="text-brand-muted text-xs mt-3">Use this balance during checkout</p>
    </div>

    <!-- Transaction History -->
    <div class="bg-brand-bg2 rounded-xl border border-white/5 overflow-hidden">
        <div class="px-5 py-4 border-b border-white/5">
            <h2 class="text-base font-bold text-brand-light">Transaction History</h2>
        </div>
        <% if (!transactions || transactions.length === 0) { %>
            <div class="px-5 py-10 text-center text-brand-muted text-sm">No transactions yet</div>
        <% } else { %>
            <div class="divide-y divide-white/5">
                <% transactions.forEach(function(t) {
                    const isCredit = t.type === 'credit';
                    const sign = isCredit ? '+' : '-';
                    const color = isCredit ? 'text-green-400' : 'text-red-400';
                    const sourceLabel = {
                        refund_cancel:   'Order Cancellation Refund',
                        refund_return:   'Return Refund',
                        checkout_pay:    'Payment',
                        admin_credit:    'Admin Credit',
                        admin_debit:     'Admin Debit',
                        referral_bonus:  'Referral Bonus'
                    }[t.source] || t.source;
                %>
                    <div class="px-5 py-4 flex items-center justify-between gap-4">
                        <div class="flex-1 min-w-0">
                            <p class="text-brand-light font-semibold text-sm"><%= sourceLabel %></p>
                            <% if (t.description) { %>
                                <p class="text-brand-muted text-xs mt-0.5 truncate"><%= t.description %></p>
                            <% } %>
                            <p class="text-brand-muted text-[11px] mt-1">
                                <%= new Date(t.createdAt).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                            </p>
                        </div>
                        <div class="flex-shrink-0 text-right">
                            <p class="font-bold text-sm <%= color %>"><%= sign %>₹<%= t.amount.toLocaleString('en-IN') %></p>
                            <p class="text-brand-muted text-[11px] mt-0.5">Balance: ₹<%= t.balanceAfter.toLocaleString('en-IN') %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
        <div class="flex justify-center gap-2 mt-6">
            <% for (let i = 1; i <= totalPages; i++) { %>
                <a href="/user/wallet?page=<%= i %>"
                    class="px-3 py-1.5 text-xs rounded-lg border <%= i === pageNum ? 'bg-brand-accent text-brand-bg1 border-brand-accent' : 'border-white/10 text-brand-muted hover:bg-white/5' %>">
                    <%= i %>
                </a>
            <% } %>
        </div>
    <% } %>
</div>
