<div class="min-h-screen bg-brand-bg1 pt-32 pb-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <h1 class="text-3xl md:text-4xl font-bold text-brand-light mb-8">Your Cart</h1>

        <% if (!cart || !cart.items || cart.items.length === 0) { %>
            <div class="flex flex-col items-center justify-center py-20 bg-brand-bg2 rounded-2xl border border-white/5">
                <svg class="w-16 h-16 text-brand-muted mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
                <h2 class="text-xl font-semibold text-brand-light mb-2">Your cart is empty</h2>
                <p class="text-brand-muted mb-6">Looks like you haven't added anything to your cart yet.</p>
                <a href="/user/store" class="px-6 py-3 bg-brand-accent text-brand-bg1 font-bold rounded-xl hover:bg-yellow-500 transition">Continue Shopping</a>
            </div>
        <% } else { %>
            <div class="flex flex-col lg:flex-row gap-8">
                
                <!-- Left: Cart Items -->
                <div class="flex-1">
                    <div class="bg-brand-bg2 rounded-2xl border border-white/5 overflow-hidden">
                        <!-- Desktop Header -->
                        <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-4 border-b border-white/5 text-xs font-semibold text-brand-muted uppercase tracking-wider">
                            <div class="col-span-6">Product</div>
                            <div class="col-span-2 text-center">Price</div>
                            <div class="col-span-2 text-center">Quantity</div>
                            <div class="col-span-2 text-right">Total</div>
                        </div>

                        <!-- Items List -->
                        <div class="divide-y divide-white/5" id="cart-items-container">
                            <% cart.items.forEach(item => { %>
                                <% 
                                    const product = item.productId; 
                                    if(!product) return; // Ignore orphaned items if product was deleted
                                    const variant = product.variants && product.variants.length > item.variantIndex 
                                        ? product.variants[item.variantIndex] 
                                        : null;
                                    const image = variant && variant.images && variant.images.length > 0 
                                                  ? variant.images[0] 
                                                  : (product.img || '/images/placeholder.png');
                                %>
                                <div class="cart-item group md:grid grid-cols-12 gap-4 items-center p-4 transition hover:bg-white/[0.02]" data-item-id="<%= item._id %>">
                                    
                                    <!-- Product Info -->
                                    <div class="col-span-6 flex gap-3 items-center mb-3 md:mb-0 relative">
                                        <div class="w-16 h-16 bg-brand-bg1 rounded-lg overflow-hidden border border-white/5 shrink-0 flex items-center justify-center">
                                            <img src="<%= image %>" class="w-full h-full object-cover">
                                        </div>
                                        <div class="flex flex-col">
                                            <a href="/user/product/<%= product._id %>" class="text-brand-light font-semibold hover:text-brand-accent transition line-clamp-1"><%= product.productName %></a>
                                            <% if (variant) { %>
                                                <span class="text-xs text-brand-muted mt-1"><%= variant.optionValue %></span>
                                            <% } %>
                                            <!-- Mobile Price & Remove -->
                                            <div class="md:hidden flex items-center gap-4 mt-2">
                                                <span class="text-brand-accent font-medium">₹<%= item.price %></span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Price (Desktop) -->
                                    <div class="hidden md:block col-span-2 text-center text-brand-light">
                                        ₹<span class="item-price"><%= item.price %></span>
                                    </div>

                                    <!-- Quantity Selector -->
                                    <div class="col-span-2 flex justify-center items-center gap-2">
                                        <div class="flex items-center border border-white/10 rounded-lg overflow-hidden bg-brand-bg1">
                                            <button class="qty-btn minus-btn p-2 text-brand-muted hover:text-brand-light transition hover:bg-white/5">-</button>
                                            <input type="number" readonly class="qty-input w-8 text-center bg-transparent text-brand-light text-sm focus:outline-none" value="<%= item.quantity %>" min="1" data-stock="<%= variant ? variant.stock : product.baseStock || 99 %>">
                                            <button class="qty-btn plus-btn p-2 text-brand-muted hover:text-brand-light transition hover:bg-white/5">+</button>
                                        </div>
                                    </div>

                                    <!-- Total & Remove -->
                                    <div class="col-span-2 flex justify-end items-center gap-4 mt-4 md:mt-0">
                                        <span class="text-brand-accent font-bold">₹<span class="item-total"><%= item.price * item.quantity %></span></span>
                                        <button class="remove-btn p-2 text-red-400/50 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition" title="Remove item">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                        </button>
                                    </div>

                                </div>
                            <% }) %>
                        </div>
                    </div>
                    
                    <div class="mt-6 flex justify-between items-center">
                        <button id="clear-cart-btn" class="text-sm text-red-500 hover:text-red-400 transition font-medium">Clear entire cart</button>
                    </div>
                </div>

                <!-- Right: Summary -->
                <div class="lg:w-80 shrink-0">
                    <div class="bg-brand-bg2 rounded-2xl border border-white/5 p-6 sticky top-24">
                        <h3 class="text-lg font-bold text-brand-light mb-6">Order Summary</h3>
                        
                        <div class="space-y-4 text-sm mb-6 border-b border-white/5 pb-6">
                            <div class="flex justify-between text-brand-muted">
                                <span>Subtotal</span>
                                <span>₹<span id="summary-subtotal"><%= cart.totalAmount %></span></span>
                            </div>
                            <!-- Future extension: standard shipping / tax -->
                            <div class="flex justify-between text-brand-muted">
                                <span>Shipping</span>
                                <span class="text-green-500">Free</span>
                            </div>
                        </div>

                        <div class="flex justify-between items-center mb-8">
                            <span class="text-brand-light font-semibold">Total</span>
                            <span class="text-2xl font-bold text-brand-accent">₹<span id="summary-total"><%= cart.totalAmount %></span></span>
                        </div>

                        <a href="/checkout" class="w-full px-6 py-4 bg-brand-accent text-brand-bg1 font-bold rounded-xl hover:bg-yellow-500 transition shadow-lg shadow-brand-accent/20 flex justify-center items-center">
                            Proceed to Checkout
                        </a>
                        <p class="text-xs text-center text-brand-muted mt-4">Taxes and shipping calculated at checkout if applicable.</p>
                    </div>
                </div>
                
            </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/user/cart.js"></script>
