<div class="min-h-screen bg-brand-bg1 pt-28 pb-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Breadcrumbs -->
        <nav class="flex mb-10 text-sm font-medium" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2 text-brand-muted">
                <li><a href="/user/cart" class="hover:text-brand-accent transition-colors">Cart</a></li>
                <li class="flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <a href="/user/checkout" class="hover:text-brand-accent transition-colors">Checkout</a>
                </li>
                <li class="flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-brand-light font-semibold">Payment</span>
                </li>
                <li class="flex items-center space-x-2 opacity-40">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span>Confirm</span>
                </li>
            </ol>
        </nav>

        <div class="flex flex-col lg:flex-row gap-10 items-start">

            <!-- Left Column -->
            <div class="flex-1 space-y-8 min-w-0">

                <!-- Vertical Stepper Progress -->
                <div class="space-y-4">
                    <!-- Step 1: Order Items (Completed) -->
                    <div class="flex items-center gap-4 p-4 bg-brand-bg2/30 border border-white/5 rounded-2xl opacity-60">
                        <div class="w-8 h-8 rounded-full bg-green-500/20 border border-green-500/30 flex items-center justify-center text-green-500">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div>
                            <p class="text-brand-light font-bold text-sm">Order Items</p>
                            <p class="text-[10px] text-brand-muted uppercase tracking-widest">Verified</p>
                        </div>
                    </div>

                    <!-- Step 2: Delivery Address (Completed) -->
                    <div class="flex items-center gap-4 p-4 bg-brand-bg2/30 border border-white/5 rounded-2xl opacity-60">
                        <div class="w-8 h-8 rounded-full bg-green-500/20 border border-green-500/30 flex items-center justify-center text-green-500">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-brand-light font-bold text-sm">Delivery Address</p>
                            <p class="text-[10px] text-brand-muted"><%= address.fullName %> &bull; <%= address.city %></p>
                        </div>
                    </div>

                    <!-- Step 3: Payment Method (Active) -->
                    <div class="p-6 bg-brand-bg2 border border-brand-accent/30 rounded-2xl shadow-[0_0_25px_rgba(234,179,8,0.05)]">
                        <div class="flex items-center gap-4 mb-8">
                            <div class="w-8 h-8 rounded-lg bg-brand-accent flex items-center justify-center text-brand-bg1 font-bold text-sm shadow-lg shadow-brand-accent/20">
                                3
                            </div>
                            <div>
                                <h2 class="text-xl font-bold text-brand-light">Payment Method</h2>
                                <p class="text-xs text-brand-muted">Select your preferred payment option</p>
                            </div>
                        </div>

                        <!-- Razorpay Option -->
                        <div class="space-y-4">
                            <label class="relative block cursor-pointer group">
                                <input type="radio" name="paymentMethod" value="razorpay" checked class="sr-only peer">
                                <div class="flex items-center gap-5 p-5 bg-brand-bg1 border border-white/10 rounded-xl peer-checked:border-brand-accent peer-checked:bg-brand-accent/[0.04] group-hover:border-white/20 transition-all duration-300">
                                    <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center shrink-0">
                                        <svg class="w-7 h-7 text-brand-accent" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5.5-2.5l7.5-7.5-7.5-7.5 1.5-1.5 9 9-9 9-1.5-1.5z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1">
                                        <div class="flex items-center justify-between">
                                            <p class="text-brand-light font-bold">Razorpay</p>
                                            <span class="text-[10px] px-2 py-0.5 bg-brand-accent/10 text-brand-accent rounded font-bold uppercase tracking-wider">Recommended</span>
                                        </div>
                                        <p class="text-xs text-brand-muted mt-0.5 leading-relaxed">Pay securely via Cards, UPI, NetBanking or Wallets</p>
                                    </div>
                                    <div class="w-5 h-5 rounded-full border-2 border-brand-muted flex items-center justify-center shrink-0 peer-checked:border-brand-accent group-has-[:checked]:border-brand-accent">
                                        <div class="w-2.5 h-2.5 rounded-full bg-brand-accent opacity-0 group-has-[:checked]:opacity-100 transition-opacity"></div>
                                    </div>
                                </div>
                            </label>

                            <!-- Cash on Delivery -->
                            <label class="relative block cursor-pointer group">
                                <input type="radio" name="paymentMethod" value="cod" class="sr-only peer">
                                <div class="flex items-center gap-5 p-5 bg-brand-bg1 border border-white/10 rounded-xl peer-checked:border-brand-accent peer-checked:bg-brand-accent/[0.04] group-hover:border-white/20 transition-all duration-300">
                                    <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center shrink-0">
                                        <svg class="w-7 h-7 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-brand-light font-bold">Cash on Delivery</p>
                                        <p class="text-xs text-brand-muted mt-0.5 leading-relaxed">Pay in cash when your order arrives</p>
                                    </div>
                                    <div class="w-5 h-5 rounded-full border-2 border-brand-muted flex items-center justify-center shrink-0 peer-checked:border-brand-accent group-has-[:checked]:border-brand-accent">
                                        <div class="w-2.5 h-2.5 rounded-full bg-brand-accent opacity-0 group-has-[:checked]:opacity-100 transition-opacity"></div>
                                    </div>
                                </div>
                            </label>

                            <!-- Wallet -->
                            <% const walletBalanceVal = (typeof walletBalance !== 'undefined') ? walletBalance : 0; %>
                            <% const walletEligible = walletBalanceVal >= (typeof grandTotal !== 'undefined' ? grandTotal : cart.totalAmount); %>
                            <label class="relative block <%= walletEligible ? 'cursor-pointer' : 'cursor-not-allowed opacity-50' %> group">
                                <input type="radio" name="paymentMethod" value="wallet" class="sr-only peer" <%= walletEligible ? '' : 'disabled' %>>
                                <div class="flex items-center gap-5 p-5 bg-brand-bg1 border border-white/10 rounded-xl peer-checked:border-brand-accent peer-checked:bg-brand-accent/[0.04] group-hover:border-white/20 transition-all duration-300">
                                    <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center shrink-0">
                                        <svg class="w-7 h-7 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M16 12a2 2 0 100 4h5v-4h-5z"/></svg>
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-brand-light font-bold">Wallet</p>
                                        <p class="text-xs text-brand-muted mt-0.5 leading-relaxed">
                                            Balance: ₹<%= walletBalanceVal.toLocaleString('en-IN') %>
                                            <% if (!walletEligible) { %><span class="text-red-400 ml-1">(Insufficient)</span><% } %>
                                        </p>
                                    </div>
                                    <div class="w-5 h-5 rounded-full border-2 border-brand-muted flex items-center justify-center shrink-0 peer-checked:border-brand-accent group-has-[:checked]:border-brand-accent">
                                        <div class="w-2.5 h-2.5 rounded-full bg-brand-accent opacity-0 group-has-[:checked]:opacity-100 transition-opacity"></div>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Right Column: Summary -->
            <div class="lg:w-80 xl:w-96 w-full shrink-0">
                <div class="bg-brand-bg2 rounded-2xl border border-white/5 p-7 sticky top-28 shadow-xl shadow-black/20">

                    <h3 class="text-lg font-bold text-brand-light mb-6">Payment Summary</h3>

                    <% const summaryGrandTotal = (typeof grandTotal !== 'undefined') ? grandTotal : cart.totalAmount; %>
                    <% const summaryPayable = (typeof payableAmount !== 'undefined') ? payableAmount : summaryGrandTotal; %>
                    <% const summaryWallet = (typeof walletApplied !== 'undefined') ? walletApplied : 0; %>
                    <% const summaryCoupon = (typeof couponDiscount !== 'undefined') ? couponDiscount : 0; %>
                    <div class="space-y-4 text-sm mb-8">
                        <div class="flex justify-between text-brand-muted">
                            <span>Order Total</span>
                            <span class="text-brand-light font-medium">₹<%= cart.totalAmount.toLocaleString() %></span>
                        </div>
                        <% if (summaryCoupon > 0 && typeof appliedCoupon !== 'undefined' && appliedCoupon) { %>
                            <div class="flex justify-between text-brand-muted">
                                <span>Coupon (<%= appliedCoupon.code %>)</span>
                                <span class="text-green-400 font-semibold">- ₹<%= summaryCoupon.toLocaleString() %></span>
                            </div>
                        <% } %>
                        <div class="flex justify-between text-brand-muted">
                            <span>Delivery</span>
                            <span class="text-green-500 font-semibold">FREE</span>
                        </div>
                        <% if (summaryWallet > 0) { %>
                            <div class="flex justify-between text-brand-muted">
                                <span>Wallet Applied</span>
                                <span class="text-green-400 font-semibold">- ₹<%= summaryWallet.toLocaleString() %></span>
                            </div>
                        <% } %>
                        <div class="flex justify-between pt-5 border-t border-white/5">
                            <span class="text-brand-light font-bold">Payable Amount</span>
                            <span class="text-brand-accent font-extrabold text-2xl">₹<%= summaryPayable.toLocaleString() %></span>
                        </div>
                    </div>

                    <button id="payNowBtn"
                        data-amount="<%= summaryPayable %>"
                        data-razorpay-key="<%= razorpayKeyId %>"
                        data-address-id="<%= address._id %>"
                        data-use-wallet="<%= (typeof useWallet !== 'undefined' && useWallet) ? '1' : '0' %>"
                        data-wallet-covers-all="<%= summaryPayable === 0 ? '1' : '0' %>"
                        class="w-full py-4 bg-brand-accent hover:bg-yellow-500 text-brand-bg1 font-extrabold text-sm rounded-xl transition-all shadow-lg shadow-brand-accent/20 active:scale-95 flex items-center justify-center gap-3">
                        <span id="payBtnLabel"><%= summaryPayable === 0 ? 'Place Order (Wallet)' : 'Pay with Razorpay' %></span>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    </button>

                    <p class="mt-6 text-center text-[10px] text-brand-muted leading-relaxed">
                        <span class="flex items-center justify-center gap-1.5 mb-2">
                            <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                            SSL Secure & Encrypted
                        </span>
                        All transactions are secure and encrypted. Your card information is never stored on our servers.
                    </p>

                </div>
            </div>

        </div>
    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="/js/user/payment.js"></script>
