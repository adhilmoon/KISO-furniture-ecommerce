<div class="min-h-screen bg-brand-bg1 pt-28 pb-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">

        <!-- Success Animation -->
        <div class="relative mb-10">
            <div class="w-24 h-24 mx-auto rounded-full bg-green-500/10 border-2 border-green-500/30 flex items-center justify-center animate-bounce-slow">
                <svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <!-- Glow ring -->
            <div class="absolute inset-0 w-24 h-24 mx-auto rounded-full bg-green-500/5 animate-ping" style="animation-duration: 2s;"></div>
        </div>

        <!-- Heading -->
        <h1 class="text-3xl sm:text-4xl font-extrabold text-brand-light mb-3">Thank You for Your Order!</h1>
        <p class="text-brand-muted text-base mb-10 max-w-md mx-auto leading-relaxed">
            <% if (order.paymentMethod === 'razorpay') { %>
                Your payment was successful and your order has been confirmed. We'll start preparing it right away.
            <% } else { %>
                Your order has been placed successfully. Please pay on delivery.
            <% } %>
        </p>

        <!-- Order Details Card -->
        <div class="bg-brand-bg2 rounded-2xl border border-white/5 p-8 mb-8 text-left">

            <div class="flex items-center justify-between pb-5 border-b border-white/5 mb-5">
                <div>
                    <p class="text-[10px] font-bold text-brand-muted uppercase tracking-widest mb-1">Order Number</p>
                    <p class="text-brand-accent font-extrabold text-lg tracking-wide">#<%= order._id.toString().slice(-8).toUpperCase() %></p>
                </div>
                <div class="text-right">
                    <p class="text-[10px] font-bold text-brand-muted uppercase tracking-widest mb-1">Order Date</p>
                    <p class="text-brand-light font-semibold text-sm"><%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
                </div>
            </div>

            <!-- Items Summary -->
            <div class="space-y-3 mb-6">
                <% order.orderItems.forEach(item => { %>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-brand-bg1 border border-white/5 flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5 text-brand-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-brand-light text-sm font-medium truncate">
                                <%= item.productId?.productName || 'Product' %>
                            </p>
                            <p class="text-brand-muted text-xs">Qty: <%= item.quantity %></p>
                        </div>
                        <p class="text-brand-accent font-bold text-sm shrink-0">₹<%= (item.price * item.quantity).toLocaleString() %></p>
                    </div>
                <% }) %>
            </div>

            <!-- Delivery Address -->
            <div class="pt-5 border-t border-white/5 mb-6">
                <p class="text-[10px] font-bold text-brand-muted uppercase tracking-widest mb-2">Delivering To</p>
                <p class="text-brand-light font-semibold text-sm"><%= order.shippingAddress.name %></p>
                <p class="text-brand-muted text-xs leading-relaxed mt-0.5">
                    <%= order.shippingAddress.streetAddress %>, <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> – <%= order.shippingAddress.pincode %><br>
                    Phone: <%= order.shippingAddress.phone %>
                </p>
            </div>

            <!-- Totals -->
            <div class="pt-5 border-t border-white/5 space-y-2">
                <div class="flex justify-between text-sm text-brand-muted">
                    <span>Subtotal</span>
                    <span class="text-brand-light">₹<%= order.subtotal.toLocaleString() %></span>
                </div>
                <div class="flex justify-between text-sm text-brand-muted">
                    <span>Shipping</span>
                    <span class="text-green-500 font-semibold">FREE</span>
                </div>
                <% if (order.discount > 0) { %>
                <div class="flex justify-between text-sm text-brand-muted">
                    <span>Discount</span>
                    <span class="text-green-500">-₹<%= order.discount.toLocaleString() %></span>
                </div>
                <% } %>
                <div class="flex justify-between pt-3 border-t border-white/5">
                    <span class="text-brand-light font-bold"><%= order.paymentMethod === 'razorpay' ? 'Total Paid' : 'Total' %></span>
                    <span class="text-brand-accent font-extrabold text-xl">₹<%= order.grandTotal.toLocaleString() %></span>
                </div>
            </div>
        </div>

        <!-- Estimated Delivery -->
        <div class="bg-brand-bg2/50 rounded-xl border border-white/5 p-5 mb-10 flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-brand-accent/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div class="text-left">
                <p class="text-brand-light font-bold text-sm">Estimated Delivery</p>
                <%
                    const deliveryStart = new Date();
                    deliveryStart.setDate(deliveryStart.getDate() + 5);
                    const deliveryEnd = new Date();
                    deliveryEnd.setDate(deliveryEnd.getDate() + 7);
                    const fmtOpts = { day: 'numeric', month: 'short' };
                %>
                <p class="text-brand-muted text-xs"><%= deliveryStart.toLocaleDateString('en-IN', fmtOpts) %> – <%= deliveryEnd.toLocaleDateString('en-IN', fmtOpts) %></p>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/user/store" class="px-8 py-3.5 bg-brand-accent hover:bg-yellow-500 text-brand-bg1 font-bold text-sm rounded-xl transition-all shadow-lg shadow-brand-accent/20 active:scale-95 flex items-center justify-center gap-2">
                Continue Shopping
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7-7 7"/></svg>
            </a>
            <a href="/user/orders" class="px-8 py-3.5 bg-brand-bg2 hover:bg-white/5 text-brand-light font-bold text-sm rounded-xl border border-white/10 transition-all flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                View My Orders
            </a>
        </div>

    </div>
</div>

<style>
    @keyframes bounce-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }
    .animate-bounce-slow { animation: bounce-slow 2s ease-in-out infinite; }
</style>
