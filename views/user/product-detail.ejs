<div class="bg-brand-bg1 min-h-screen">
  <% if (isUnavailable) { %>
    <div class="max-w-3xl mx-auto px-4 pt-40 pb-20 flex flex-col items-center justify-center text-center min-h-[70vh]">
      <!-- Icon -->
      <div class="w-24 h-24 bg-red-500/10 rounded-full flex items-center justify-center mb-8 border border-red-500/20">
        <svg class="w-12 h-12 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9.172 9.172a4 4 0 015.656 5.656M15 9l-6 6" />
        </svg>
      </div>
  
      <!-- Title -->
      <h2 class="text-4xl font-bold text-white mb-4 tracking-tight">
        Product Unavailable
      </h2>

      <!-- Description -->
      <p class="text-brand-muted mb-10 max-w-lg text-lg leading-relaxed">
        We're sorry, but the product you're looking for is currently unavailable or has been removed. Explore our collection for similar premium pieces.
      </p>

      <!-- Buttons -->
      <div class="flex gap-4 flex-wrap justify-center">
        <!-- Back Button -->
        <button onclick="history.back()"
          class="px-8 py-4 rounded-xl border border-white/10 text-white font-bold tracking-[0.1em] uppercase text-sm hover:bg-white/5 hover:border-white/20 transition-all">
          ← Go Back
        </button>

        <!-- Store Button -->
        <a href="/user/store" class="px-8 py-4 rounded-xl bg-brand-accent text-brand-bg1 font-bold tracking-[0.1em] uppercase text-sm hover:opacity-90 transition-all shadow-[0_0_20px_rgba(212,175,55,0.2)]">
          Continue Shopping
        </a>
      </div>
    </div>
  <% } else { %>
        <!-- normal product UI -->
        <div class="max-w-7xl mx-auto px-4 md:px-8 pt-28 pb-8">
          <nav class="flex text-[11px] uppercase tracking-widest text-brand-muted/60 mb-8" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-2">
              <li><a href="/user/store" class="hover:text-brand-accent transition-colors">Store</a></li>
              <% if (product.category) { %>
                <li class="flex items-center gap-2">
                  <span>/</span>
                  <a href="/user/store?category=<%= product.category._id %>"
                    class="hover:text-brand-accent transition-colors">
                    <%= product.category.categoryName %>
                  </a>
                </li>
                <% } %>
            </ol>
          </nav>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

            <!-- LEFT: Gallery -->
            <div class="flex flex-col gap-4">
              <% let allImageObjects=[]; if (product.variants && product.variants.length> 0) {
                product.variants.forEach((v, vIdx) => {
                if (v.images) {
                v.images.forEach(img => {
                allImageObjects.push({ url: img, variantIndex: vIdx });
                });
                }
                });
                }
                %>
                <div
                  class="relative aspect-square md:aspect-[4/3] bg-brand-bg2 rounded-2xl overflow-hidden border border-white/5">
                  <img id="mainImage"
                    src="<%= allImageObjects.length ? allImageObjects[0].url : '/images/placeholder.png' %>"
                    class="w-full h-full object-cover">
                  <button id="wishlistBtn" onclick="toggleWishlist('<%= product._id %>')"
                    class="absolute top-4 right-4 backdrop-blur-sm p-2.5 rounded-full transition-all duration-300 z-10
                    <%= isInWishlist ? 'bg-brand-accent text-brand-bg1 opacity-100' : 'bg-brand-bg1/80 text-brand-muted hover:bg-brand-accent hover:text-brand-bg1' %>">
                    <svg class="w-5 h-5" fill="<%= isInWishlist ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                  </button>
                </div>

                <!-- Thumbnails -->
                <div class="flex gap-3 overflow-x-auto pb-1 hide-scrollbar" id="thumbnailContainer">
                  <% allImageObjects.forEach((imgObj, i)=> { %>
                    <button data-variant-index="<%= imgObj.variantIndex %>"
                      onclick="switchImage('<%= imgObj.url %>', this)"
                      class="thumb-btn flex-shrink-0 w-20 h-20 rounded-xl overflow-hidden border-2 transition-all duration-200 <%= imgObj.variantIndex === 0 ? '' : 'hidden' %> <%= i === 0 ? 'border-brand-accent' : 'border-white/10 hover:border-white/30' %> bg-brand-bg2 p-1">
                      <img src="<%= imgObj.url %>" alt="View <%= i+1 %>"
                        class="w-full h-full object-cover rounded-lg opacity-80 hover:opacity-100 transition-opacity">
                    </button>
                    <% }) %>
                </div>

                <!-- Trust badges -->
                <div class="grid grid-cols-4 gap-3 mt-4">
                  <div class="flex flex-col items-center gap-1.5 text-center">
                    <div
                      class="w-10 h-10 bg-brand-bg2 rounded-xl flex items-center justify-center border border-white/5">
                      <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                          d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" />
                        <path stroke-linecap="round" stroke-linejoin="round"
                          d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" />
                      </svg>
                    </div>
                    <span class="text-[11px] text-brand-muted">Solid Wood</span>
                  </div>
                  <div class="flex flex-col items-center gap-1.5 text-center">
                    <div
                      class="w-10 h-10 bg-brand-bg2 rounded-xl flex items-center justify-center border border-white/5">
                      <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                      </svg>
                    </div>
                    <span class="text-[11px] text-brand-muted">5yr Warranty</span>
                  </div>
                  <div class="flex flex-col items-center gap-1.5 text-center">
                    <div
                      class="w-10 h-10 bg-brand-bg2 rounded-xl flex items-center justify-center border border-white/5">
                      <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                          d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                      </svg>
                    </div>
                    <span class="text-[11px] text-brand-muted">Free Delivery</span>
                  </div>
                  <div class="flex flex-col items-center gap-1.5 text-center">
                    <div
                      class="w-10 h-10 bg-brand-bg2 rounded-xl flex items-center justify-center border border-white/5">
                      <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                          d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                      </svg>
                    </div>
                    <span class="text-[11px] text-brand-muted">EMI Available</span>
                  </div>
                </div>
            </div>

            <!-- RIGHT: Product Info -->
            <div class="flex flex-col gap-5">
              <div>
                <p class="text-xs font-bold tracking-[0.2em] uppercase text-brand-accent mb-2">
                  <% if (product.category) { %> KISO · <%= product.category.categoryName %>
                      <% } %>
                </p>
                <h1 class="text-3xl md:text-5xl font-bold text-brand-light leading-[1.1]">
                  <%= product.productName %>
                </h1>
              </div>

              <!-- Rating -->
              <div class="flex items-center gap-3">
                <div class="flex text-brand-accent text-sm">
                  ★★★★★
                </div>
                <span class="text-sm font-medium text-brand-light">5.0</span>
                <a href="#reviews"
                  class="text-sm text-brand-muted underline underline-offset-2 hover:text-brand-light transition-colors">
                  12 reviews
                </a>
              </div>

              <!-- Price -->
              <%
                const v0 = product.variants && product.variants[0];
                const offer0 = v0 && v0.bestOffer;
                const initialPrice = offer0 ? offer0.effectivePrice : (v0 ? v0.price : product.basePrice);
              %>
              <div class="bg-brand-bg2 rounded-2xl p-6 border border-white/5 mt-2">
                <div class="flex items-baseline flex-wrap gap-3 mb-1">
                  <span class="text-4xl font-bold text-brand-light" id="product-price">₹<%= initialPrice %></span>
                  <span id="product-original-price" class="text-xl text-brand-muted line-through <%= offer0 ? '' : 'hidden' %>">
                    ₹<%= offer0 ? offer0.originalPrice : '' %>
                  </span>
                  <span id="product-discount-badge" class="text-[11px] font-bold uppercase tracking-wider text-green-400 bg-green-400/10 border border-green-400/20 px-2 py-0.5 rounded <%= offer0 ? '' : 'hidden' %>">
                    <%= offer0 ? offer0.percentOff + '% Off' : '' %>
                  </span>
                </div>
                <p id="product-offer-name" class="text-xs text-brand-muted mt-2 <%= offer0 ? '' : 'hidden' %>">
                  Offer applied: <span class="text-brand-accent font-semibold"><%= offer0 ? offer0.name : '' %></span>
                </p>
              </div>

              <!-- Variants -->
              <% if(product.variants && product.variants.length> 0) { %>
                <div class="mt-4">
                  <p class="text-xs font-medium text-brand-muted uppercase tracking-wider mb-4">
                    Available Options
                  </p>
                  <div class="flex gap-3 flex-wrap">
                    <% product.variants.forEach((v, i)=> { %>
                      <button
                        onclick="selectVariant(this, '<%= v.price %>', '<%= v.images && v.images[0] ? v.images[0] : '' %>', <%= i %>, <%= v.stock %>)"
                        class="variant-btn flex flex-col items-center gap-2 border-2 rounded-xl p-2 transition-all <%= i === 0 ? 'border-brand-accent' : 'border-white/10 hover:border-white/30' %>"
                        data-stock="<%= v.stock %>"
                        data-original-price="<%= v.price %>"
                        data-effective-price="<%= v.bestOffer ? v.bestOffer.effectivePrice : v.price %>"
                        data-percent-off="<%= v.bestOffer ? v.bestOffer.percentOff : 0 %>"
                        data-offer-name="<%= v.bestOffer ? v.bestOffer.name : '' %>">
                        <div class="w-16 h-16 rounded-lg overflow-hidden bg-brand-bg1 p-1">
                          <img src="<%= v.images && v.images[0] ? v.images[0] : '/images/placeholder.png' %>"
                            alt="<%= v.optionValue %>" class="w-full h-full object-cover rounded-md">
                        </div>
                        <span class="text-[11px] text-brand-muted font-bold truncate px-1">
                          <%= v.optionValue %>
                        </span>
                      </button>
                      <% }) %>
                  </div>
                </div>
                <% } %>

                  <!-- Quantity -->
                  <div class="flex items-center gap-4 mt-4">
                    <div
                      class="flex items-center bg-brand-bg2 border border-white/10 rounded-xl overflow-hidden h-14 w-36">
                      <button type="button" onclick="changeQty(-1)"
                        class="w-12 h-full flex items-center justify-center text-brand-light hover:bg-white/5 transition-colors text-xl">−</button>
                      <span id="qtyDisplay"
                        class="flex-1 text-center text-lg font-bold border-x border-white/10 h-full flex items-center justify-center text-brand-light">1</span>
                      <button type="button" onclick="changeQty(1)"
                        class="w-12 h-full flex items-center justify-center text-brand-light hover:bg-white/5 transition-colors text-xl">+</button>
                    </div>
                    <span id="stock-status"
                      class="text-sm px-4 py-1.5 font-bold rounded-full transition-all duration-300">
                      <!-- Dynamically updated -->
                    </span>
                  </div>

                  <!-- CTA Buttons -->
                  <div class="flex gap-4 mt-2">
                    <button type="button" id="add-to-cart-btn" onclick="addToCart('<%= product._id %>')"
                      class="flex-1 py-4 text-sm font-bold tracking-[0.15em] uppercase text-brand-accent bg-brand-accent/10 border border-brand-accent rounded-xl hover:bg-brand-accent hover:text-brand-bg1 transition-all disabled:opacity-40 disabled:grayscale disabled:cursor-not-allowed">
                      Add to Cart
                    </button>
                    <button type="button" id="buy-now-btn" onclick="buyNow('<%= product._id %>')"
                      class="flex-1 py-4 text-sm font-bold tracking-[0.15em] uppercase text-brand-bg1 bg-brand-accent rounded-xl hover:opacity-90 transition-all shadow-[0_0_20px_rgba(212,175,55,0.2)] disabled:opacity-40 disabled:grayscale disabled:cursor-not-allowed disabled:shadow-none">
                      Buy Now
                    </button>
                  </div>

                  <!-- Offer Cards -->
                  <div class="mt-4">
                    <p class="text-xs font-medium text-brand-muted uppercase tracking-wider mb-3">Save extra with offers
                    </p>
                    <div class="grid grid-cols-3 gap-3">
                      <div class="bg-brand-bg2 border border-white/5 rounded-xl p-3 md:p-4 text-center">
                        <p class="text-xs font-semibold text-brand-accent mb-1">Store Discount</p>
                        <p class="text-[10px] text-brand-muted/80 leading-tight">Get instant extra discount</p>
                      </div>
                      <div class="bg-brand-bg2 border border-white/5 rounded-xl p-3 md:p-4 text-center">
                        <p class="text-xs font-semibold text-brand-accent mb-1">5% Instant</p>
                        <p class="text-[10px] text-brand-muted/80 leading-tight">Credit & Debit EMI</p>
                      </div>
                      <div class="bg-brand-bg2 border border-white/5 rounded-xl p-3 md:p-4 text-center">
                        <p class="text-xs font-semibold text-brand-accent mb-1">No Cost EMI</p>
                        <p class="text-[10px] text-brand-muted/80 leading-tight">From ₹2,791/month</p>
                      </div>
                    </div>
                  </div>
            </div>
          </div>

          <!-- TABS: Description / Specs / Reviews -->
          <div class="mt-20">
            <div class="flex border-b border-white/10" id="tabBar">
              <button onclick="showTab('description', this)"
                class="tab-btn px-8 py-4 text-sm font-bold tracking-widest uppercase text-brand-accent border-b-2 border-brand-accent -mb-px">Description</button>
              <button onclick="showTab('specifications', this)"
                class="tab-btn px-8 py-4 text-sm font-bold tracking-widest uppercase text-brand-muted hover:text-brand-light transition-colors border-b-2 border-transparent -mb-px">Specifications</button>
            </div>

            <div id="descriptionTab"
              class="tab-content py-10 text-brand-muted leading-relaxed text-sm max-w-4xl prose prose-invert">
              <%- product.description %>
            </div>

            <div id="specificationsTab"
              class="tab-content hidden py-10 text-brand-muted max-w-4xl border-t border-white/5">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% if (product.material) { %>
                  <div class="flex border-b border-white/5 py-3">
                    <span class="w-48 text-sm text-brand-muted font-bold tracking-wide">Material</span>
                    <span class="text-sm text-brand-light">
                      <%= product.material %>
                    </span>
                  </div>
                  <% } %>
                    <% if (product.dimensions) { %>
                      <div class="flex border-b border-white/5 py-3">
                        <span class="w-48 text-sm text-brand-muted font-bold tracking-wide">Dimensions (cm)</span>
                        <span class="text-sm text-brand-light">
                          <%= product.dimensions.width %>W x <%= product.dimensions.height %>H x <%=
                                product.dimensions.depth %>D
                        </span>
                      </div>
                      <% } %>
                        <% if (product.customAttributes && product.customAttributes.length> 0) { %>
                          <% product.customAttributes.forEach((attr)=> { %>
                            <div class="flex border-b border-white/5 py-3">
                              <span class="w-48 text-sm text-brand-muted font-bold tracking-wide">
                                <%= attr.key %>
                              </span>
                              <span class="text-sm text-brand-light">
                                <%= attr.value %>
                              </span>
                            </div>
                            <% }) %>
                              <% } %>
              </div>
            </div>
          </div>
          <!-- Related Products -->
          <div class="mt-20">
            <h2 class="text-2xl font-bold text-brand-light mb-6">
              Related Products
            </h2>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
              <% if (relatedProducts && relatedProducts.length> 0) { %>
                <% relatedProducts.forEach(p=> { %>
                  <a href="/user/product/<%= p._id %>"
                    class="block bg-brand-bg2 rounded-xl p-4 border border-white/5 hover:border-brand-accent/40 transition-colors duration-300">

                    <img src="<%= p.variants && p.variants[0]?.images[0] %>"
                      class="w-full h-40 object-cover rounded-lg mb-3">

                    <h3 class="text-sm text-brand-light font-semibold">
                      <%= p.productName %>
                    </h3>

                    <% if (p.bestOffer) { %>
                      <p class="text-brand-accent font-bold mt-1">
                        ₹<%= p.bestOffer.effectivePrice %>
                        <span class="text-xs text-brand-muted line-through ml-1 font-medium">₹<%= p.bestOffer.originalPrice %></span>
                      </p>
                    <% } else { %>
                      <p class="text-brand-accent font-bold mt-1">₹<%= p.variants && p.variants[0]?.price %></p>
                    <% } %>

                    <span class="block mt-3 text-xs text-brand-accent">
                      View Product →
                    </span>

                  </a>
                  <% }) %>
                    <% } else { %>
                      <p class="text-brand-muted">No related products found</p>
                      <% } %>
            </div>
          </div>
        </div>
        <% } %>

    </div>

    <script src="/js/user/productDetail.js"></script>