<div class="min-h-screen bg-brand-bg1 pt-24 pb-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- ── Header ──────────────────────────────────────────── -->
        <div class="mb-4">
            <% 
               let pageTitle = "Kiso Store";
               if (activeFilters.categoryId) { 
                   const activeCat = categories.find(c => String(c._id) === activeFilters.categoryId);
                   if (activeCat) {
                       pageTitle = activeCat.categoryName;
                   }
               }
            %>
            <h1 class="text-4xl md:text-5xl font-bold text-brand-light mb-4"><%= pageTitle %></h1>
        </div>

        <!-- ── Search & Sort ──────────────────────────────────────── -->
        <div class="flex flex-col md:flex-row items-center gap-4 mb-8">
            <!-- Search -->
            <div class="flex items-center flex-1 bg-brand-bg2/80 backdrop-blur-md border border-white/10
                hover:border-brand-accent/40 focus-within:border-brand-accent rounded-xl px-4 py-3 gap-3
                transition-all duration-300 shadow-sm focus-within:shadow-[0_0_0_2px_rgba(212,175,55,0.2)]">
                <svg class="w-5 h-5 text-brand-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <input type="text" id="searchInput" placeholder="Search furniture..."
                    value="<%= searchQuery %>"
                    oninput="handleSearchDebounced()"
                    class="bg-transparent outline-none text-brand-light placeholder:text-brand-muted/60 text-sm w-full"/>
                <button type="button" id="clearSearchBtn" onclick="clearSearch()"
                    class="<%= searchQuery ? '' : 'hidden' %> text-brand-muted hover:text-white text-lg transition">&times;</button>
            </div>

            <!-- Sort -->
            <div class="w-full md:w-64">
                <select id="sortSelect" onchange="applySort()"
                    class="w-full bg-brand-bg2/80 backdrop-blur-md border border-white/10 text-brand-light text-sm rounded-xl px-4 py-3 outline-none focus:border-brand-accent transition-all cursor-pointer appearance-none">
                    <option value="newest" <%= activeSort === 'newest' ? 'selected' : '' %>>New Arrivals</option>
                    <option value="price-low" <%= activeSort === 'price-low' ? 'selected' : '' %>>Price: Low to High</option>
                    <option value="price-high" <%= activeSort === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
                    <option value="a-z" <%= activeSort === 'a-z' ? 'selected' : '' %>>Name: A-Z</option>
                    <option value="z-a" <%= activeSort === 'z-a' ? 'selected' : '' %>>Name: Z-A</option>
                </select>
            </div>
        </div>

        <!-- ── Active filter chips ──────────────────────────────── -->
        <div id="activeFilterChips" class="flex flex-wrap gap-2 mb-6">
            <% if (activeFilters.categoryId) { %>
                <% const activeCat = categories.find(c => String(c._id) === activeFilters.categoryId); %>
                <% if (activeCat) { %>
                    <span class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-brand-accent/10 border border-brand-accent/30 text-brand-accent text-xs font-medium">
                        Category: <%= activeCat.categoryName %>
                        <button onclick="removeCategoryFilter()" class="hover:text-white transition">&times;</button>
                    </span>
                <% } %>
            <% } %>
            <% if (activeFilters.minPrice > 0 || activeFilters.maxPrice > 0) { %>
                <span class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-brand-accent/10 border border-brand-accent/30 text-brand-accent text-xs font-medium">
                    Price:
                    <%= activeFilters.minPrice > 0 ? '₹' + activeFilters.minPrice : '₹0' %>
                    –
                    <%= activeFilters.maxPrice > 0 ? '₹' + activeFilters.maxPrice : 'Any' %>
                    <button onclick="removePriceFilter()" class="hover:text-white transition">&times;</button>
                </span>
            <% } %>
        </div>

        <!-- ── Layout: Sidebar + Grid ──────────────────────────── -->
        <div class="flex gap-8">

            <!-- Sidebar -->
            <aside class="hidden lg:block w-64 flex-shrink-0">
                <%- include('../partials/user/storesidebar') %>
            </aside>

            <!-- Products -->
            <div class="flex-1">

                <!-- Grid -->
                <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                                <% 
                                   const productLink = `/user/product/${product._id}`;
                                   const displayVariantIndex = (product.variants || []).findIndex(v => v.stock > 0);
                                   const finalVariantIndex = displayVariantIndex > -1 ? displayVariantIndex : 0;
                                   const displayVariant = product.variants && product.variants.length > 0 ? product.variants[finalVariantIndex] : null;
                                %>
                                <div class="group">
                                    <div class="bg-brand-bg2 rounded-xl overflow-hidden border border-white/5
                                        hover:border-brand-accent/40 transition-all duration-500
                                        hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(212,175,55,0.15)]">

                                        <!-- Image -->
                                        <div class="relative aspect-square overflow-hidden bg-brand-bg1 flex items-center justify-center">
                                            <a href="<%= productLink %>" class="w-full h-full">
                                                <img src="<%= displayVariant?.images?.[0] || product.img || '/images/placeholder.png' %>"
                                                    alt="<%= product.productName %>"
                                                    class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700 ease-in-out">
                                            </a>

                                            <!-- Wishlist -->
                                            <button onclick="toggleWishlist('<%= product._id %>')"
                                                class="absolute top-4 right-4 bg-brand-bg1/80 backdrop-blur-sm p-2.5 rounded-full
                                                hover:bg-brand-accent hover:text-brand-bg1 transition-all duration-300
                                                opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                                                </svg>
                                            </button>

                                            <!-- Quick View -->
                                            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300
                                                flex items-center justify-center opacity-0 group-hover:opacity-100 pointer-events-none">
                                                <a href="<%= productLink %>" class="px-6 py-2 bg-brand-accent text-brand-bg1 font-semibold rounded-lg
                                                    transform scale-75 group-hover:scale-100 transition-transform duration-300 pointer-events-auto">
                                                    View Details
                                                </a>
                                            </div>
                                        </div>

                                        <!-- Info -->
                                        <div class="p-5">
                                            <a href="<%= productLink %>" class="block">
                                                <h3 class="text-lg font-bold text-brand-light mb-1 line-clamp-2 hover:text-brand-accent transition-colors"><%= product.productName %></h3>
                                            </a>
                                            <p class="text-sm text-brand-muted mb-4"><%= product.category?.categoryName || 'Furniture' %></p>

                                            <!-- Price -->
                                            <div class="flex items-baseline gap-2 mb-4">
                                                <span class="text-xl font-bold text-brand-accent">
                                                    ₹<%= displayVariant ? displayVariant.price : product.basePrice %>
                                                </span>
                                                <% if (displayVariant && product.basePrice && product.basePrice > displayVariant.price) { %>
                                                    <span class="text-sm text-brand-muted line-through">₹<%= product.basePrice %></span>
                                                <% } %>
                                            </div>

                                            <!-- Stock -->
                                            <div class="mb-4">
                                                <% if (product.totalQuantity <= 0) { %>
                                                    <span class="text-xs font-semibold text-red-400">Out of Stock</span>
                                                <% } else if (product.totalQuantity <= 5) { %>
                                                    <span class="text-xs font-semibold text-orange-400">Only <%= product.totalQuantity %> left</span>
                                                <% } else { %>
                                                    <span class="text-xs font-semibold text-green-400">In Stock</span>
                                                <% } %>
                                            </div>

                                            <!-- Add to Cart -->
                                            <button <%= product.totalQuantity === 0 ? 'disabled' : '' %>
                                                onclick="addToCartFromStore('<%= product._id %>', <%= finalVariantIndex %>)"
                                                class="w-full px-4 py-3 bg-brand-accent hover:bg-yellow-600 text-brand-bg1 font-semibold
                                                rounded-lg transition-all transform hover:scale-105 active:scale-95
                                                flex items-center justify-center gap-2
                                                disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                                </svg>
                                                <%= product.totalQuantity === 0 ? 'Unavailable' : 'Add to Cart' %>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-span-full flex flex-col items-center justify-center py-20">
                            <svg class="w-16 h-16 text-brand-muted mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M20 7l-8-4-8 4m0 0l-2 1m2-1v10l8 4 8-4V7m-8 4l8-4m0 0V3m0 4L4 7"/>
                            </svg>
                            <p class="text-brand-muted text-lg">
                                <% if (searchQuery) { %>No products found for "<%= searchQuery %>"
                                <% } else { %>No products match your filters<% } %>
                            </p>
                            <button onclick="clearFilters()" class="mt-4 text-brand-accent text-sm hover:underline">Clear filters</button>
                        </div>
                    <% } %>
                </div>

                <!-- ── Pagination ──────────────────────────────── -->
                <%
                  // Build a base query string that carries all active filters into page links
                  const qp = [];
                  if (searchQuery)              qp.push(`search=${encodeURIComponent(searchQuery)}`);
                  if (activeFilters.categoryId) qp.push(`category=${encodeURIComponent(activeFilters.categoryId)}`);
                  if (activeFilters.minPrice>0) qp.push(`minPrice=${activeFilters.minPrice}`);
                  if (activeFilters.maxPrice>0) qp.push(`maxPrice=${activeFilters.maxPrice}`);
                  const baseQS = qp.length ? '&' + qp.join('&') : '';
                %>
                <% if (totalPages > 1) { %>
                    <div class="flex items-center justify-center gap-2 flex-wrap">

                        <!-- Prev -->
                        <a href="/user/store?page=<%= Math.max(1, currentPage - 1) %><%= baseQS %>"
                            class="p-2 border border-white/10 rounded-lg hover:bg-brand-bg2 text-brand-muted hover:text-brand-light transition-colors
                            <%= currentPage === 1 ? 'opacity-50 cursor-not-allowed' : '' %>"
                            <%= currentPage === 1 ? 'onclick="return false"' : '' %>>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                            </svg>
                        </a>

                        <!-- Pages -->
                        <%
                          let startPage = Math.max(1, currentPage - 2);
                          let endPage   = Math.min(totalPages, currentPage + 2);
                          if (endPage - startPage < 4) {
                            if (startPage === 1) endPage = Math.min(totalPages, startPage + 4);
                            else startPage = Math.max(1, endPage - 4);
                          }
                        %>
                        <% if (startPage > 1) { %>
                            <a href="/user/store?page=1<%= baseQS %>"
                                class="px-4 py-2 rounded-lg font-medium transition-all border border-white/10 text-brand-light hover:bg-brand-bg2">1</a>
                            <% if (startPage > 2) { %><span class="text-brand-muted">…</span><% } %>
                        <% } %>

                        <% for (let i = startPage; i <= endPage; i++) { %>
                            <a href="/user/store?page=<%= i %><%= baseQS %>"
                                class="px-4 py-2 rounded-lg font-medium transition-all
                                <%= i === currentPage ? 'bg-brand-accent text-brand-bg1' : 'border border-white/10 text-brand-light hover:bg-brand-bg2' %>">
                                <%= i %>
                            </a>
                        <% } %>

                        <% if (endPage < totalPages) { %>
                            <% if (endPage < totalPages - 1) { %><span class="text-brand-muted">…</span><% } %>
                            <a href="/user/store?page=<%= totalPages %><%= baseQS %>"
                                class="px-4 py-2 rounded-lg font-medium transition-all border border-white/10 text-brand-light hover:bg-brand-bg2">
                                <%= totalPages %>
                            </a>
                        <% } %>

                        <!-- Next -->
                        <a href="/user/store?page=<%= Math.min(totalPages, currentPage + 1) %><%= baseQS %>"
                            class="p-2 border border-white/10 rounded-lg hover:bg-brand-bg2 text-brand-muted hover:text-brand-light transition-colors
                            <%= currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : '' %>"
                            <%= currentPage === totalPages ? 'onclick="return false"' : '' %>>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </a>

                    </div>

                    <div class="text-center mt-6 text-sm text-brand-muted">
                        Page <span class="text-brand-accent font-semibold"><%= currentPage %></span>
                        of <span class="text-brand-accent font-semibold"><%= totalPages %></span>
                    </div>
                <% } %>

            </div><!-- /products -->
        </div><!-- /flex layout -->
    </div>
</div>


<script src="/js/user/storeManagement.js"></script>