<div class="min-h-screen bg-brand-bg1 pt-24 pb-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Header with Search -->
        <div class="mb-12">
            <h1 class="text-4xl md:text-5xl font-bold text-brand-light mb-4">
                Kiso Store
            </h1>
            <p class="text-sm text-brand-muted mb-8 flex items-center gap-2">
                <span class="text-brand-light font-medium">Showing</span>

                <span class="px-2 py-0.5 rounded-md bg-brand-accent/10 text-brand-accent font-semibold">
                    <%= products.length %>
                </span>

                <span>of</span>

                <span class="px-2 py-0.5 rounded-md bg-white/5 text-brand-light font-semibold">
                    <%= totalProducts %>
                </span>

                <span class="text-brand-muted">products</span>
            </p>

            <!-- Search Form -->
        </div>
        <div
            class="flex items-center max-w-md mb-10 bg-brand-bg2/80 backdrop-blur-md border border-white/10 hover:border-brand-accent/40 focus-within:border-brand-accent rounded-xl px-4 py-3 gap-3 transition-all duration-300 shadow-sm focus-within:shadow-[0_0_0_2px_rgba(212,175,55,0.2)]">

            <!-- Icon -->
            <svg class="w-5 h-5 text-brand-muted group-focus-within:text-brand-accent transition-colors" fill="none"
                stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>

            <!-- Input -->
            <input type="text" id="searchInput" placeholder="Search furniture..." oninput="handleSearchDebounced()"
                class="bg-transparent outline-none text-brand-light placeholder:text-brand-muted/60 text-sm w-full" />

            <!-- Clear button -->
            <button type="button" id="clearSearchBtn" onclick="clearSearch()"
                class="hidden text-brand-muted hover:text-white text-lg transition">
                &times;
            </button>

        </div>
<div class="flex gap-8">
        <aside class="hidden lg:block w-64 flex-shrink-0 sticky top-24 h-fit">
            <%- include('../partials/user/storesidebar') %>
        </aside>

        <!-- 🔹 PRODUCTS -->
     <div class="flex-1">
            <!-- Products Grid -->
            <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
                <% if(products && products.length> 0) { %>
                    <% products.forEach(product=> { %>
                        <div class="group">
                            <div
                                class="bg-brand-bg2 rounded-xl overflow-hidden border border-white/5 hover:border-brand-accent/40 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(212,175,55,0.15)]">

                                <!-- Product Image -->
                                <div
                                    class="relative aspect-square overflow-hidden bg-brand-bg1 flex items-center justify-center">
                                    <img src="<%= product.variants?.[0]?.images?.[0] || product.img %>"
                                        alt="<%= product.productName %>"
                                        class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700 ease-in-out">

                                    <!-- Wishlist Button -->
                                    <button
                                        class="absolute top-4 right-4 bg-brand-bg1/80 backdrop-blur-sm p-2.5 rounded-full hover:bg-brand-accent hover:text-brand-bg1 transition-all duration-300 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                        </svg>
                                    </button>

                                    <!-- Quick View Badge -->
                                    <div
                                        class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100">
                                        <button
                                            class="px-6 py-2 bg-brand-accent text-brand-bg1 font-semibold rounded-lg transform scale-75 group-hover:scale-100 transition-transform duration-300">
                                            Quick View
                                        </button>
                                    </div>
                                </div>

                                <!-- Product Info -->
                                <div class="p-5">
                                    <h3 class="text-lg font-bold text-brand-light mb-1 line-clamp-2">
                                        <%= product.productName %>
                                    </h3>
                                    <p class="text-sm text-brand-muted mb-4">
                                        <%= product.category?.categoryName || 'Furniture' %>
                                    </p>

                                    <!-- Price -->
                                    <div class="flex items-baseline gap-2 mb-4">

                                        <% const firstVariant=product.variants && product.variants.length> 0 ?
                                            product.variants[0] : null; %>

                                            <span class="text-xl font-bold text-brand-accent">
                                                ₹<%= firstVariant ? firstVariant.price : product.basePrice %>
                                            </span>

                                            <% if (firstVariant && product.basePrice && product.basePrice>
                                                firstVariant.price) { %>
                                                <span class="text-sm text-brand-muted line-through">
                                                    ₹<%= product.basePrice %>
                                                </span>
                                                <% } %>

                                    </div>

                                    <!-- Stock Status -->
                                    <div class="mb-4">
                                        <% if(product.totalQuantity> 0) { %>
                                            <span class="text-xs font-semibold text-green-400">
                                                In Stock (<%= product.totalQuantity %>)
                                            </span>
                                            <% } else { %>
                                                <span class="text-xs font-semibold text-red-400">
                                                    Out of Stock
                                                </span>
                                                <% } %>
                                    </div>

                                    <!-- Add to Cart Button -->
                                    <button <%=product.totalQuantity===0 ? 'disabled' : '' %>
                                        class="w-full px-4 py-3 bg-brand-accent hover:bg-yellow-600 text-brand-bg1
                                        font-semibold rounded-lg transition-all transform hover:scale-105
                                        active:scale-95
                                        flex items-center justify-center gap-2 disabled:opacity-50
                                        disabled:cursor-not-allowed disabled:hover:scale-100">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 4v16m8-8H4" />
                                        </svg>
                                        <%= product.totalQuantity===0 ? 'Unavailable' : 'Add to Cart' %>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                            <% } else { %>
                                <div class="col-span-full flex flex-col items-center justify-center py-20">
                                    <svg class="w-16 h-16 text-brand-muted mb-4 opacity-50" fill="none"
                                        stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M20 7l-8-4-8 4m0 0l-2 1m2-1v10l8 4 8-4V7m-8 4l8-4m0 0V3m0 4L4 7" />
                                    </svg>
                                    <p class="text-brand-muted text-lg">
                                        <% if(searchQuery) { %>
                                            No products found for "<%= searchQuery %>"
                                                <% } else { %>
                                                    No products available
                                                    <% } %>
                                    </p>
                                </div>
                                <% } %>
            </div>

            <!-- Pagination -->
            <% if(totalPages> 1) { %>
                <div class="flex items-center justify-center gap-2 flex-wrap">

                    <!-- Previous Button -->
                    <a href="/store?page=<%= Math.max(1, currentPage - 1) %><%= searchQuery ? `&search=${searchQuery}` : '' %>"
                        class="p-2 border border-white/10 rounded-lg hover:bg-brand-bg2 text-brand-muted hover:text-brand-light transition-colors <%= currentPage === 1 ? 'opacity-50 cursor-not-allowed' : '' %>"
                        <%=currentPage===1 ? 'onclick="return false"' : '' %>
                        >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                    </a>

                    <!-- Page Numbers -->
                    <% let startPage=Math.max(1, currentPage - 2); let endPage=Math.min(totalPages, currentPage + 2); if
                        (endPage - startPage < 4) { if (startPage===1) { endPage=Math.min(totalPages, startPage + 4); }
                        else { startPage=Math.max(1, endPage - 4); } } %>

                        <!-- First page if not in range -->
                        <% if(startPage> 1) { %>
                            <a href="/user/store?page=1<%= searchQuery ? `&search=${searchQuery}` : '' %>"
                                class="px-4 py-2 rounded-lg font-medium transition-all border border-white/10 text-brand-light hover:bg-brand-bg2">
                                1
                            </a>
                            <% if(startPage> 2) { %>
                                <span class="text-brand-muted">...</span>
                                <% } %>
                                    <% } %>

                                        <!-- Page number buttons -->
                                        <% for(let i=startPage; i <=endPage; i++) { %>
                                            <a href="/user/store?page=<%= i %><%= searchQuery ? `&search=${searchQuery}` : '' %>"
                                                class="px-4 py-2 rounded-lg font-medium transition-all <%= i === currentPage ? 'bg-brand-accent text-brand-bg1' : 'border border-white/10 text-brand-light hover:bg-brand-bg2' %>">
                                                <%= i %>
                                            </a>
                                            <% } %>

                                                <!-- Last page if not in range -->
                                                <% if(endPage < totalPages) { %>
                                                    <% if(endPage < totalPages - 1) { %>
                                                        <span class="text-brand-muted">...</span>
                                                        <% } %>
                                                            <a href="/store?page=<%= totalPages %><%= searchQuery ? `&search=${searchQuery}` : '' %>"
                                                                class="px-4 py-2 rounded-lg font-medium transition-all border border-white/10 text-brand-light hover:bg-brand-bg2">
                                                                <%= totalPages %>
                                                            </a>
                                                            <% } %>

                                                                <!-- Next Button -->
                                                                <a href="/store?page=<%= Math.min(totalPages, currentPage + 1) %><%= searchQuery ? `&search=${searchQuery}` : '' %>"
                                                                    class="p-2 border border-white/10 rounded-lg hover:bg-brand-bg2 text-brand-muted hover:text-brand-light transition-colors <%= currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : '' %>"
                                                                    <%=currentPage===totalPages
                                                                    ? 'onclick="return false"' : '' %>
                                                                    >
                                                                    <svg class="w-5 h-5" fill="none"
                                                                        stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round"
                                                                            stroke-linejoin="round" stroke-width="2"
                                                                            d="M9 5l7 7-7 7" />
                                                                    </svg>
                                                                </a>
                </div>

                <!-- Page Info -->
                <div class="text-center mt-6 text-sm text-brand-muted">
                    Page <span class="text-brand-accent font-semibold">
                        <%= currentPage %>
                    </span> of <span class="text-brand-accent font-semibold">
                        <%= totalPages %>
                    </span>
                </div>
                <% } %>
         </div>
       </div>
    </div>
</div>
    <script src="/js/user/storeManagement.js"></script>