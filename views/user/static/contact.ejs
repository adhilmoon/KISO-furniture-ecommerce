<section class="max-w-4xl mx-auto px-6 py-20 text-brand-light">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-accent font-bold mb-3">Contact</p>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Get in touch.</h1>
    <p class="text-brand-muted mb-10">We usually reply within one business day.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

        <!-- Info -->
        <aside class="space-y-6">
            <% if (locals.site?.contact?.email) { %>
                <div>
                    <p class="text-xs uppercase tracking-widest text-brand-muted mb-1">Email</p>
                    <a href="mailto:<%= locals.site.contact.email %>"
                        class="text-brand-light hover:text-brand-accent transition-colors break-all">
                        <%= locals.site.contact.email %>
                    </a>
                </div>
            <% } %>
            <% if (locals.site?.contact?.phone) { %>
                <div>
                    <p class="text-xs uppercase tracking-widest text-brand-muted mb-1">Phone</p>
                    <a href="tel:<%= locals.site.contact.phone.replace(/\s+/g, '') %>"
                        class="text-brand-light hover:text-brand-accent transition-colors">
                        <%= locals.site.contact.phone %>
                    </a>
                </div>
            <% } %>
            <div>
                <p class="text-xs uppercase tracking-widest text-brand-muted mb-1">Hours</p>
                <p class="text-sm">Mon – Fri, 9:00 – 18:00 IST</p>
            </div>
        </aside>

        <!-- Form -->
        <form id="contactForm" class="md:col-span-2 space-y-4" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-brand-muted uppercase tracking-widest mb-2">Name</label>
                    <input type="text" name="name" required maxlength="100"
                        class="w-full bg-brand-bg2 border border-white/10 rounded-xl px-4 py-2.5 text-brand-light text-sm outline-none focus:border-brand-accent/40" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-brand-muted uppercase tracking-widest mb-2">Email</label>
                    <input type="email" name="email" required maxlength="150"
                        class="w-full bg-brand-bg2 border border-white/10 rounded-xl px-4 py-2.5 text-brand-light text-sm outline-none focus:border-brand-accent/40" />
                </div>
            </div>
            <div>
                <label class="block text-xs font-semibold text-brand-muted uppercase tracking-widest mb-2">Subject</label>
                <input type="text" name="subject" maxlength="150"
                    class="w-full bg-brand-bg2 border border-white/10 rounded-xl px-4 py-2.5 text-brand-light text-sm outline-none focus:border-brand-accent/40" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-brand-muted uppercase tracking-widest mb-2">Message</label>
                <textarea name="message" rows="5" required maxlength="2000"
                    class="w-full bg-brand-bg2 border border-white/10 rounded-xl px-4 py-2.5 text-brand-light text-sm outline-none focus:border-brand-accent/40 resize-y"></textarea>
            </div>
            <button type="submit"
                class="px-8 py-3 bg-brand-accent text-brand-bg1 font-bold text-xs uppercase tracking-widest hover:scale-105 transition-transform">
                Send Message
            </button>
        </form>
    </div>
</section>

<script>
    (function () {
        const form = document.getElementById('contactForm');
        if (!form) return;
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = Object.fromEntries(new FormData(form));
            try {
                const res = await axios.post('/user/contact', data);
                if (res.data.success) {
                    showToast(res.data.message, 'success');
                    form.reset();
                }
            } catch (err) {
                showToast(err.response?.data?.message || 'Failed to send message', 'error');
            }
        });
    })();
</script>
