<div class="flex-grow flex items-center justify-center px-4 py-12 bg-brand-bg1 min-h-screen">
    <div class="w-full max-w-md bg-brand-bg1 p-8 rounded-2xl shadow-sm border border-gray-100">
        <h1 class="text-3xl text-center mb-2 font-normal text-kiso-text">Reset Password</h1>
        <p class="text-center text-brand-muted mb-8 text-sm">Please enter your new password below.</p>

        <form id="resetPasswordForm" onsubmit="handleResetPassword(event)" class="space-y-6" novalidate>
            <div class="space-y-2">
                <label class="block text-sm font-medium text-kiso-text">New Password</label>
                <input type="password" id="password" name="newPassword" placeholder="••••••••"
                    class="w-full px-4 py-3 bg-brand-bg2 border border-white/5 rounded-lg focus:outline-none focus:border-kiso-brown transition-colors"
                    required>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-medium text-kiso-text">Confirm New Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••"
                    class="w-full px-4 py-3 bg-brand-bg2 border border-white/5 rounded-lg focus:outline-none focus:border-kiso-brown transition-colors"
                    required>
            </div>

          

            <div id="reset-error" class="text-center mt-4 text-sm font-medium text-red-500"></div>
            <div class="flex items-center justify-between">
                <label for="showPasswordToggle" class="flex items-center cursor-pointer">
                    <div class="relative">
                    
                        <input type="checkbox" id="showPasswordToggle" class="peer sr-only"
                            onchange="togglePasswordVisibility()">

                     
                        <div
                            class="block w-12 h-6 bg-gray-300 rounded-full peer-checked:bg-[#9A7556] transition-colors">
                        </div>

                 
                        <div
                            class="absolute left-1 top-1 bg-brand-bg1 w-4 h-4 rounded-full transition-transform peer-checked:translate-x-6">
                        </div>
                    </div>
                    <span class="ml-3 text-sm font-medium text-brand-light">Show Password</span>
                </label>
            </div>
              <button type="submit"
                class="w-full bg-kiso-brown text-white py-3 rounded-lg font-medium hover:bg-kiso-brown-dark transition-colors">
                Update Password
            </button>
        </form>
    </div>

</div>
<script src="/js/user/forgotPassword.js"></script>
<script src="/js/user/handleSignup.js"></script>