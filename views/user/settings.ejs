<div class="w-full max-w-4xl mx-auto px-4 py-8 space-y-6">

    <h1 class="text-2xl font-bold text-brand-light">Account Settings</h1>

    <!-- Email -->
    <section class="bg-brand-bg1 p-6 rounded-2xl shadow-sm border border-white/5">
        <h2 class="text-lg font-semibold text-brand-light mb-4">Email Address</h2>
        <div class="flex items-center justify-between gap-4">
            <div class="min-w-0">
                <p class="text-sm text-brand-muted">Current Email</p>
                <p class="font-medium text-brand-light truncate"><%= user.email %></p>
            </div>
            <% if (!user.googleId) { %>
                <button type="button" onclick="showEmailModal()"
                    class="shrink-0 text-sm text-brand-accent hover:underline">Change Email</button>
            <% } else { %>
                <span class="shrink-0 text-xs bg-brand-bg2 px-3 py-1 rounded-full text-brand-muted border border-white/5">
                    <i class="fab fa-google mr-1"></i> Google Auth User
                </span>
            <% } %>
        </div>
    </section>

    <!-- Security -->
    <% if (!user.googleId) { %>
        <section class="bg-brand-bg1 p-6 rounded-2xl shadow-sm border border-white/5">
            <div class="flex items-center justify-between gap-4">
                <h2 class="text-lg font-semibold text-brand-light">Security</h2>
                <button type="button" id="togglePasswordForm"
                    class="shrink-0 text-sm text-brand-accent hover:underline">
                    Change Password
                </button>
            </div>

            <form id="changePasswordForm" class="space-y-4 mt-5 hidden" novalidate>
                <div>
                    <label class="block text-sm text-brand-muted">Current Password</label>
                    <input type="password" name="currentPassword" id="currentPassword"
                        class="w-full border border-white/5 rounded-md p-2 mt-1 text-black bg-white">
                </div>
                <div>
                    <label class="block text-sm text-brand-muted">New Password</label>
                    <input type="password" name="newPassword" id="newPassword"
                        class="w-full border border-white/5 rounded-md p-2 mt-1 text-black bg-white">
                </div>

                <div class="flex items-center justify-between">
                    <label for="showPasswordToggle" class="flex items-center cursor-pointer">
                        <div class="relative">
                            <input type="checkbox" id="showPasswordToggle" class="peer sr-only"
                                onchange="togglePasswordVisibility()">
                            <div class="block w-12 h-6 bg-gray-300 rounded-full peer-checked:bg-[#9A7556] transition-colors"></div>
                            <div class="absolute left-1 top-1 bg-brand-bg1 w-4 h-4 rounded-full transition-transform peer-checked:translate-x-6"></div>
                        </div>
                        <span class="ml-3 text-sm font-medium text-brand-light">Show Password</span>
                    </label>
                </div>

                <p id="pass-error" class="text-red-500 text-xs font-medium min-h-[1rem]"></p>

                <div class="flex gap-3 pt-2">
                    <button type="button" id="cancelPasswordChange"
                        class="px-4 py-2 border border-white/10 text-brand-light rounded-md hover:bg-brand-bg2 transition">
                        Cancel
                    </button>
                    <button type="submit"
                        class="bg-black text-white px-4 py-2 rounded-md hover:bg-zinc-800 transition">
                        Update Password
                    </button>
                </div>
            </form>
        </section>
    <% } else { %>
        <section class="bg-brand-bg2 p-6 rounded-2xl border border-white/5 italic text-brand-muted text-sm">
            You are logged in via Google. Password management is handled by your Google Account.
        </section>
    <% } %>

    <%- include('./email-modal') %>
    <%- include('./otp-modal') %>
</div>

<script src="/js/user/settings.js"></script>
